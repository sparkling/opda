# Copy to .env and fill in real values. `.env` is gitignored.

# TailwindPlus subscription credentials, consumed by `pnpm tailwindplus:download`
# which wraps the @richardkmichael/tailwindplus-downloader CLI.
# Get them by signing up at https://tailwindcss.com/plus
TAILWINDPLUS_EMAIL=
TAILWINDPLUS_PASSWORD=

# Artalk (comments backend on Railway). The admin password is the only
# secret here — the URL and email are baked into the public site.
# Seeded into the container via ATK_ADMIN_USERS_0_PASSWORD env var on
# Railway; change in the dashboard after first login then update here.
ARTALK_URL=https://artalk-production-4ade.up.railway.app
ARTALK_ADMIN_EMAIL=
ARTALK_ADMIN_PASSWORD=

# Artalk JWT signing key — needed by the SSO bridge to mint Artalk session tokens server-side.
# Set as ATK_APP_KEY on Railway; same value here so the Pages Function can sign tokens.
ARTALK_APP_KEY=

# ──────────────────────────────────────────────────────────────────────
# Domain migration → opda.org.uk (Cloudflare Pages custom domain + Porkbun DNS)
# ──────────────────────────────────────────────────────────────────────
# Porkbun REST API (https://api.porkbun.com/api/json/v3/).
# Generate under Account → API Access, AND toggle "API Access" ON for the
# opda.org.uk domain (Domain Management → opda.org.uk → Details).
PORKBUN_API_KEY=pk1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORKBUN_SECRET_KEY=sk1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare API. Token needs: Account › Cloudflare Pages › Edit,
# Zone › Zone › Edit, Zone › DNS › Edit (Zone resources: All zones from the account).
# Account ID = dashboard right sidebar (same value as the CI CLOUDFLARE_ACCOUNT_ID secret).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Gamma presentation API (gamma.app)
GAMMA_API_KEY=
