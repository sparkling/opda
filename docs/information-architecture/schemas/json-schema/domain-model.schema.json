{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hm.com/ns/ia/schemas/domain-model.schema.json",
  "title": "DomainModel",
  "description": "Root schema for exchanging a complete or partial ontology website domain model. Contains collection arrays for all 13 entity types. All top-level properties are optional, enabling partial payloads.",
  "type": "object",
  "properties": {
    "concepts": {
      "type": "array",
      "items": { "$ref": "concept.schema.json" },
      "description": "Collection of Concept entities."
    },
    "properties": {
      "type": "array",
      "items": { "$ref": "property.schema.json" },
      "description": "Collection of Property entities."
    },
    "enumerations": {
      "type": "array",
      "items": { "$ref": "enumeration.schema.json" },
      "description": "Collection of Enumeration entities."
    },
    "subjectAreas": {
      "type": "array",
      "items": { "$ref": "subject-area.schema.json" },
      "description": "Collection of SubjectArea entities."
    },
    "classificationFacets": {
      "type": "array",
      "items": { "$ref": "classification-facet.schema.json" },
      "description": "Collection of ClassificationFacet entities."
    },
    "crossDomainMappings": {
      "type": "array",
      "items": { "$ref": "cross-domain-mapping.schema.json" },
      "description": "Collection of CrossDomainMapping entities."
    },
    "statusBadges": {
      "type": "array",
      "items": { "$ref": "status-badge.schema.json" },
      "description": "Collection of StatusBadge entities (typically embedded in concepts, but available standalone for reference)."
    },
    "propertyGroups": {
      "type": "array",
      "items": { "$ref": "property-group.schema.json" },
      "description": "Collection of PropertyGroup entities."
    },
    "suggestionGenerators": {
      "type": "array",
      "items": { "$ref": "suggestion-generator.schema.json" },
      "description": "Collection of SuggestionGenerator entities."
    },
    "actionDescriptions": {
      "type": "array",
      "items": { "$ref": "action-description.schema.json" },
      "description": "Collection of ActionDescription entities."
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "rule.schema.json" },
      "description": "Collection of Rule entities."
    },
    "instanceExamples": {
      "type": "array",
      "items": { "$ref": "instance-example.schema.json" },
      "description": "Collection of InstanceExample entities."
    }
  },
  "additionalProperties": false
}
