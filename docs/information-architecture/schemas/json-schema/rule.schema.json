{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hm.com/ns/ia/schemas/rule.schema.json",
  "title": "Rule",
  "description": "A SHACL Rule that automatically materialises derived property values. Rules fire at data load time, not interactively.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of this rule."
    },
    "ruleType": {
      "type": "string",
      "enum": ["TripleRule", "SPARQLRule"],
      "description": "Type of rule (TripleRule or SPARQLRule)."
    },
    "derivedProperty": {
      "type": "string",
      "description": "The property that this rule materialises."
    }
  },
  "required": ["name", "ruleType", "derivedProperty"],
  "additionalProperties": false
}
