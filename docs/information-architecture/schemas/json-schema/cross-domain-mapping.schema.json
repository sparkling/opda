{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hm.com/ns/ia/schemas/cross-domain-mapping.schema.json",
  "title": "CrossDomainMapping",
  "description": "A semantic link between concepts in different bounded contexts, expressing that they represent the same or similar real-world things.",
  "type": "object",
  "properties": {
    "matchType": {
      "type": "string",
      "enum": ["exact", "close", "broad"],
      "description": "Strength of the mapping (exact, close, or broad)."
    },
    "note": {
      "type": "string",
      "description": "Explanatory note about this mapping."
    },
    "source": {
      "type": "string",
      "format": "uri",
      "description": "URI of the source concept (1)."
    },
    "target": {
      "type": "string",
      "format": "uri",
      "description": "URI of the target concept (1)."
    }
  },
  "required": ["matchType", "source", "target"],
  "additionalProperties": false
}
