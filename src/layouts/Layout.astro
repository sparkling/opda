---
/**
 * OPDA Knowledge Base — page shell.
 *
 * Composes Header + Sidebar + main content + PageFooter at build time.
 * Derives section / active state / prev-next from Astro.url.pathname via
 * src/lib/site.ts. No runtime chrome injection; FOUC-free.
 *
 * Per-page interactivity (theme toggle, sidebar collapse, tree folder
 * toggle, mobile menu, TOC observer, Mermaid) ships as small client
 * scripts loaded at the bottom of the body.
 *
 * Astro's <ClientRouter /> enables view transitions for smooth
 * page-to-page navigation (docs/adr/0003 idiomatic Astro refactor).
 */
import fs from 'node:fs';
import path from 'node:path';
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Sidebar from '@/components/Sidebar.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageFooter from '@/components/PageFooter.astro';
import Comments from '@/components/Comments.astro';
import { getActiveSection } from '@/lib/site';

function assetVersion(rel: string): string {
  try {
    const full = path.resolve(process.cwd(), 'public', rel.replace(/^\//, ''));
    const m = fs.statSync(full).mtimeMs;
    return Math.floor(m).toString(36);
  } catch {
    return 'dev';
  }
}
const cssV = assetVersion('/ui/design-system.css');
const twV = assetVersion('/ui/tailwind.built.css');
const clientV = assetVersion('/ui/client.js');

interface Props {
  /** Page title — used as <title> (suffix " · OPDA Knowledge Base" added unless already present). */
  title: string;
  /** <meta name="description"> contents. */
  description?: string;
  /** Prose width class. Default 'prose wide'; pass 'prose' for narrow reading width. */
  proseClass?: string;
  /** Include the TailwindPlus Elements ESM script. Default true. */
  tailwindPlus?: boolean;
  /** Wrap the slot in `<article class={proseClass}>`. Default true. */
  wrapArticle?: boolean;
  /** Hide the sidebar (e.g. for the home page or single-page sections). */
  hideSidebar?: boolean;
  /** Hide the breadcrumbs (e.g. on section roots). */
  hideBreadcrumbs?: boolean;
  /** Hide the prev/next page footer. */
  hideFooter?: boolean;
  /** Hide the Artalk comments section (e.g. on /callback, /404, /design-system). */
  hideComments?: boolean;
}

const {
  title,
  description,
  proseClass = 'prose wide',
  tailwindPlus = true,
  wrapArticle = true,
  hideSidebar = false,
  hideBreadcrumbs = false,
  hideFooter = false,
  hideComments = false,
} = Astro.props;

const fullTitle = /knowledge base/i.test(title)
  ? title
  : `${title} · OPDA Knowledge Base`;

const activeSection = getActiveSection(Astro.url.pathname);
const sectionAttr = activeSection ?? '';
const showSidebar = !hideSidebar && !!activeSection;
---
<!doctype html>
<html lang="en" data-section={sectionAttr}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  {description && <meta name="description" content={description} />}
  <link rel="stylesheet" href={`/ui/design-system.css?v=${cssV}`} />
  <link rel="stylesheet" href={`/ui/tailwind.built.css?v=${twV}`} />

  {/* Pre-paint theme: applies data-theme before first render to avoid FOUC.
      Reads ?theme= URL param, then localStorage, falls back to dark.
      data-astro-rerun makes it re-execute on every view transition; without
      that flag the new <html> would render without data-theme on navigation,
      flashing back to the default. */}
  <script is:inline data-astro-rerun>
    (function () {
      try {
        var t = new URLSearchParams(location.search).get('theme');
        if (t !== 'light' && t !== 'dark') {
          t = localStorage.getItem('opda-theme');
        }
        if (t !== 'light' && t !== 'dark') t = 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>

  {/* Site-wide auth gate. Pre-paint hide so content never flashes before
      Auth0 sign-in is confirmed. Skips /callback (runs its own redirect
      handler) and any tab that already confirmed a session this visit
      (opda-auth-ok), so view-transition navigations don't re-hide.
      Reveal / redirect logic is the module script at the end of <body>. */}
  <style is:inline>
    #auth-gate { display: none; }
    html.auth-pending #app { display: none !important; }
    html.auth-pending #auth-gate {
      display: flex; position: fixed; inset: 0; z-index: 99999;
      flex-direction: column; align-items: center; justify-content: center;
      gap: 1rem; padding: 1.5rem; text-align: center;
      background: #0b0e14; color: #e8eaed;
      font: 500 1rem/1.5 system-ui, -apple-system, "Segoe UI", sans-serif;
    }
    html[data-theme="light"].auth-pending #auth-gate { background: #ffffff; color: #1a1a1a; }
    .auth-gate__spinner {
      width: 28px; height: 28px; border-radius: 50%; opacity: 0.7;
      border: 3px solid currentColor; border-right-color: transparent;
      animation: auth-gate-spin 0.7s linear infinite;
    }
    @keyframes auth-gate-spin { to { transform: rotate(360deg); } }
    .auth-gate__btn {
      font: inherit; padding: 0.55rem 1.1rem; border-radius: 8px; cursor: pointer;
      border: 1px solid currentColor; background: transparent; color: inherit;
    }
  </style>
  <script is:inline data-astro-rerun>
    (function () {
      var p = location.pathname;
      if (/^\/callback\/?$/.test(p)) return;
      var ok = false;
      try { ok = sessionStorage.getItem('opda-auth-ok') === '1'; } catch (e) {}
      if (!ok) document.documentElement.classList.add('auth-pending');
    })();
  </script>

  {tailwindPlus && (
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
  )}

  <ClientRouter />
  <slot name="head" />
</head>
<body>
  <div id="app">
    <Header />
    <div class={`app-body${showSidebar ? '' : ' no-sidebar'}`}>
      {showSidebar && <Sidebar />}
      <main class="app-main">
        {!hideBreadcrumbs && <Breadcrumbs />}
        {wrapArticle ? (
          <article class={proseClass}>
            <slot />
          </article>
        ) : (
          <slot />
        )}
        {!hideComments && <Comments />}
        {!hideFooter && <PageFooter />}
      </main>
    </div>
  </div>

  {/* Auth-gate splash — sibling of #app so it stays visible while #app is
      hidden. Shown only when <html class="auth-pending"> (see head). */}
  <div id="auth-gate" aria-live="polite">
    <div class="auth-gate__spinner" id="auth-gate-spinner" aria-hidden="true"></div>
    <p id="auth-gate-msg">Checking sign-in…</p>
    <button class="auth-gate__btn" id="auth-gate-signin" type="button" hidden>Sign in</button>
  </div>

  <script is:inline src={`/ui/client.js?v=${clientV}`}></script>

  {/* Site-wide auth gate: reuses the existing Auth0 SPA client. Reveals the
      page when signed in, otherwise redirects to Auth0 login (once per tab,
      to avoid loops if the allowlist Action denies a user). */}
  <script>
    import { getAuth0Client } from '@/lib/auth0';

    async function gate() {
      if (/^\/callback\/?$/.test(location.pathname)) return;

      const reveal = () => {
        try { sessionStorage.setItem('opda-auth-ok', '1'); } catch {}
        try { sessionStorage.removeItem('opda-gate-redirected'); } catch {}
        document.documentElement.classList.remove('auth-pending');
      };
      const prompt = (msg: string) => {
        document.documentElement.classList.add('auth-pending');
        const m = document.getElementById('auth-gate-msg');
        const sp = document.getElementById('auth-gate-spinner');
        const btn = document.getElementById('auth-gate-signin') as HTMLButtonElement | null;
        if (m) m.textContent = msg;
        if (sp) sp.hidden = true;
        if (btn) {
          btn.hidden = false;
          if (!btn.dataset.bound) {
            btn.dataset.bound = '1';
            btn.addEventListener('click', async () => {
              try {
                try { sessionStorage.removeItem('opda-gate-redirected'); } catch {}
                const auth = await getAuth0Client();
                await auth.loginWithRedirect({
                  appState: { returnTo: location.pathname + location.search },
                });
              } catch { /* leave the prompt visible */ }
            });
          }
        }
      };

      try {
        const auth = await getAuth0Client();
        if (await auth.isAuthenticated()) { reveal(); return; }

        let redirected = false;
        try { redirected = sessionStorage.getItem('opda-gate-redirected') === '1'; } catch {}
        if (redirected) {
          prompt('Please sign in to view the OPDA Knowledge Base.');
          return;
        }
        try { sessionStorage.setItem('opda-gate-redirected', '1'); } catch {}
        const auth2 = await getAuth0Client();
        await auth2.loginWithRedirect({
          appState: { returnTo: location.pathname + location.search },
        });
      } catch (err) {
        console.warn('[OPDA] auth gate failed:', err);
        prompt('Sign-in is required to view this page.');
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', gate);
    } else {
      gate();
    }
    document.addEventListener('astro:page-load', gate);
  </script>
  <slot name="scripts" />
</body>
</html>
