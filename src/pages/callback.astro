---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Signing in"
  description="Completing authentication."
  hideSidebar
  hideBreadcrumbs
  hideFooter
  hideComments
>
  <h1>Signing you in…</h1>
  <p class="lead" id="auth-callback-status">One moment while we complete authentication.</p>

  <script>
    import { getAuth0Client } from '@/lib/auth0';

    async function handleCallback() {
      const status = document.getElementById('auth-callback-status');
      try {
        const params = new URLSearchParams(window.location.search);
        if (params.has('error')) {
          const err = params.get('error_description') || params.get('error') || 'Unknown error';
          if (status) status.textContent = 'Authentication failed: ' + err;
          return;
        }
        if (!params.has('code') || !params.has('state')) {
          // Direct visit without auth params — bounce home.
          window.location.replace('/');
          return;
        }
        const client = await getAuth0Client();
        const result = await client.handleRedirectCallback();
        const returnTo =
          (result.appState && typeof result.appState === 'object' &&
           typeof (result.appState as { returnTo?: string }).returnTo === 'string')
            ? (result.appState as { returnTo: string }).returnTo
            : '/';
        window.history.replaceState({}, document.title, returnTo);
        window.location.replace(returnTo);
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        if (status) status.textContent = 'Authentication error: ' + msg;
      }
    }

    handleCallback();
  </script>
</Layout>
