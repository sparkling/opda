---
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
---
<Layout
  title="Library"
  description="Curated index of every document, transcript, recording and external reference held in the project archive."
>
<PageMeta category="Section overview" variant="brand" updated="Updated 2026-05-14" />

      <h1>Library</h1>
      <p class="lead">
        The curated reading list. Across <code>source/</code> we hold roughly 500 MB
        of cloned upstream repos, third-party reports, presentations, video
        transcripts, government PDFs and consultation responses. This section is the
        index that turns that pile into something readable: catalogued by topic, with
        every entry linkable via the resource viewer.
      </p>

      <h2 id="holdings">Project holdings</h2>
      <p>Material produced by OPDA, the DPMSG and the Sandbox participants.</p>
      <div class="card-grid">
        <a class="card" href="/library/library-overview">
          <div class="pill pill--brand">Start here</div>
          <h3>Library overview</h3>
          <p>The shape of the archive — 5 cloned GitHub repos, 16 OPDA website pages, 70 blog posts, 15 videos, 8 steering-group meeting packs, third-party reports.</p>
        </a>
        <a class="card" href="/library/document-archive">
          <div class="pill pill--info">Built</div>
          <h3>Document archive</h3>
          <p>Trust Framework PoC materials, project plan, sandbox setup &amp; technical guides, DPMSG reports, third-party research.</p>
        </a>
        <a class="card" href="/library/transcript-archive">
          <div class="pill pill--info">Built</div>
          <h3>Transcript archive</h3>
          <p>15 YouTube transcripts, 1 Vimeo transcript, 4 Sandbox monthly update transcripts, 5 DPMSG Trust &amp; Interop Steering Group transcripts.</p>
        </a>
      </div>

      <h2 id="external">External</h2>
      <p>Authoritative source material from outside OPDA — gov.uk, regulator sites, related standards bodies.</p>
      <div class="card-grid">
        <a class="card" href="/library/external-references">
          <div class="pill pill--info">Built</div>
          <h3>External references</h3>
          <p>NTS Material Information archive (recovered after withdrawal), MHCLG consultation pages, gov.uk DSIT/DMCC pages, related W3C VC/DID specs.</p>
        </a>
      </div>
</Layout>
