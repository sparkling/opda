          <tr><td><a class="resource-link" href="/resource.html?path=source/03-standards/schemas/src/schemas/v3/overlays/ta6.json" title="source/03-standards/schemas/src/schemas/v3/overlays/ta6.json"><code>ta6.json</code></a></td><td>Law Society TA6 Property Information Form (6th ed, 2025)</td><td>Active</td></tr>
          <tr><td><a class="resource-link" href="/resource.html?path=source/03-standards/schemas/src/schemas/v3/overlays/ta7.json" title="source/03-standards/schemas/src/schemas/v3/overlays/ta7.json"><code>ta7.json</code></a></td><td>Law Society TA7 Leasehold Information Form (5th ed, 2025)</td><td>Active</td></tr>
          <tr><td><a class="resource-link" href="/resource.html?path=source/03-standards/schemas/src/schemas/v3/overlays/ta10.json" title="source/03-standards/schemas/src/schemas/v3/overlays/ta10.json"><code>ta10.json</code></a></td><td>Law Society TA10 Fittings and Contents Form</td><td>Active</td></tr>
          <tr><td><a class="resource-link" href="/resource.html?path=source/03-standards/schemas/src/schemas/v3/overlays/nts.json" title="source/03-standards/schemas/src/schemas/v3/overlays/nts.json"><code>nts.json</code></a></td><td>NTS Material Information rules (Sales / Lettings v1.0)</td><td><strong>Underlying rules withdrawn</strong> — awaits MHCLG replacement</td></tr>
