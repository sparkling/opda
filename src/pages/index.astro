---
/**
 * Public "coming soon" homepage — opda.org.uk/
 *
 * Standalone: no KB Layout, so it carries none of the gated chrome (auth
 * header, sidebar, Artalk comments, logout button). Pure static, edge-cacheable,
 * sitting in front of the gated knowledge base (the KB landing lives at /home).
 *
 * Plain block flow: centred brand heading, illustration directly underneath
 * (centred via margin:auto). "Members sign in" is a corner link, top-right.
 */
const title = 'OPDA — Coming Soon';
const description =
  'The OPDA knowledge base is being built. Coming soon — stay tuned for our grand opening.';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/coming-soon.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <style is:global>
    :root { color-scheme: dark; }
    * { box-sizing: border-box; }
    html, body { margin: 0; }
    body {
      min-height: 100vh;
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      background: radial-gradient(120% 120% at 50% 0%, #3a2a1e 0%, #1a1310 55%, #0d0a08 100%);
      color: #f3e9dc;
      text-align: center;
      padding: clamp(1.5rem, 5vh, 3.5rem) clamp(1rem, 4vw, 3rem) clamp(2rem, 6vh, 4rem);
    }
    .cs-signin {
      position: absolute;
      top: clamp(1rem, 3vw, 1.75rem);
      right: clamp(1.25rem, 4vw, 2.5rem);
      font-size: clamp(0.8rem, 0.7rem + 0.4vw, 0.95rem);
      font-weight: 600;
      letter-spacing: 0.02em;
      color: #d9c4a8;
      text-decoration: none;
      opacity: 0.85;
    }
    .cs-signin:hover { opacity: 1; color: #fff; }
    .cs-wordmark {
      display: block;
      margin: 0 0 clamp(1rem, 3vh, 2rem);
      font-weight: 800;
      font-size: clamp(1.5rem, 1rem + 2vw, 2.5rem);
      letter-spacing: 0.04em;
      color: #f3e9dc;
      text-decoration: none;
    }
    .cs-art {
      display: block;
      margin: 0 auto;
      max-width: min(100%, 1500px);
      max-height: 78vh;
      width: auto;
      height: auto;
      border-radius: 14px;
      box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.7),
                  0 0 0 1px rgba(255, 255, 255, 0.04);
    }
    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap; border: 0;
    }
  </style>
</head>
<body>
  <h1 class="sr-only">Coming soon — the OPDA knowledge base is being built</h1>
  <a class="cs-signin" href="/home">Members sign in →</a>
  <a class="cs-wordmark" href="/">Open Property Data Association</a>
  <img
    class="cs-art"
    src="/coming-soon.jpg"
    width="2400"
    height="1339"
    alt="A colony of cartoon beavers building a dam at sunset, beside a wooden sign reading ‘Coming soon — our new home is being built. Stay tuned for our grand opening.’"
    fetchpriority="high"
  />
</body>
</html>
