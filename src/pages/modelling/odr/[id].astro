---
/**
 * ODR detail page — ADR-0024. Renders the ODR markdown through the SAME Astro
 * content-collection pipeline as the manual (render(entry) → <Content/>), so
 * ODR pages inherit identical .prose styling and theme-aware diagrams. Replaces
 * the earlier marked + set:html path (generate-odr-html.mjs).
 */
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { ODR_REGISTRY } from '@/lib/odr-pages.mjs';

const KIND_PILL = {
  methodology: 'pill--brand', pattern: 'pill--info', mapping: 'pill--info',
  architecture: 'pill--warn', programme: 'pill--warn',
};
const STATUS_PILL = { accepted: 'pill--ok', proposed: 'pill--warn', rejected: 'pill--error' };

export async function getStaticPaths() {
  const entries = await getCollection('odr');
  return entries.map((entry) => {
    const num = (String(entry.id).match(/(\d{4})/) || [])[1] || '';
    const meta = ODR_REGISTRY.find((o) => o.number === num)
      || { id: `odr-${num}`, number: num, title: '', kind: '', status: '' };
    return { params: { id: meta.id }, props: { entry, odr: meta } };
  });
}

const { entry, odr } = Astro.props;
const { Content } = await render(entry);
const data = entry.data || {};
const dateStr = data.date instanceof Date ? data.date.toISOString().slice(0, 10) : (data.date || '');
const kind = odr.kind || data.kind || '';
const status = odr.status || data.status || '';
---
<Layout
  title={`ODR-${odr.number} — ${odr.title}`}
  description={`Ontology Decision Record ${odr.number}: ${odr.title} (${kind}, ${status})`}
  proseClass="prose wide odr-detail"
>
  <nav class="breadcrumb-override" aria-label="ODR breadcrumb">
    <a href="/modelling/odr">ODR Corpus</a>
    <span aria-hidden="true"> / </span>
    <span>ODR-{odr.number}</span>
  </nav>
  <div class="odr-meta">
    {kind && <span class={`pill ${KIND_PILL[kind] ?? 'pill--brand'}`}>{kind}</span>}
    {status && <span class={`pill ${STATUS_PILL[status] ?? ''}`}>{status}</span>}
    {dateStr && <time datetime={dateStr}>{dateStr}</time>}
  </div>
  <Content />
  <footer class="odr-footer">
    <p>
      <a href="/modelling/odr">← Back to ODR Corpus</a>
      &ensp;|&ensp;
      <a href="https://github.com/sparkling/opda/tree/main/docs/ontology/odr" rel="noopener noreferrer">View source</a>
    </p>
    <p class="muted">
      ODR-{odr.number} is immutable per <a href="/modelling/odr/odr-0001">ODR-0001</a>.
      Amendments produce new records.
    </p>
  </footer>
</Layout>
