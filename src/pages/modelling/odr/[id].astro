---
/**
 * ODR detail page — ADR-0023 (build-time immutable enriched ODR pages).
 *
 * getStaticPaths: only enriched ODRs with committed artefacts.
 * Serves committed HTML via set:html — the same serving pattern as
 * src/pages/manual/validation-report.astro (ADR-0021 §"Separate task").
 *
 * The artefact HTML is read at build time from docs/ontology/odr/_html/.
 * Mermaid diagrams render client-side via the existing client.js loader.
 *
 * This page DOES NOT convert or generate ODR HTML — it only serves artefacts
 * that were already committed. A skip-on-exists guard in the production step
 * ensures enriched artefacts are never regenerated.
 */
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import Layout from '@/layouts/Layout.astro';
import { ENRICHED_ODRS } from '@/lib/odr-pages.mjs';

export function getStaticPaths() {
  return ENRICHED_ODRS.map((odr) => ({
    params: { id: odr.id },
    props: { odr },
  }));
}

const { odr } = Astro.props;

// Read the committed artefact at build time.
// The artefact path is relative to the project root.
const artefactPath = resolve(process.cwd(), odr.artefact);
const html = readFileSync(artefactPath, 'utf8');
---
<Layout title={`ODR-${odr.number} — ${odr.title}`} description={`Ontology Decision Record ${odr.number}: ${odr.title} (${odr.kind}, ${odr.status})`}>
  <nav class="breadcrumb-override" aria-label="ODR breadcrumb">
    <a href="/modelling/odr">ODR Corpus</a>
    <span aria-hidden="true"> / </span>
    <span>ODR-{odr.number}</span>
  </nav>
  <Fragment set:html={html} />
  <footer class="odr-footer">
    <p>
      <a href="/modelling/odr">← Back to ODR Corpus</a>
      &ensp;|&ensp;
      <a href={`https://github.com/sparkling/opda/blob/main/${odr.artefact}`} rel="noopener noreferrer">
        View committed artefact
      </a>
    </p>
    <p class="muted">
      ODR-{odr.number} is immutable per <a href="/modelling/odr/odr-0001">ODR-0001</a>.
      Amendments produce new records; this artefact is frozen.
    </p>
  </footer>
</Layout>
