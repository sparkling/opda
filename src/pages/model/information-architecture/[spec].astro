---
/**
 * Realises ADR-0016 per ADR-0015; render mechanism per ADR-0021 §"Separate task".
 * Serves generator-produced static HTML for each IA-spec document.
 *
 * Fragments are generated from docs/information-architecture/*.md by the
 * `opda-report-generator` integration into src/generated/ia-<slug>.html. This
 * route serves them via set:html — the report generator generates the HTML,
 * the page serves it. Replaces the dev-only /resource.html?path=…md links.
 */
import Layout from '@/layouts/Layout.astro';
import { IA_SPECS } from '@/lib/generated-reports.mjs';

export function getStaticPaths() {
  return IA_SPECS.map((s) => ({ params: { spec: s.slug }, props: { title: s.title } }));
}

const { title } = Astro.props;
const { spec } = Astro.params;

const fragments = import.meta.glob('../../../generated/ia-*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const bySlug = {};
for (const [path, content] of Object.entries(fragments)) {
  bySlug[path.split('/').pop().replace(/^ia-/, '').replace(/\.html$/, '')] = content;
}
const html = bySlug[spec] ?? '';
---
<Layout title={`Information architecture — ${title}`}>
  <Fragment set:html={html} />
</Layout>
