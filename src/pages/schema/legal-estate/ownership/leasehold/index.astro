import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Schema · Ownership — leasehold transfer"
  description="Landing for the Ownership — leasehold transfer cluster."
>
<div class="page-meta">
        <span class="pill pill--info">Schema</span>
        <span>Page 38e</span>
        <span>Landing</span>
      </div>
      <h1>Ownership — leasehold transfer</h1>
      <p class="lead">
        When the ownership being transferred is leasehold, this cluster
        is the assignment of the lease — its term, the people who own and
        manage it, ground rent, service charge, consents, and assorted
        legal artefacts. Eight sub-pages each scope one part of the
        leasehold disclosure.
      </p>
      <h2 id="subpages">Pages in this cluster</h2>
      <ul class="cluster-index">
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-term"><strong>Term &amp; shared ownership</strong></a> — lease term, shared-ownership percentage and rent schedule.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-contacts-list"><strong>Contact list</strong></a> — freeholder, management company, agent, sinking-fund holder.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-contacts-roles"><strong>Service-contact roles</strong></a> — which contact does what.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-management"><strong>Management</strong></a> — ownership-and-management structure and obligations.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-rent"><strong>Ground rent</strong></a> — schedule, escalation, payment terms.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-charges"><strong>Service charge &amp; insurance</strong></a> — service-charge accounts, buildings insurance schedule.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-legal"><strong>Consents, restrictions, alterations, safety</strong></a> — landlord consents, lease restrictions, alterations, enfranchisement, Building Safety Act.</li>
        <li><a href="/schema/legal-estate/ownership/leasehold/lease-misc"><strong>Disputes, general, documents, confirmation</strong></a> — disputes, general declarations, required documents, accuracy confirmation.</li>
      </ul>
</Layout>
