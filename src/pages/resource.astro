---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="Resource"
  description="Unified viewer for any file in the OPDA Knowledge Base. Accepts ?path=… and renders the resource inline within the site chrome."
>
<div class="page-meta">
        <span class="pill pill--brand">Resource viewer</span>
        <span id="res-mode-label" class="muted tiny">—</span>
      </div>

      <div class="res-breadcrumb" id="res-breadcrumb">—</div>
      <h1 id="res-title">Loading…</h1>

      <dl class="res-meta">
        <dt>Path</dt>           <dd><code id="res-path">—</code></dd>
        <dt>Type</dt>           <dd id="res-type">—</dd>
        <dt>Rendered as</dt>    <dd id="res-rendered">—</dd>
      </dl>

      <div class="res-actions">
        <a id="res-open" href="#" target="_blank" rel="noopener">Open original ↗</a>
        <a id="res-download" href="#" download>Download</a>
      </div>

      <div id="res-body">
        <div class="muted">Loading…</div>
      </div>

<script>
  // Resource viewer — resolves ?path=… to a fetchable URL and renders it.
  //
  // Path resolution (ADR-0054): source/ is served two different ways.
  //   • DEV  — astro.config.mjs's serveProjectRoots Vite plugin exposes the
  //            archive at /source/… , so source/a/b.pdf → /source/a/b.pdf.
  //   • PROD — source/ is NOT in dist/. Its mirror lives in the public S3
  //            bucket, served by CloudFront under /resources/* with the leading
  //            "source/" stripped (the bucket mirrors source/ at its root). So
  //            source/a/b.pdf → /resources/a/b.pdf. This is why all the existing
  //            /resource?path=source/… links work in prod with no rewrite.
  // Non-source paths (e.g. docs/…) are served from the site root as-is in both.
  function resolveResourceUrl(p) {
    if (p.startsWith('source/')) {
      return import.meta.env.PROD
        ? '/resources/' + p.slice('source/'.length)  // prod: S3-mirror, strip prefix
        : '/' + p;                                    // dev: Vite plugin at /source/…
    }
    return '/' + p.replace(/^\/+/, '');               // other roots: served as-is
  }

  // Extension → render strategy. Covers every type present in the S3 archive
  // plus common siblings, so the viewer degrades gracefully for anything.
  const IMAGE  = new Set(['png','jpg','jpeg','webp','gif','avif','bmp','ico','svg']);
  const VIDEO  = new Set(['mp4','webm','mov','m4v','ogv']);
  const AUDIO  = new Set(['mp3','wav','ogg','oga','m4a','flac','aac']);
  const FRAME  = new Set(['pdf','html','htm']);                 // browser renders natively
  const OFFICE = new Set(['docx','xlsx','pptx','doc','xls','ppt']); // Office Online preview
  const TEXT   = new Set(['txt','md','markdown','mdx','ttl','rdf','n3','nt','nq','trig',
    'json','jsonld','geojson','xml','yaml','yml','toml','ini','env','cfg','conf','properties',
    'csv','tsv','js','mjs','cjs','jsx','ts','tsx','css','scss','less','sh','bash','zsh','py',
    'rb','sql','log','patch','diff','vtt','srt','gitignore','nvmrc','prettierrc','firebaserc',
    'editorconfig','iml','graphql','gql','map']);
  const TEXT_MAX = 2 * 1024 * 1024; // 2 MB cap for inline text fetch

  const esc = (s) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));

  function fmtSize(n) {
    if (!Number.isFinite(n)) return '';
    if (n < 1024) return n + ' B';
    if (n < 1048576) return (n / 1024).toFixed(1) + ' KB';
    return (n / 1048576).toFixed(1) + ' MB';
  }

  function downloadCard(body, url, name, ext, reason) {
    body.innerHTML =
      '<div class="res-binary">' +
      '<p><strong>' + esc(name) + '</strong>' + (ext ? ' <code>.' + esc(ext) + '</code>' : '') + '</p>' +
      '<p class="muted">' + esc(reason || 'This file type can’t be previewed inline.') + '</p>' +
      '<p><a class="res-folder-up" href="' + url + '" download>Download</a> ' +
      '<a class="res-folder-up" href="' + url + '" target="_blank" rel="noopener">Open in new tab ↗</a></p>' +
      '</div>';
  }

  function csvTable(text, sep) {
    // Minimal CSV/TSV parse with quoted-field support.
    const rows = []; let row = [], field = '', q = false;
    for (let i = 0; i < text.length; i++) {
      const c = text[i];
      if (q) {
        if (c === '"' && text[i + 1] === '"') { field += '"'; i++; }
        else if (c === '"') q = false;
        else field += c;
      } else if (c === '"') q = true;
      else if (c === sep) { row.push(field); field = ''; }
      else if (c === '\n') { row.push(field); rows.push(row); row = []; field = ''; }
      else if (c !== '\r') field += c;
    }
    if (field.length || row.length) { row.push(field); rows.push(row); }
    if (!rows.length) return '<div class="res-binary muted">Empty file.</div>';
    const head = rows[0], bodyRows = rows.slice(1);
    return '<div class="res-csv-wrap"><table><thead><tr>' +
      head.map((h) => '<th>' + esc(h) + '</th>').join('') + '</tr></thead><tbody>' +
      bodyRows.map((r) => '<tr>' + head.map((_, i) => '<td>' + esc(r[i] ?? '') + '</td>').join('') + '</tr>').join('') +
      '</tbody></table></div>';
  }

  async function renderText(body, url, ext) {
    let res;
    try { res = await fetch(url); } catch { return false; }
    if (!res.ok) return false;
    const len = Number(res.headers.get('content-length'));
    if (Number.isFinite(len) && len > TEXT_MAX) return false; // too big → caller falls back to download
    const text = await res.text();
    if (text.length > TEXT_MAX) return false;
    if (ext === 'csv' || ext === 'tsv') { body.innerHTML = csvTable(text, ext === 'tsv' ? '\t' : ','); return true; }
    let out = text;
    if (ext === 'json' || ext === 'jsonld' || ext === 'geojson') {
      try { out = JSON.stringify(JSON.parse(text), null, 2); } catch { /* show raw */ }
    }
    body.innerHTML = '<div class="res-code-wrap"><pre><code>' + esc(out) + '</code></pre></div>';
    return true;
  }

  async function renderResource() {
    const $ = (id) => document.getElementById(id);
    const body = $('res-body');
    if (!body) return; // not the resource page

    const raw = new URLSearchParams(window.location.search).get('path') || '';
    const path = raw.replace(/^\/+/, '').replace(/\.\.(?:\/|$)/g, ''); // strip leading / and any ..
    const modeLabel = $('res-mode-label');

    if (!path) {
      if (modeLabel) modeLabel.textContent = 'no path';
      $('res-title').textContent = 'No resource selected';
      $('res-path').textContent = '—';
      body.innerHTML = '<div class="res-error">Add <code>?path=…</code> to the URL, '
        + 'e.g. <code>?path=source/INVENTORY.md</code>.</div>';
      return;
    }

    const url = resolveResourceUrl(path);
    const name = path.replace(/\/$/, '').split('/').pop() || path;
    const ext = (name.includes('.') ? name.split('.').pop() : '').toLowerCase();

    if (modeLabel) modeLabel.textContent = import.meta.env.PROD ? 'resources' : 'dev source';
    $('res-title').textContent = name;
    $('res-path').textContent = path;
    $('res-type').textContent = ext ? '.' + ext : '—';

    const open = $('res-open'), dl = $('res-download');
    if (open) open.setAttribute('href', url);
    if (dl)   dl.setAttribute('href', url);

    const setRendered = (s) => { const e = $('res-rendered'); if (e) e.textContent = s; };
    body.innerHTML = '<div class="muted">Loading…</div>';

    // 1. Images
    if (IMAGE.has(ext)) {
      setRendered('image');
      body.innerHTML = '<div class="res-image-wrap"><img src="' + url + '" alt="' + esc(name) + '" /></div>';
      return;
    }
    // 2. Video / audio
    if (VIDEO.has(ext)) {
      setRendered('video');
      body.innerHTML = '<div class="res-frame-wrap"><video class="res-frame" controls src="' + url + '"></video></div>';
      return;
    }
    if (AUDIO.has(ext)) {
      setRendered('audio');
      body.innerHTML = '<div class="res-binary"><audio controls src="' + url + '" style="width:100%"></audio></div>';
      return;
    }
    // 3. PDF / HTML — native iframe
    if (FRAME.has(ext)) {
      setRendered(ext === 'pdf' ? 'PDF frame' : 'HTML frame');
      const frame = document.createElement('iframe');
      frame.className = 'res-frame'; frame.src = url; frame.setAttribute('title', name);
      const wrap = document.createElement('div'); wrap.className = 'res-frame-wrap'; wrap.appendChild(frame);
      body.innerHTML = ''; body.appendChild(wrap);
      return;
    }
    // 4. Office (docx/xlsx/pptx) — Microsoft Office Online viewer. Needs a public
    //    URL, which only exists in prod (/resources/* is ungated); in dev the file
    //    isn't publicly reachable, so fall back to download.
    if (OFFICE.has(ext)) {
      if (import.meta.env.PROD) {
        setRendered('Office Online preview');
        const abs = location.origin + url;
        const src = 'https://view.officeapps.live.com/op/view.aspx?src=' + encodeURIComponent(abs);
        body.innerHTML = '<div class="res-frame-wrap"><iframe class="res-frame" src="' + src +
          '" title="' + esc(name) + '"></iframe></div>' +
          '<p class="muted tiny">Preview rendered by Microsoft Office Online. Use Download for the original.</p>';
      } else {
        setRendered('download (preview in prod)');
        downloadCard(body, url, name, ext, 'Office preview needs the public production URL — download to open locally.');
      }
      return;
    }
    // 5. Text / code / data — fetch + render (pre, or table for CSV/TSV)
    if (TEXT.has(ext) || !ext) {
      setRendered(ext === 'csv' || ext === 'tsv' ? 'table' : 'text');
      const ok = await renderText(body, url, ext);
      if (!ok) { setRendered('download'); downloadCard(body, url, name, ext, 'File is too large or unavailable to preview inline.'); }
      return;
    }
    // 6. Everything else (eml, msg, zip, binaries…) — download only
    setRendered('download');
    downloadCard(body, url, name, ext, 'This file type can’t be previewed in the browser.');
  }

  // Run on first load and after each view-transition navigation (ClientRouter).
  document.addEventListener('astro:page-load', renderResource);
</script>
</Layout>

<style is:global>
/* Resource viewer — local styles */
    .res-meta {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: var(--space-2) var(--space-4);
      font-size: var(--text-sm);
      margin: var(--space-3) 0 var(--space-5);
      padding: var(--space-3) var(--space-4);
      background: var(--color-ink-50);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
    }
    .res-meta dt { color: var(--color-text-muted); font-weight: 600; margin: 0; }
    .res-meta dd { color: var(--color-text); margin: 0; }
    .res-meta dd code { word-break: break-all; }
    .res-actions {
      display: flex; flex-wrap: wrap; gap: var(--space-2);
      margin: 0 0 var(--space-4);
    }
    .res-actions a {
      display: inline-flex; align-items: center; gap: var(--space-2);
      padding: 0.4rem 0.85rem;
      background: var(--color-brand-100);
      color: var(--color-brand-900);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      font-weight: 500;
    }
    .res-actions a:hover {
      background: var(--color-brand-200);
      text-decoration: none;
    }
    .res-frame-wrap {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-surface);
      box-shadow: var(--shadow-sm);
    }
    .res-frame {
      display: block;
      width: 100%;
      height: 80vh;
      border: 0;
      background: white;
    }
    .res-image-wrap {
      padding: var(--space-4);
      background: var(--color-ink-50);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      text-align: center;
    }
    .res-image-wrap img { max-width: 100%; height: auto; border-radius: var(--radius-sm); }
    .res-error {
      padding: var(--space-5);
      background: var(--color-warning-100);
      border: 1px solid var(--color-warning-700);
      color: var(--color-warning-700);
      border-radius: var(--radius-md);
    }
    .res-error code { background: rgba(0,0,0,0.06); padding: 1px 4px; border-radius: 3px; }
    .res-binary {
      padding: var(--space-5);
      background: var(--color-ink-50);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      color: var(--color-text-muted);
    }
    /* JSON viewer toggle + JSON Crack frame */
    .res-json-modes {
      display: inline-flex;
      border: 1px solid var(--color-border-strong);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-surface);
      margin: 0 0 var(--space-3);
    }
    .res-json-modes button {
      padding: 0.45rem 0.9rem;
      border: 0;
      background: transparent;
      color: var(--color-ink-700);
      font-size: var(--text-sm);
      font-family: inherit;
      cursor: pointer;
      border-right: 1px solid var(--color-border);
    }
    .res-json-modes button:last-child { border-right: 0; }
    .res-json-modes button.active {
      background: var(--color-brand-700);
      color: white;
    }
    .res-json-modes button:not(.active):hover {
      background: var(--color-brand-100);
      color: var(--color-brand-900);
    }
    .res-jsoncrack-wrap {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: white;
      box-shadow: var(--shadow-sm);
      position: relative;
    }
    .res-jsoncrack-wrap iframe {
      display: block;
      width: 100%;
      height: 80vh;
      border: 0;
      background: white;
    }
    .res-jsoncrack-status {
      padding: var(--space-3) var(--space-4);
      background: var(--color-ink-50);
      border-bottom: 1px solid var(--color-border);
      font-size: var(--text-sm);
      color: var(--color-text-muted);
    }
    .res-jsoncrack-status code { background: rgba(0,0,0,0.06); padding: 1px 4px; border-radius: 3px; }
    .res-breadcrumb {
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      margin-bottom: var(--space-2);
      word-break: break-all;
    }
    .res-breadcrumb a, .res-breadcrumb span { color: inherit; }
    .res-breadcrumb a:hover { color: var(--color-brand-700); }
    .res-breadcrumb .sep { margin: 0 0.25em; color: var(--color-ink-400); }

    /* Rendered markdown */
    .res-prose-wrap {
      padding: var(--space-5) var(--space-6);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
    }
    .res-prose-wrap > :first-child { margin-top: 0; }
    .res-prose-wrap > :last-child  { margin-bottom: 0; }
    .res-prose-wrap h1 { margin-top: var(--space-5); }
    .res-prose-wrap h2 { margin-top: var(--space-5); }
    .res-prose-wrap h3 { margin-top: var(--space-4); }
    .res-prose-wrap pre {
      background: var(--color-ink-50);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      padding: var(--space-3) var(--space-4);
      overflow-x: auto;
      font-size: var(--text-sm);
      line-height: 1.55;
    }
    .res-prose-wrap pre code { background: transparent; padding: 0; }
    .res-prose-wrap code {
      background: var(--color-ink-50);
      padding: 1px 4px;
      border-radius: 3px;
      font-size: 0.9em;
    }
    .res-prose-wrap table {
      width: 100%;
      border-collapse: collapse;
      margin: var(--space-3) 0;
      font-size: var(--text-sm);
    }
    .res-prose-wrap th, .res-prose-wrap td {
      padding: var(--space-2) var(--space-3);
      border-bottom: 1px solid var(--color-border);
      text-align: left;
    }
    .res-prose-wrap th { font-weight: 600; background: var(--color-ink-50); }
    .res-prose-wrap blockquote {
      margin: var(--space-3) 0;
      padding: var(--space-2) var(--space-4);
      border-left: 3px solid var(--color-brand-700);
      background: var(--color-ink-50);
      color: var(--color-text-muted);
    }

    /* Source code */
    .res-code-wrap {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-surface);
      box-shadow: var(--shadow-sm);
    }
    .res-code-wrap pre {
      margin: 0;
      padding: var(--space-4) var(--space-5);
      overflow: auto;
      max-height: 80vh;
      font-size: var(--text-sm);
      line-height: 1.55;
      background: transparent;
    }
    .res-code-wrap code {
      font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      background: transparent;
      padding: 0;
      color: var(--color-text);
    }

    /* CSV / TSV tables */
    .res-csv-wrap {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: auto;
      background: var(--color-surface);
      max-height: 80vh;
      box-shadow: var(--shadow-sm);
    }
    .res-csv-wrap table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--text-sm);
    }
    .res-csv-wrap thead th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: var(--color-ink-50);
      text-align: left;
      font-weight: 600;
      padding: var(--space-2) var(--space-3);
      border-bottom: 1px solid var(--color-border);
      white-space: nowrap;
    }
    .res-csv-wrap td {
      padding: var(--space-2) var(--space-3);
      border-bottom: 1px solid var(--color-border);
      vertical-align: top;
    }
    .res-csv-wrap tbody tr:nth-child(even) td { background: var(--color-ink-50); }

    .res-load-error {
      padding: var(--space-4) var(--space-5);
      background: var(--color-warning-100);
      border: 1px solid var(--color-warning-700);
      color: var(--color-warning-700);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
    }
    .res-load-error code { background: rgba(0,0,0,0.08); padding: 1px 4px; border-radius: 3px; }

    /* Folder listing */
    .res-folder-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-3);
    }
    .res-folder-crumbs { font-size: var(--text-sm); color: var(--color-text-muted); word-break: break-all; }
    .res-folder-crumbs a { color: inherit; }
    .res-folder-crumbs a:hover { color: var(--color-brand-700); }
    .res-folder-crumbs .sep { margin: 0 0.25em; color: var(--color-ink-400); }
    .res-folder-up {
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.75rem;
      background: var(--color-brand-100);
      color: var(--color-brand-900);
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      font-weight: 500;
    }
    .res-folder-up:hover { background: var(--color-brand-200); text-decoration: none; }
    .res-folder-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      font-size: var(--text-sm);
      background: var(--color-surface);
    }
    .res-folder-table thead th {
      text-align: left;
      padding: var(--space-2) var(--space-3);
      background: var(--color-ink-50);
      border-bottom: 1px solid var(--color-border);
      font-weight: 600;
    }
    .res-folder-table tbody td {
      padding: var(--space-2) var(--space-3);
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }
    .res-folder-table tbody tr:last-child td { border-bottom: 0; }
    .res-folder-table tbody tr:hover td { background: var(--color-ink-50); }
    .res-folder-table td:first-child { width: 60%; }
    .res-folder-table td:nth-child(2) { width: 18%; }
    .res-folder-table td:nth-child(3) { width: 22%; }
    .res-folder-table a { color: var(--color-text); text-decoration: none; }
    .res-folder-table a:hover { color: var(--color-brand-700); text-decoration: underline; }
</style>
