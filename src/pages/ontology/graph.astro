---
/**
 * /ontology/graph — the multi-engine ontology-graph bake-off (ADR-0043 / ADR-0047).
 *
 * Every scored graph engine renders the SAME committed model
 * (/data/ontology-graph-elements.json, derived from the SPARQL model by
 * scripts/ontology-graph.mjs) in its own tab, so the ADR-0043 Cytoscape pick can
 * be judged in situ against the alternatives. Server-less: each engine
 * lazy-loads from the jsdelivr CDN client-side (the Mermaid pattern), so the
 * page is pure SSG. The orchestrator (public/ui/ontology-graph.js) owns the tab
 * bar + shared chrome; each engine is a self-registering module under
 * public/ui/graph-engines/.
 */
import Layout from '@/layouts/Layout.astro';
import { model } from '@/lib/ontology-model';

const counts = model.counts;

// Node fill encodes node TYPE (see _shared.js COLORS); the UFO facet is a filter,
// not a colour. Bump clientV when the engine/orchestrator JS changes (cache-bust).
const clientV = '4';
---
<Layout
  title="Ontology graph — interactive bake-off"
  description="The whole OPDA ontology as an interactive node-link graph, rendered by every graph engine in the ADR-0043/0047 bake-off — Cytoscape, D3, vis-network, force-graph, G6, Sigma, plus Mermaid and Graphviz. Switch tabs to compare them on the same SPARQL-derived model: zoom, filter, focus a term's neighbourhood."
  hideComments={true}
>
  <nav class="term-nav" aria-label="Breadcrumb">
    <a href="/ontology">Ontology</a>
    <span class="sep" aria-hidden="true">›</span>
    <span aria-current="page">Interactive graph</span>
  </nav>

  <header class="term-header">
    <p class="term-kind"><span class="pill pill--brand">Interactive graph · engine bake-off</span></p>
    <h1>Ontology graph</h1>
    <p class="term-comment">
      The whole ontology as a node-link graph, rendered from the committed SPARQL-derived model
      (<a href="/resource?path=docs/adr/ADR-0043-ontology-graph-diagram-tooling.md">ADR-0043</a> /
      <a href="/resource?path=docs/adr/ADR-0047-ontology-graph-engine-bakeoff.md">ADR-0047</a>). Each
      <strong>tab</strong> is a different graph engine drawing the <strong>same</strong> {counts.classes} classes
      and {counts.objectProps} object properties, <strong>coloured by node type</strong>. Use
      <strong>Filter by facet</strong> to show only chosen
      <a href="/ontology/foundational-ontology"><code>opda:ufoCategory</code></a> meta-categories, or flip
      <strong>Show SKOS layer</strong> to add the {counts.schemes} concept schemes and {counts.concepts} concepts.
      Click a node to focus its neighbourhood and open its dereferenceable <code>/pdtf</code> page.
      Engines lazy-load from a CDN on first view.
    </p>
  </header>

  <div id="og-root" class="og-root">
    <p class="og-tabs-label">Graph engine — click a tab to switch:</p>
    <div id="og-tabs" class="flex flex-wrap gap-1 border-b-2 border-[var(--color-border-strong)]" role="tablist" aria-label="Graph engine"></div>
    <p id="og-note" class="og-note" aria-live="polite"></p>

    <div class="og-toolbar" role="group" aria-label="Graph controls">
      <label class="og-ctl" id="og-layout-wrap" hidden>Layout
        <select id="og-layout"></select>
      </label>
      <label class="og-ctl og-ctl--check">
        <input type="checkbox" id="og-skos" /> Show SKOS layer
      </label>
      <button type="button" id="og-reset" class="og-btn">Reset</button>
      <span id="og-status" class="og-status" aria-live="polite">Initialising…</span>
      <div class="og-ctl og-facets-ctl">
        <span class="og-facets-title">Filter by facet</span>
        <div id="og-facets" class="og-facets" role="group" aria-label="Filter by UFO meta-category facet"></div>
      </div>
    </div>

    <div class="og-stage">
      <div id="ontology-graph" class="og-canvas" role="img"
           aria-label="Interactive node-link graph of the OPDA ontology. Requires JavaScript; the typed indexes under /ontology are the non-interactive equivalent."></div>
      <aside class="og-side">
        <div id="og-info" class="og-info"></div>
        <div class="og-legend">
          <h4>Node type</h4>
          <ul class="og-legend--shapes">
            <li><span class="og-swatch og-swatch--class"></span>Class (OWL)</li>
            <li><span class="og-swatch og-swatch--scheme"></span>Concept scheme (SKOS)</li>
            <li><span class="og-swatch og-swatch--concept"></span>Concept (SKOS)</li>
            <li><span class="og-swatch og-swatch--external"></span>External target</li>
            <li><span class="og-swatch og-swatch--shape"></span>Has SHACL shape</li>
          </ul>
          <p class="og-legend-note">Colour shows node <strong>type</strong>; use <strong>Filter by facet</strong> above to narrow classes by <code>opda:ufoCategory</code>.</p>
        </div>
      </aside>
    </div>
    <noscript>
      <p class="og-noscript">This interactive graph needs JavaScript. The same model is available as
        the typed indexes under <a href="/ontology/classes">Classes</a>,
        <a href="/ontology/vocabularies">Vocabularies</a> and
        <a href="/ontology/shapes">Shapes</a>.</p>
    </noscript>
  </div>

  <h2 id="related">Related</h2>
  <p>
    Per-term pages: <a href="/ontology/classes">Classes</a> ·
    <a href="/ontology/vocabularies">Vocabularies (SKOS)</a> ·
    <a href="/ontology/shapes">Shapes (SHACL)</a>. The classification doctrine behind the facets:
    <a href="/ontology/identity#doctrine">Identity &amp; classification</a>. Tooling decisions:
    <a href="/resource?path=docs/adr/ADR-0043-ontology-graph-diagram-tooling.md">ADR-0043</a> ·
    <a href="/resource?path=docs/adr/ADR-0047-ontology-graph-engine-bakeoff.md">ADR-0047</a>.
  </p>
  <p class="og-external">
    <strong>External-only tools</strong> (scored in the bake-off but can&rsquo;t read the corpus behind the
    site&rsquo;s edge auth, so they aren&rsquo;t live tabs):
    <a href="https://service.tib.eu/webvowl/" rel="external">WebVOWL</a> (OWL-only, interactive) ·
    <a href="https://skos-play.sparna.fr/play/" rel="external">SKOS Play!</a> (concept-scheme trees / sunburst).
    Point either at a public export to use them.
  </p>

  <style>
    .term-nav { font: 500 var(--text-sm)/1.4 var(--font-sans); color: var(--color-text-muted); margin: 0 0 var(--space-4); display: flex; flex-wrap: wrap; gap: var(--space-2); align-items: center; }
    .term-nav .sep { color: var(--color-border-strong); }
    .term-header { margin: 0 0 var(--space-5); }
    .term-kind { margin: 0 0 var(--space-2); }
    .term-comment { font: 400 var(--text-base)/var(--leading-relaxed) var(--font-sans); color: var(--color-text); margin: var(--space-3) 0 0; max-width: 72ch; }
  </style>

  <!-- og-* rules are is:global because the tab buttons + info-panel content are
       created by ontology-graph.js at runtime; Astro's scoped styles would not
       match JS-created elements (they lack the data-astro-cid attribute). All
       selectors are og-namespaced, so global is leak-safe. -->
  <style is:global>
    .og-external { font: 400 var(--text-sm)/var(--leading-relaxed) var(--font-sans); color: var(--color-text-muted); max-width: 72ch; }

    .og-root { margin: var(--space-5) 0; }
    .og-tabs-label { font: 700 var(--text-xs)/1.3 var(--font-sans); text-transform: uppercase; letter-spacing: .04em; color: var(--color-text-muted); margin: 0 0 var(--space-2); }
    .og-note { font: 400 var(--text-xs)/1.4 var(--font-sans); color: var(--color-text-muted); margin: var(--space-2) 0 var(--space-3); min-height: 1.2em; }

    .og-toolbar { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: end; padding: var(--space-3); background: var(--color-surface-tint); border: 1px solid var(--color-border); border-radius: var(--radius-md, 8px); margin: 0 0 var(--space-3); }
    .og-ctl { display: flex; flex-direction: column; gap: var(--space-1); font: 600 var(--text-xs)/1.3 var(--font-sans); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: .03em; }
    .og-ctl--check { flex-direction: row; align-items: center; gap: var(--space-2); text-transform: none; letter-spacing: 0; font-size: var(--text-sm); color: var(--color-text); align-self: center; }
    .og-ctl select { font: 400 var(--text-sm)/1.4 var(--font-sans); color: var(--color-text); background: var(--color-surface); border: 1px solid var(--color-border-strong); border-radius: 6px; padding: var(--space-1) var(--space-2); min-width: 11rem; }
    .og-btn { font: 600 var(--text-sm)/1 var(--font-sans); color: var(--color-text); background: var(--color-surface); border: 1px solid var(--color-border-strong); border-radius: 6px; padding: var(--space-2) var(--space-3); cursor: pointer; align-self: center; }
    .og-btn:hover { border-color: var(--color-brand-500); }
    .og-status { font: 400 var(--text-xs)/1.4 var(--font-sans); color: var(--color-text-muted); margin-left: auto; align-self: center; }

    /* Facet filter — built by ontology-graph.js, so styled globally (the chips
       are JS-created and never carry Astro's scoped data-astro-cid attribute). */
    .og-facets-ctl { flex-basis: 100%; flex-direction: column; align-items: stretch; gap: var(--space-2); }
    .og-facets-title { font: 600 var(--text-xs)/1.3 var(--font-sans); text-transform: uppercase; letter-spacing: .03em; color: var(--color-text-muted); }
    .og-facets { display: flex; flex-wrap: wrap; gap: var(--space-1) var(--space-2); }
    .og-facet { display: inline-flex; align-items: center; gap: var(--space-1); font: 500 var(--text-xs)/1.2 var(--font-sans); color: var(--color-text); background: var(--color-surface); border: 1px solid var(--color-border-strong); border-radius: 999px; padding: 2px var(--space-2); cursor: pointer; user-select: none; }
    .og-facet:hover { border-color: var(--color-brand-500); }
    .og-facet input { margin: 0; cursor: pointer; }

    .og-stage { display: grid; grid-template-columns: 1fr 17rem; gap: var(--space-3); }
    .og-canvas { height: 72vh; min-height: 30rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md, 8px); overflow: hidden; position: relative; }
    .og-canvas--diagram { overflow: auto; }
    .og-side { display: flex; flex-direction: column; gap: var(--space-3); min-width: 0; }
    .og-info { padding: var(--space-3); background: var(--color-surface-tint); border: 1px solid var(--color-border); border-radius: var(--radius-md, 8px); min-height: 6rem; }
    .og-info h3 { font: 700 var(--text-base)/1.3 var(--font-mono, monospace); color: var(--color-text-strong); margin: 0 0 var(--space-2); word-break: break-word; }
    .og-info .og-meta { display: flex; flex-wrap: wrap; gap: var(--space-1); margin: var(--space-2) 0 0; font-size: var(--text-xs); color: var(--color-text-muted); }
    .og-info .og-pill { background: var(--color-surface-inset); border: 1px solid var(--color-border); border-radius: 999px; padding: 1px var(--space-2); }
    .og-info .og-hint { font-size: var(--text-sm); color: var(--color-text-muted); margin: 0; }
    .og-legend { padding: var(--space-3); background: var(--color-surface-tint); border: 1px solid var(--color-border); border-radius: var(--radius-md, 8px); }
    .og-legend h4 { font: 600 var(--text-xs)/1.3 var(--font-sans); text-transform: uppercase; letter-spacing: .03em; color: var(--color-text-muted); margin: 0 0 var(--space-2); }
    .og-legend h4:not(:first-child) { margin-top: var(--space-3); }
    .og-legend ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-1); }
    .og-legend li { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--color-text); }
    .og-swatch { width: 14px; height: 14px; border-radius: 50%; flex: none; border: 1px solid var(--color-border-strong); }
    .og-swatch--class { background: #0072B2; }
    .og-swatch--scheme { background: #6E56CF; border-radius: 3px; }
    .og-swatch--concept { background: #9E8CFC; }
    .og-swatch--external { background: #9E9E9E; transform: rotate(45deg); border-radius: 2px; }
    .og-swatch--shape { background: transparent; border: 3px double var(--color-brand-500); }
    .og-legend-note { font: 400 var(--text-xs)/1.4 var(--font-sans); color: var(--color-text-muted); margin: var(--space-3) 0 0; }
    .og-noscript, .og-info a { font-size: var(--text-sm); }
    @media (max-width: 56rem) { .og-stage { grid-template-columns: 1fr; } .og-canvas { height: 60vh; } }
  </style>

  <!-- Engine bake-off: shared registry, then each self-registering engine, then the orchestrator. -->
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/_shared.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/cytoscape.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/d3.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/vis-network.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/force-graph.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/g6.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/sigma.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/mermaid.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/graph-engines/dot.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun src={`/ui/ontology-graph.js?v=${clientV}`}></script>
  <script slot="scripts" is:inline data-astro-rerun>
    // Mount is deferred to astro:page-load so the engine modules + orchestrator
    // above have loaded and set window.OPDA_GRAPH. The handler is stored on
    // window so each re-run (data-astro-rerun) removes the previous listener,
    // preventing multiple mounts across view-transition navigation.
    if (window._opdaGraphMount) {
      document.removeEventListener('astro:page-load', window._opdaGraphMount);
    }
    window._opdaGraphMount = function () {
      if (window.OPDA_GRAPH && document.getElementById('og-root')) window.OPDA_GRAPH.mount();
    };
    document.addEventListener('astro:page-load', window._opdaGraphMount);
  </script>
</Layout>
