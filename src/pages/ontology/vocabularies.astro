---
/**
 * /ontology/vocabularies — typed index of the SKOS concept schemes (ADR-0044
 * Phase 4). Reads the SPARQL-derived ontology model (no regex): every scheme
 * with its concept count, prefLabel, definition and opda:ufoCategory, each
 * linking to its canonical dereferenceable /pdtf page. The Skosmos / Ontospy
 * renderings remain linked as per-concept browse extras.
 */
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import { model } from '@/lib/ontology-model';
import fs from 'node:fs';
import path from 'node:path';

const PUB = path.resolve(process.cwd(), 'public/ontology');
function exists(rel: string): boolean {
  try { return fs.existsSync(path.join(PUB, rel)); } catch { return false; }
}

const schemes = Object.values(model.schemes).sort((a, b) => a.localName.localeCompare(b.localName));
const totalConcepts = schemes.reduce((n, s) => n + s.concepts.length, 0);

const SKOSMOS = { href: '/ontology/tools/skosmos/schemes.html', live: exists('tools/skosmos/schemes.html'), browser: 'http://localhost:9090/' };
const ONTOSPY = { href: '/ontology/tools/ontospy/index.html', live: exists('tools/ontospy/index.html') };
---
<Layout
  title="Vocabularies (SKOS)"
  description="Typed index of the OPDA SKOS concept schemes: every scheme with its concept count, UFO category and definition from the SPARQL-derived ontology model, each linking to its canonical /pdtf page. Plus the /pdtf/scheme/ kind-split (ADR-0006) and the Skosmos / Ontospy browse renderings."
>
<PageMeta category="Browse the model" variant="brand" updated="Draft · Updated 2026-06-15" />

  <h1>Vocabularies (SKOS)</h1>

  <p class="lead">
    The <strong>{schemes.length} SKOS concept schemes</strong> ({totalConcepts} concepts in total) that carry
    every coded value-space in the ontology — from the SPARQL-extracted
    <a href="/ontology/provenance">ontology model</a>. Under the
    <a href="/ontology/identity#doctrine">classification doctrine</a> (<a href="/modelling/odr/odr-0027">ODR-0027</a>), these schemes do the work that
    subclass trees do in lesser models: every enumeration, status set, and kind-discriminator is a
    <code>skos:ConceptScheme</code> referenced by a coded value — <em>never</em> an <code>owl:oneOf</code> bag
    and never a subclass enumeration. <strong>Each scheme links to its own page</strong> with its full concept
    membership.
  </p>

  <nav class="callout callout--note" aria-label="On this page">
    <p class="callout__label">On this page</p>
    <ul>
      <li><a href="#kind-split">The <code>/pdtf/scheme/</code> kind-split</a> — why schemes live in their own namespace (<a href="/modelling/adr/adr-0006">ADR-0006</a>)</li>
      <li><a href="#ufo">UFO-category roll-up</a> — the seven-category framework</li>
      <li><a href="#index">Scheme index</a> — all {schemes.length}, linked, with concept counts</li>
      <li><a href="#browse">Browse per-concept</a> — Skosmos &amp; Ontospy</li>
    </ul>
  </nav>

  <h2 id="kind-split">The <code>/pdtf/scheme/</code> kind-split (<a href="/modelling/adr/adr-0006">ADR-0006</a>)</h2>
  <p>
    The concept schemes deliberately live under a <strong>separate namespace segment</strong>,
    <code>https://opda.org.uk/pdtf/scheme/</code> (prefix <code>opda-v:</code>), distinct from the flat term
    namespace <code>https://opda.org.uk/pdtf/</code> (prefix <code>opda:</code>). The reason
    (<a href="/governance">ADR-0006</a>, directing-authority ruling 2026-06-02) is collision-avoidance: a
    property such as <code>opda:role</code> at <code>…/pdtf/role</code> must not collide with the
    <em>Participant Role</em> scheme — so the scheme resolves at <code>…/pdtf/scheme/role</code> and its members
    at <code>…/pdtf/scheme/role/Buyer</code>. A few schemes minted in the flat term namespace (e.g.
    <code>BoundedContextScheme</code>) resolve at <code>…/pdtf/{'{'}Name{'}'}</code> instead — the link target
    below reflects each scheme's actual IRI.
  </p>

  <h2 id="ufo">UFO category</h2>
  <p>
    Schemes no longer carry <code>opda:ufoCategory</code>. The register-deference value-space tags
    (<strong>Quale-in-Region</strong> etc.) were split off the predicate — they are value-space shape,
    not UFO categorial work (<a href="/ontology/foundational-ontology">ODR-0030 Rule 2 / ODR-0031</a>).
    The <code>opda:ufoCategory</code> facet is now reserved for the nine UFO meta-categories of the OWL
    <a href="/ontology/classes#by-category">classes</a>, as an inert, annotation-graph-only documentary
    annotation (UFO-informed, not UFO-grounded).
  </p>

  <h2 id="index">Scheme index <span class="muted">· {schemes.length} schemes · {totalConcepts} concepts</span></h2>
  <table>
    <thead><tr><th>Scheme</th><th>Concepts</th><th>Definition</th></tr></thead>
    <tbody>
      {schemes.map((s) => (
        <tr>
          <td><a href={`/pdtf/${s.id}`}><code>{s.localName}</code></a>{s.prefLabel && s.prefLabel !== s.localName && <><br/><span class="muted">{s.prefLabel}</span></>}</td>
          <td>{s.concepts.length}</td>
          <td>{s.definition || <span class="muted">—</span>}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2 id="browse">Browse per-concept</h2>
  <p>
    Each concept has its own <code>/pdtf</code> page (linked from its scheme above). For an interactive
    cross-scheme browser — concept hierarchies, search — the bake-off (<a href="/ontology/bake-off">ADR-0041</a>)
    renders the schemes with two tools:
  </p>
  <table>
    <thead><tr><th>Rendering</th><th>What it gives</th><th>Open</th></tr></thead>
    <tbody>
      <tr>
        <td><strong>Skosmos</strong></td>
        <td>The dedicated SKOS browser — schemes list, concept hierarchies, search. Runs over the local Fuseki via <code>make serve-data</code> + <code>make skosmos</code> (localhost-only, <a href="/ontology/bake-off">ADR-0041</a> §B2); the static schemes list is the always-available fallback.</td>
        <td>
          <a href={SKOSMOS.browser}>Skosmos browser ↗</a> <span class="muted">(localhost:9090 — needs <code>make serve-data</code> + <code>make skosmos</code>)</span><br/>
          {SKOSMOS.live ? <a href={SKOSMOS.href}>Static schemes list ↗</a> : <span class="pill pill--warn">Pending generation</span>}
        </td>
      </tr>
      <tr>
        <td><strong>Ontospy</strong></td>
        <td>Multi-page browser with a per-scheme / per-concept page set (e.g. <code>class-skosconceptscheme.html</code>).</td>
        <td>{ONTOSPY.live ? <a href={ONTOSPY.href}>Ontospy SKOS pages ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
    </tbody>
  </table>

  <h2 id="related">Related</h2>
  <p>
    Why coded schemes carry the classification: <a href="/ontology/identity#doctrine">the classification
    doctrine (ODR-0027)</a>. The OWL classes these values attach to are on
    <a href="/ontology/classes">Classes</a>; the properties that reference them are on
    <a href="/ontology/properties">Properties</a>. Full index:
    <a href="/ontology/glossary">Index &amp; glossary</a>.
  </p>
</Layout>
