 * ADR-0041 §13 (previously MISSING). The practical guide for a machine
 * consumer: the prefix / namespace map (with the ADR-0006 kind-split IRI
 * paths), runnable SPARQL, a dereferenceability / content-negotiation note,
 * the SHACL-validation recipe (pyshacl advanced=True REQUIRED), and the TTL
 * downloads.
 *
 * Prefixes verified against public/ontology/artefacts/opda-merged.ttl and
 * opda-shapes-merged.ttl. IRI paths follow ADR-0006 (kind-split namespaces).
 */
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import fs from 'node:fs';
import path from 'node:path';

// The merged-corpus artefact bundle is build-generated under public/ontology/
// (gitignored). Guard the download links so the page degrades to plain text
// when the bundle is absent rather than emitting dangling links — the same
// pattern exemplars.astro / shapes.astro use for the artefacts index.
const PUB = path.resolve(process.cwd(), 'public/ontology');
const exists = (rel: string): boolean => {
  try { return fs.existsSync(path.join(PUB, rel)); } catch { return false; }
};
const mergedTtl = exists('artefacts/opda-merged.ttl');
const shapesTtl = exists('artefacts/opda-shapes-merged.ttl');
const sourceIdx = exists('artefacts/source/index.html');
