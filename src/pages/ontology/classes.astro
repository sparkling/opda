---
/**
 * /ontology/classes — typed index of the OWL classes (ADR-0044 Phase 4).
 *
 * Reads the committed src/data/ontology-model.json (SPARQL-derived, ADR-0044
 * Phase 1 — no brittle regex), groups the classes by bounded-context module, and
 * links each to its canonical dereferenceable page at /pdtf/{LocalName}. The
 * pyLODE/WIDOCO/Ontospy renderings remain linked as comparison extras
 * (ADR-0044 §Supersession; the native /pdtf pages are now the per-term reference).
 */
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import { model } from '@/lib/ontology-model';
import fs from 'node:fs';
import path from 'node:path';

const PUB = path.resolve(process.cwd(), 'public/ontology');
function exists(rel: string): boolean {
  try { return fs.existsSync(path.join(PUB, rel)); } catch { return false; }
}

// Bounded-context grouping (ADR-0044 Phase-1 canonical 7); notes per ODR.
const GROUPS = [
  { ctx: 'foundation',  heading: 'Foundation', note: 'UFO meta-classes + provenance/validation units shared across modules (ODR-0004 / ODR-0009 / ODR-0011).' },
  { ctx: 'property',    heading: 'Property & land', note: 'The identity crux — three Substance Kinds plus succession events and address (ODR-0005 / ODR-0015).' },
  { ctx: 'agent',       heading: 'Agents & roles', note: 'Person / Organisation Kinds and the Seller / Buyer / Proprietor roles founded by Relators (ODR-0006).' },
  { ctx: 'transaction', heading: 'Transaction & lifecycle', note: 'The Transaction Relator, milestones, and chains (ODR-0007).' },
  { ctx: 'claim',       heading: 'Claims, evidence & provenance', note: 'PROV-O-backed Claim / Evidence (RoleMixin) / verification structures (ODR-0009).' },
  { ctx: 'governance',  heading: 'Governance', note: 'DPV mapping records and the special-category PII scheme (ODR-0012).' },
  { ctx: 'descriptive', heading: 'Descriptive attributes', note: 'Authority-retrieved Information Objects and value structures — EPC, survey, valuation, search (ODR-0008).' },
];
const allClasses = Object.values(model.classes);
const data = GROUPS.map((g) => ({
  ...g,
  classes: allClasses.filter((c) => c.context === g.ctx).sort((a, b) => a.localName.localeCompare(b.localName)),
})).filter((g) => g.classes.length > 0);
const total = allClasses.length;

const PYLODE = { href: '/ontology/tools/pylode/index.html', live: exists('tools/pylode/index.html') };
const WIDOCO = { href: '/ontology/tools/widoco/doc/index-en.html', live: exists('tools/widoco/doc/index-en.html') };
const ONTOSPY = { href: '/ontology/tools/ontospy/index.html', live: exists('tools/ontospy/index.html') };
---
<Layout
  title="Classes"
  description="Typed index of the OPDA OWL classes, grouped by bounded-context module with each class's rdfs:comment, read from the SPARQL-derived ontology model. Each class links to its canonical dereferenceable /pdtf page."
>
<PageMeta category="Browse the model" variant="brand" updated="Draft · Updated 2026-06-15" />

  <h1>Classes</h1>

  <p class="lead">
    The <strong>{total} OWL classes</strong> of the OPDA PDTF ontology, grouped by bounded-context module and
    listed with each class's <code>rdfs:comment</code> — sourced from the SPARQL-extracted
    <a href="/ontology/provenance">ontology model</a> (ADR-0044). The classes are kept deliberately few and
    rigid (every type that merely <em>varies</em> is a coded SKOS value, not a subclass — see
    <a href="/ontology/identity#doctrine">the classification doctrine</a>). <strong>Each class links to its own
    page</strong> at <code>/pdtf/{'{'}LocalName{'}'}</code> — the canonical, dereferenceable reference with its
    incoming and outgoing connections, attributes, governing shapes and provenance.
  </p>

  <nav class="callout callout--note" aria-label="On this page">
    <p class="callout__label">On this page</p>
    <ul>
      {data.map((g) => (
        <li><a href={`#${g.ctx}`}>{g.heading}</a> — {g.classes.length} classes</li>
      ))}
      <li><a href="#reference">Comparison renderings</a> — pyLODE &amp; WIDOCO</li>
    </ul>
  </nav>

  {data.map((g) => (
    <section>
      <h2 id={g.ctx}><a href={`/ontology/context/${g.ctx}`}>{g.heading}</a> <span class="muted">· {g.classes.length} classes</span></h2>
      <p>{g.note}</p>
      <table>
        <thead><tr><th>Class</th><th>Definition (<code>rdfs:comment</code>)</th></tr></thead>
        <tbody>
          {g.classes.map((c) => (
            <tr>
              <td><a href={`/pdtf/${c.id}`}><code>opda:{c.localName}</code></a></td>
              <td>{c.comment || <span class="muted">—</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}

  <h2 id="reference">Comparison renderings</h2>
  <p>
    The native per-class pages above are the authoritative reference (ADR-0044). The bake-off
    (<a href="/ontology/bake-off">ADR-0041</a>) OWL tools remain available as comparison extras — pyLODE as the
    best single-file term reference, WIDOCO as the richest publishable shell with VOWL diagrams.
  </p>
  <table>
    <thead><tr><th>Rendering</th><th>What it gives</th><th>Open</th></tr></thead>
    <tbody>
      <tr>
        <td><strong>pyLODE</strong></td>
        <td>Best single-file OWL term reference — every class &amp; property with axioms inline.</td>
        <td>{PYLODE.live ? <a href={PYLODE.href}>View pyLODE ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
      <tr>
        <td><strong>WIDOCO</strong></td>
        <td>Richest publishable shell — metadata, cross-reference, WebVOWL diagrams.</td>
        <td>{WIDOCO.live ? <a href={WIDOCO.href}>View WIDOCO ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
      <tr>
        <td><strong>Ontospy</strong></td>
        <td>Multi-page OWL browser with per-class pages and visualisations.</td>
        <td>{ONTOSPY.live ? <a href={ONTOSPY.href}>View Ontospy ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
    </tbody>
  </table>

  <h2 id="related">Related</h2>
  <p>
    Why the classes are shaped this way: <a href="/ontology/foundation#ufo">the UFO meta-category legend</a>
    and <a href="/ontology/identity">Identity &amp; classification</a>. See also
    <a href="/ontology/properties">Properties</a> and <a href="/ontology/vocabularies">Vocabularies (SKOS)</a>.
    Full index: <a href="/ontology/glossary">Index &amp; glossary</a>.
  </p>
</Layout>
