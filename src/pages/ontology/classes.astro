---
/**
 * /ontology/classes — typed index of the OWL classes (ADR-0044 Phase 4).
 *
 * Reads the committed src/data/ontology-model.json (SPARQL-derived, ADR-0044
 * Phase 1 — no brittle regex), groups the classes by bounded-context module, and
 * links each to its canonical dereferenceable page at /pdtf/{LocalName}. The
 * pyLODE/WIDOCO/Ontospy renderings remain linked as comparison extras
 * (ADR-0044 §Supersession; the native /pdtf pages are now the per-term reference).
 */
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import { model, ufoCategories } from '@/lib/ontology-model';
import fs from 'node:fs';
import path from 'node:path';

const PUB = path.resolve(process.cwd(), 'public/ontology');
function exists(rel: string): boolean {
  try { return fs.existsSync(path.join(PUB, rel)); } catch { return false; }
}

// Bounded-context grouping (ADR-0044 Phase-1 canonical 7); notes per ODR.
const GROUPS = [
  { ctx: 'foundation',  heading: 'Foundation', note: 'UFO meta-classes + provenance/validation units shared across modules (ODR-0004 / ODR-0009 / ODR-0011).' },
  { ctx: 'property',    heading: 'Property & land', note: 'The identity crux — three Substance Kinds plus succession events and address (ODR-0005 / ODR-0015).' },
  { ctx: 'agent',       heading: 'Agents & roles', note: 'Person / Organisation Kinds and the Seller / Buyer / Proprietor roles founded by Relators (ODR-0006).' },
  { ctx: 'transaction', heading: 'Transaction & lifecycle', note: 'The Transaction Relator, milestones, and chains (ODR-0007).' },
  { ctx: 'claim',       heading: 'Claims, evidence & provenance', note: 'PROV-O-backed Claim / Evidence (RoleMixin) / verification structures (ODR-0009).' },
  { ctx: 'governance',  heading: 'Governance', note: 'DPV mapping records and the special-category PII scheme (ODR-0012).' },
  { ctx: 'descriptive', heading: 'Descriptive attributes', note: 'Authority-retrieved Information Objects and value structures — EPC, survey, valuation, search (ODR-0008).' },
];
const allClasses = Object.values(model.classes);
const data = GROUPS.map((g) => ({
  ...g,
  classes: allClasses.filter((c) => c.context === g.ctx).sort((a, b) => a.localName.localeCompare(b.localName)),
})).filter((g) => g.classes.length > 0);
const total = allClasses.length;
const cats = ufoCategories();

// Per-section class diagram (diagramming skill 17-LINKED-DATA-GUIDE: flowchart LR
// + ELK, Subject -->|predicate| Object). The context's own classes are :::user.
// Object properties to/from classes in OTHER sections are ALSO drawn — we walk
// each class's `incoming` as well as its `outgoing`, so a cross-section link
// appears in BOTH endpoints' sections. The foreign class is pulled in as a
// :::xsection node (dashed border + muted fill) with its owning "(Section)" on a
// second line, and its connector is dashed (-.->) to mark the boundary. Authored
// bare — client.js owns the theme + Cagle palette (ODR diagram convention), so no
// classDef / %%init%% here (the :::xsection palette entry lives in client.js).
function sectionDiagram(g: { heading: string; classes: any[] }): string {
  const safe = (s: string) => 'c_' + String(s).replace(/[^A-Za-z0-9]/g, '_');
  const esc = (s: string) => String(s ?? '').replace(/&/g, '&amp;').replace(/"/g, '&quot;');
  const ctxHeading: Record<string, string> = Object.fromEntries(GROUPS.map((x) => [x.ctx, x.heading]));
  const inCtx = new Set(g.classes.map((c) => c.id));
  const nodes = new Map<string, { sid: string; label: string; cls: string }>();
  // Ensure a node for an opda class id (datatype/scheme/external non-classes are
  // skipped — they are attribute-like, not class graph nodes). In-context classes
  // are :::user; a class owned by another section is :::xsection with a
  // "Name<br/>(Section)" two-line label so the boundary is explicit in every view.
  const ensureNode = (id: string): { sid: string; label: string; cls: string } | null => {
    const hit = nodes.get(id);
    if (hit) return hit;
    const c = (model.classes as Record<string, any>)[id];
    if (!c) return null;
    const isIn = inCtx.has(id);
    const name = esc(c.label || c.localName);
    const heading = esc(ctxHeading[c.context] || c.context || 'other');
    const n = {
      sid: safe(id),
      label: isIn ? name : `${name}<br/>(${heading})`,
      cls: isIn ? 'user' : 'xsection',
    };
    nodes.set(id, n);
    return n;
  };
  for (const c of g.classes) ensureNode(c.id);
  // One edge per (source,target) class pair; collapse the parallel object
  // properties (e.g. Property's six monetary predicates → MonetaryAmount) so the
  // diagram reads as a class graph rather than a hairball. `xsec` marks a pair
  // that touches another section → dashed connector + dashed node.
  const pairs = new Map<string, { s: string; t: string; preds: string[]; xsec: boolean }>();
  const addPair = (sId: string, tId: string, predLocal?: string) => {
    const s = ensureNode(sId), t = ensureNode(tId);
    if (!s || !t) return;
    const key = s.sid + '>>' + t.sid;
    if (!pairs.has(key)) pairs.set(key, { s: s.sid, t: t.sid, preds: [], xsec: s.cls === 'xsection' || t.cls === 'xsection' });
    const p = pairs.get(key)!;
    if (predLocal && !p.preds.includes(predLocal)) p.preds.push(predLocal);
  };
  for (const c of g.classes) {
    for (const e of c.outgoing || []) for (const t of e.targets || []) addPair(c.id, t.id, e.predicateLocal);
    for (const e of c.incoming || []) for (const s of e.sources || []) addPair(s.id, c.id, e.predicateLocal);
  }
  // Hierarchy (ADR-0055 Part 2; Council session-051 Q6, 7–0 FOR): draw each
  // class's rdfs:subClassOf as a muted dotted "isA" edge. EXTERNAL upper classes
  // (prov:Activity/Entity, time:, vcard:, org:, skos:) render as a distinct
  // :::upper node (prefixed label) — this is what groups the otherwise-disconnected
  // events under prov:Activity and the Information Objects under prov:Entity.
  // Internal opda supers (RoleMixin/Role/Relator) are ordinary class nodes
  // (user/xsection). Documentary depiction, NOT a subclass-tree commitment
  // (ODR-0027 classification-over-inheritance); never entailed (ADR-0035).
  const NS_PREFIX: Record<string, string> = {
    'http://www.w3.org/ns/prov#': 'prov:', 'http://www.w3.org/2006/time#': 'time:',
    'http://www.w3.org/2006/vcard/ns#': 'vcard:', 'http://www.w3.org/ns/org#': 'org:',
    'http://www.w3.org/2004/02/skos/core#': 'skos:', 'http://www.w3.org/2002/07/owl#': 'owl:',
  };
  const prefixed = (sup: { id: string; localName: string }) => {
    for (const ns in NS_PREFIX) if (String(sup.id).startsWith(ns)) return NS_PREFIX[ns] + sup.localName;
    return sup.localName;
  };
  const isa: { s: string; t: string }[] = [];
  for (const c of g.classes) {
    for (const sup of ((c as any).superClasses || [])) {
      let sid: string | null = null;
      if (sup.external) {
        const uid = 'u_' + safe(sup.id);
        if (!nodes.has(uid)) nodes.set(uid, { sid: uid, label: esc(prefixed(sup)), cls: 'upper' });
        sid = uid;
      } else {
        sid = ensureNode(sup.id)?.sid ?? null;
      }
      if (sid) isa.push({ s: safe(c.id), t: sid });
    }
  }
  const lines = [
    '---', 'config:', '  layout: elk', '  elk:', '    mergeEdges: false',
    '    nodePlacementStrategy: BRANDES_KOEPF', '---', 'flowchart LR',
    `    accTitle: ${g.heading} — class diagram`,
    `    accDescr: The classes of the ${g.heading} context, the object properties relating them (cross-context links dashed to a muted "(section)" node), and each class's rdfs:subClassOf hierarchy as a muted dotted "isA" edge to its super (external upper classes such as prov:Activity shown as muted nodes).`,
  ];
  for (const n of nodes.values()) lines.push(`    ${n.sid}["${n.label}"]:::${n.cls}`);
  for (const p of pairs.values()) {
    const label = p.preds.length === 1 ? p.preds[0] : p.preds.length > 1 ? `${p.preds.length} properties` : '';
    const arrow = p.xsec ? '-.->' : '-->';
    lines.push(label ? `    ${p.s} ${arrow}|${label}| ${p.t}` : `    ${p.s} ${arrow} ${p.t}`);
  }
  for (const p of isa) lines.push(`    ${p.s} -.->|isA| ${p.t}`);
  return lines.join('\n');
}

const PYLODE = { href: '/ontology/tools/pylode/index.html', live: exists('tools/pylode/index.html') };
const WIDOCO = { href: '/ontology/tools/widoco/doc/index-en.html', live: exists('tools/widoco/doc/index-en.html') };
const ONTOSPY = { href: '/ontology/tools/ontospy/index.html', live: exists('tools/ontospy/index.html') };
---
<Layout
  title="Classes"
  description="Typed index of the OPDA OWL classes, grouped by bounded-context module with each class's rdfs:comment, read from the SPARQL-derived ontology model. Each class links to its canonical dereferenceable /pdtf page."
>
<PageMeta category="Browse the model" variant="brand" updated="Draft · Updated 2026-06-15" />

  <h1>Classes</h1>

  <p class="lead">
    The <strong>{total} OWL classes</strong> of the OPDA PDTF ontology, grouped by bounded-context module and
    listed with each class's <code>rdfs:comment</code> — sourced from the SPARQL-extracted
    <a href="/ontology/provenance">ontology model</a> (<a href="/modelling/adr/adr-0044">ADR-0044</a>). The classes are kept deliberately few and
    rigid (every type that merely <em>varies</em> is a coded SKOS value, not a subclass — see
    <a href="/ontology/identity#doctrine">the classification doctrine</a>). <strong>Each class links to its own
    page</strong> at <code>/pdtf/{'{'}LocalName{'}'}</code> — the canonical, dereferenceable reference with its
    incoming and outgoing connections, attributes, governing shapes and provenance.
  </p>

  <nav class="callout callout--note" aria-label="On this page">
    <p class="callout__label">On this page</p>
    <ul>
      {data.map((g) => (
        <li><a href={`#${g.ctx}`}>{g.heading}</a> — {g.classes.length} classes</li>
      ))}
      <li><a href="#by-category">By UFO meta-category</a> — {cats.length} categories</li>
      <li><a href="#reference">Comparison renderings</a> — pyLODE &amp; WIDOCO</li>
    </ul>
  </nav>

  <p class="muted">
    Each section opens with its <strong>class diagram</strong> (same conventions as the
    <a href="/ontology/graph">interactive graph</a>): the context's own classes and the object properties
    relating them, with classes from <em>other</em> contexts they reference pulled in with a muted border.
  </p>

  {data.map((g) => (
    <section>
      <h2 id={g.ctx}><a href={`/ontology/context/${g.ctx}`}>{g.heading}</a> <span class="muted">· {g.classes.length} classes</span></h2>
      <p>{g.note}</p>
      <figure class="diagram section-class-diagram" role="figure"><div class="mermaid">{sectionDiagram(g)}</div></figure>
      <table>
        <thead><tr><th>Class</th><th>Definition (<code>rdfs:comment</code>)</th></tr></thead>
        <tbody>
          {g.classes.map((c) => (
            <tr>
              <td style="white-space: nowrap"><a href={`/pdtf/${c.id}`}>{c.label || c.localName}</a></td>
              <td>{c.comment || <span class="muted">—</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}

  <h2 id="by-category">Browse by UFO meta-category</h2>
  <p>
    The classes also group by their UFO foundational meta-category — the structured
    <code>opda:ufoCategory</code> facet (<a href="/modelling/odr/odr-0011">ODR-0011</a> §8a), the "facets, not subclass trees" view of
    <a href="/ontology/identity#doctrine">the classification doctrine</a>.
  </p>
  <ul class="ufo-cat-list">
    {cats.map((c) => (
      <li><a href={`/ontology/category/${c.slug}`}><strong>{c.category}</strong></a> <span class="muted">· {c.classes.length}</span></li>
    ))}
  </ul>

  <h2 id="reference">Comparison renderings</h2>
  <p>
    The native per-class pages above are the authoritative reference (<a href="/modelling/adr/adr-0044">ADR-0044</a>). The bake-off
    (<a href="/ontology/bake-off">ADR-0041</a>) OWL tools remain available as comparison extras — pyLODE as the
    best single-file term reference, WIDOCO as the richest publishable shell with VOWL diagrams.
  </p>
  <table>
    <thead><tr><th>Rendering</th><th>What it gives</th><th>Open</th></tr></thead>
    <tbody>
      <tr>
        <td><strong>pyLODE</strong></td>
        <td>Best single-file OWL term reference — every class &amp; property with axioms inline.</td>
        <td>{PYLODE.live ? <a href={PYLODE.href}>View pyLODE ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
      <tr>
        <td><strong>WIDOCO</strong></td>
        <td>Richest publishable shell — metadata, cross-reference, WebVOWL diagrams.</td>
        <td>{WIDOCO.live ? <a href={WIDOCO.href}>View WIDOCO ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
      <tr>
        <td><strong>Ontospy</strong></td>
        <td>Multi-page OWL browser with per-class pages and visualisations.</td>
        <td>{ONTOSPY.live ? <a href={ONTOSPY.href}>View Ontospy ↗</a> : <span class="pill pill--warn">Pending generation</span>}</td>
      </tr>
    </tbody>
  </table>

  <h2 id="related">Related</h2>
  <p>
    Why the classes are shaped this way: <a href="/ontology/foundation#ufo">the UFO meta-category legend</a>
    and <a href="/ontology/identity">Identity &amp; classification</a>. See also
    <a href="/ontology/properties">Properties</a> and <a href="/ontology/vocabularies">Vocabularies (SKOS)</a>.
    Full index: <a href="/ontology/glossary">Index &amp; glossary</a>.
  </p>

  <style is:global>
    /* Per-section class diagrams render at a quarter of the column width,
       left-aligned — the LR class graphs get very tall at full width. The
       fullscreen lightbox (zoom icon, top-right of each diagram) is the escape
       hatch for reading detail. */
    .diagram.section-class-diagram { max-width: 1200px !important; margin-right: auto !important; }
  </style>
</Layout>
