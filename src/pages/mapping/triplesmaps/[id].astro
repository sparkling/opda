---
/**
 * TriplesMap detail page — one per rr:TriplesMap (ADR-0060; per-rule pages
 * added 2026-07-06, mirroring the ADR-0044 /pdtf/{id} per-entity pattern).
 * Data comes from the committed source/03-standards/rml/triplesmap-index.json
 * (generated by harness/build_triplesmap_index.py, Jena arq only, ADR-0037/0061).
 */
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import fs from 'node:fs';
import path from 'node:path';
import { hasResource, pdtfUrl } from '@/lib/ontology-model';
import { schemaPathIndex, schemaContainerIndex } from '@/lib/schema-anchors';

// NB: getStaticPaths() is extracted into its own isolated scope by Astro's
// build — it cannot see module-level consts declared elsewhere in this file,
// only imports. So the index path is computed fresh, inline, both here and
// again below for the rest of the frontmatter (cheap: one small JSON read).
export function getStaticPaths() {
  const idxPath = path.resolve(process.cwd(), 'source/03-standards/rml/triplesmap-index.json');
  const idx = JSON.parse(fs.readFileSync(idxPath, 'utf8'));
  const bySection = new Map();
  for (const tm of idx.triplesmaps) {
    const code = tm.section_code || 'zzz';
    if (!bySection.has(code)) bySection.set(code, []);
    bySection.get(code).push(tm.id);
  }
  return idx.triplesmaps.map((tm) => {
    const siblings = bySection.get(tm.section_code || 'zzz');
    const i = siblings.indexOf(tm.id);
    return {
      params: { id: tm.id },
      props: {
        tm,
        prevId: i > 0 ? siblings[i - 1] : null,
        nextId: i < siblings.length - 1 ? siblings[i + 1] : null,
      },
    };
  });
}

const { tm, prevId, nextId } = Astro.props;

function resourceHref(compact: string): string | null {
  const id = compact.startsWith('opda:') ? compact.slice('opda:'.length) : compact;
  return hasResource(id) ? pdtfUrl(id) : null;
}
// Real, precise links into the /schema/* pages themselves — not the
// data-dictionary search (tried first, rejected: it indexes ONE canonical
// example path per shared property, e.g. opda:documentDate has two genuinely
// different real occurrences, and a bare-name search can't tell them apart).
// schemaPathIndex() reads the /schema pages' own committed
// data-leaf-path/id anchors directly (see src/lib/schema-anchors.ts) — the
// pipeline's real, final output, not a re-derivation of its routing rules.
const LEAF_INDEX = schemaPathIndex();
const CONTAINER_INDEX = schemaContainerIndex();
function hrefFrom(hit: { url: string; anchor: string | null } | undefined): string | null {
  if (!hit) return null;
  return hit.anchor ? `${hit.url}#${hit.anchor}` : hit.url;
}
function schemaHref(jsonPath: string): string | null {
  return hrefFrom(LEAF_INDEX[jsonPath]);
}
// The mapping file's own section comments (section_title/section_code) are
// kept ONLY as an internal ordering key for prev/next below — NOT shown on
// this page. They're the mapping author's own work-log entries, the exact
// "rule cluster" structure a design critique already rejected as page
// structure on the index (2026-07-06); showing the same label here would
// just reintroduce it one level down.
function iteratorContainerPath(iterator: string): string {
  let p = iterator.trim();
  if (p.startsWith("$")) p = p.slice(1);
  return p.replace(/^\./, "").replace(/\[\?\([^)]*\)\]/g, "[]").replace(/\[\*\]/g, "[]");
}
const iteratorHref = hrefFrom(CONTAINER_INDEX[iteratorContainerPath(tm.iterator)]);
---
<Layout
  title={`Mapping — #${tm.id}`}
  description={`RML TriplesMap #${tm.id} — ${tm.classes.join(', ') || 'untyped node'}, iterator ${tm.iterator}.`}
>
<PageMeta category={tm.classes.join(', ') || 'Untyped node'} variant="info" updated="Updated 2026-07-06" />

  <nav class="breadcrumb-override" aria-label="TriplesMap breadcrumb">
    <a href="/mapping/triplesmaps">TriplesMaps reference</a>
    <span aria-hidden="true"> / </span>
    <span>#{tm.id}</span>
  </nav>

  <h1><code>#{tm.id}</code></h1>
  <p class="lead">
    {tm.classes.length > 0 ? (
      <>Asserts <strong>
        {tm.classes.map((c, i) => (<>
          {i > 0 && ', '}
          {resourceHref(c) ? <a href={resourceHref(c)!}>{c}</a> : c}
        </>))}
      </strong></>
    ) : 'A class-assertion-only node (no predicateObjectMap rows).'}
    {' '}in the RML mapping.
  </p>

  <table>
    <tbody>
      <tr><th>JSONPath iterator</th><td>{iteratorHref
        ? <a href={iteratorHref}><code>{tm.iterator}</code></a>
        : <code>{tm.iterator}</code>}</td></tr>
      <tr><th>Subject template</th><td><code>{tm.subject_template || '—'}</code></td></tr>
    </tbody>
  </table>

  {tm.rows.length > 0 ? (
    <>
      <h2>Predicate rows <span class="muted">· {tm.rows.length}</span></h2>
      <table>
        <thead><tr><th>Predicate</th><th>Kind</th><th>JSON path / constant</th></tr></thead>
        <tbody>
          {tm.rows.map((r) => (
            <tr>
              <td>{resourceHref(r.predicate)
                ? <a href={resourceHref(r.predicate)!}><code>{r.predicate}</code></a>
                : <code>{r.predicate}</code>}
              </td>
              <td>{r.kind}</td>
              <td>{r.kind === 'constant'
                ? <code>{r.constant}</code>
                : (r.json_path && schemaHref(r.json_path)
                    ? <a href={schemaHref(r.json_path)!}><code>{r.json_path}</code></a>
                    : (r.json_path ? <code>{r.json_path}</code> : <span class="muted tiny">—</span>))}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  ) : (
    <p class="muted tiny">No predicateObjectMap rows — a class-assertion-only node.</p>
  )}

  <p class="muted tiny">
    Source: <a class="resource-link" href="/resource?path=source/03-standards/rml/mapping/opda-pdtf.rml.ttl"><code>mapping/opda-pdtf.rml.ttl</code></a>.
  </p>

  <p>
    {prevId && <>← <a href={`/mapping/triplesmaps/${prevId}`}><code>#{prevId}</code></a> · </>}
    <a href="/mapping/triplesmaps">All TriplesMaps</a>
    {nextId && <> · <a href={`/mapping/triplesmaps/${nextId}`}><code>#{nextId}</code></a> →</>}
  </p>
</Layout>
