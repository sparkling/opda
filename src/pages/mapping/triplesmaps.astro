---
import Layout from '@/layouts/Layout.astro';
import PageMeta from '@/components/PageMeta.astro';
import fs from 'node:fs';
import path from 'node:path';

// triplesmap-index.json is COMMITTED (source/03-standards/rml/, sibling to the
// already-tracked provenance-index.json) — regenerate via
// `make -C source/03-standards/rml triplesmap-index` after editing the mapping
// file. Generated by harness/build_triplesmap_index.py (Jena arq only, ADR-0060).
const INDEX_PATH = path.resolve(process.cwd(), 'source/03-standards/rml/triplesmap-index.json');
const triplesmapIndex = JSON.parse(fs.readFileSync(INDEX_PATH, 'utf8'));
const counts = triplesmapIndex.counts;

// -- View 1 data: group TriplesMaps by their M-section for a static listing --
const sectionsMap = new Map();
for (const tm of triplesmapIndex.triplesmaps) {
  const sec = tm.section || '(no section label)';
  if (!sectionsMap.has(sec)) sectionsMap.set(sec, []);
  sectionsMap.get(sec).push(tm);
}
const sections = [...sectionsMap.entries()]
  .sort((a, b) => a[0].localeCompare(b[0], undefined, { numeric: true }));

// -- Views 2 & 3 data: derive both directions from the one canonical index --
const byResourceMap = new Map();
const byPathMap = new Map();

for (const tm of triplesmapIndex.triplesmaps) {
  for (const cls of tm.classes) {
    if (!byResourceMap.has(cls)) {
      byResourceMap.set(cls, { resource: cls, kind: 'class', triplesmaps: new Set(), json_paths: new Set() });
    }
    byResourceMap.get(cls).triplesmaps.add(tm.id);
  }
  for (const row of tm.rows) {
    const pred = row.predicate;
    if (!byResourceMap.has(pred)) {
      byResourceMap.set(pred, { resource: pred, kind: 'property', triplesmaps: new Set(), json_paths: new Set() });
    }
    byResourceMap.get(pred).triplesmaps.add(tm.id);

    if (row.json_path) {
      for (const p of row.json_path.split(', ')) {
        byResourceMap.get(pred).json_paths.add(p);
        if (!byPathMap.has(p)) {
          byPathMap.set(p, { json_path: p, triplesmaps: new Set(), resources: new Set() });
        }
        byPathMap.get(p).triplesmaps.add(tm.id);
        byPathMap.get(p).resources.add(pred);
      }
    }
  }
}

const byResource = [...byResourceMap.values()]
  .map(r => ({ resource: r.resource, kind: r.kind, triplesmaps: [...r.triplesmaps].sort(), json_paths: [...r.json_paths].sort() }))
  .sort((a, b) => a.resource.localeCompare(b.resource));

const bySchemaPath = [...byPathMap.values()]
  .map(r => ({ json_path: r.json_path, triplesmaps: [...r.triplesmaps].sort(), resources: [...r.resources].sort() }))
  .sort((a, b) => a.json_path.localeCompare(b.json_path));
---
<Layout
  title="Mapping — TriplesMaps reference"
  description="Every rr:TriplesMap in the RML mapping, documented, plus two bidirectional indices — browse by ontology resource or by JSON Schema path."
>
<PageMeta category="Rule reference" variant="info" updated="Updated 2026-07-06" damaKa={["Metadata Management", "Data Integration & Interoperability"]} />

  <h1>TriplesMaps reference</h1>
  <p class="lead">
    Every <code>rr:TriplesMap</code> in <a class="resource-link" href="/resource?path=source/03-standards/rml/mapping/opda-pdtf.rml.ttl"><code>mapping/opda-pdtf.rml.ttl</code></a>,
    documented, plus two indices over the same data giving both directions of
    lookup — start from an ontology term, or start from a JSON Schema path.
  </p>

  <nav class="callout callout--note" aria-label="On this page">
    <div class="callout__label">On this page</div>
    <ul style="margin: 0;">
      <li><a href="#counts">The numbers</a></li>
      <li><a href="#by-triplesmap">By TriplesMap</a></li>
      <li><a href="#by-resource">By ontology resource</a></li>
      <li><a href="#by-schema-path">By JSON Schema path</a></li>
    </ul>
  </nav>

  <h2 id="counts">The numbers</h2>
  <table>
    <thead><tr><th>Metric</th><th>Count</th></tr></thead>
    <tbody>
      <tr><td><code>rr:TriplesMap</code> rules</td><td>{counts.triplesmaps}</td></tr>
      <tr><td>Real predicateObjectMaps (owned directly by a TriplesMap)</td><td>{counts.predicate_object_maps}</td></tr>
      <tr><td>Distinct ontology classes/properties touched</td><td>{counts.distinct_classes} classes + {counts.distinct_predicates} properties</td></tr>
      <tr><td>Distinct JSON Schema paths referenced</td><td>{counts.distinct_json_paths}</td></tr>
    </tbody>
  </table>
  <div class="callout callout--note">
    <div class="callout__label">526, not 438 — and why that's not a contradiction</div>
    <p>
      The mapping file has <strong>{counts.predicate_object_map_triples_total}</strong> total
      <code>rr:predicateObjectMap</code> triples, but only <strong>{counts.predicate_object_maps}</strong> of
      them belong directly to a <code>rr:TriplesMap</code>. The other
      <strong>{counts.fnml_nested_predicate_object_maps}</strong> are nested inside
      <strong>{counts.fnml_call_sites}</strong> <code>fnml:functionValue</code> blocks — the FNML
      function-call pattern (<a href="/mapping/how-it-works#enums">enum→SKOS slugification, date
      truncation</a>) — binding a function's name and parameters, not a schema↔ontology
      correspondence in their own right. This page's counts and rows are the
      {counts.predicate_object_maps} real ones only; the <a href="/mapping">section overview</a>'s
      own stat table now makes the same distinction.
    </p>
  </div>

  <h2 id="by-triplesmap">By TriplesMap</h2>
  <p>
    All {counts.triplesmaps} rules, grouped by the mapping file's own M-section comments
    (<code>M1</code>–<code>M36</code>, with lettered sub-variants). Each shows its JSONPath
    iterator (the row-selection context), the ontology class(es) it asserts, and every
    predicate it populates with the JSON Schema path (or constant) driving it.
  </p>
  {sections.map(([section, tms]) => (
    <details>
      <summary><strong>{section}</strong> — {tms.length} TriplesMap{tms.length === 1 ? '' : 's'}</summary>
      {tms.map(tm => (<>
        <p>
          <code>#{tm.id}</code>
          {tm.classes.length > 0 && <> — <strong>{tm.classes.join(', ')}</strong></>}
          {' '}<span class="muted tiny">iterator: <code>{tm.iterator}</code></span>
        </p>
        {tm.rows.length > 0 ? (
          <table>
            <thead><tr><th>Predicate</th><th>Kind</th><th>JSON path / constant</th></tr></thead>
            <tbody>
              {tm.rows.map(r => (
                <tr>
                  <td><code>{r.predicate}</code></td>
                  <td>{r.kind}</td>
                  <td>{r.kind === 'constant'
                    ? <code>{r.constant}</code>
                    : (r.json_path ? <code>{r.json_path}</code> : <span class="muted tiny">—</span>)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p class="muted tiny">No predicateObjectMap rows — a class-assertion-only node.</p>
        )}
      </>))}
    </details>
  ))}

  <h2 id="by-resource">By ontology resource</h2>
  <p>Start from a class or property — which TriplesMap(s) touch it, and which JSON Schema path(s) it reaches.</p>
  <div id="resource-browser" class="data-browser"></div>

  <h2 id="by-schema-path">By JSON Schema path</h2>
  <p>Start from a schema path — which TriplesMap(s) consume it, and which ontology term(s) it feeds.</p>
  <div id="schema-path-browser" class="data-browser"></div>

  <p>
    <a href="/mapping/how-it-works">← How it works</a> · <a href="/mapping/coverage">Coverage &amp; gaps →</a>
  </p>

<script type="application/json" id="mapping-by-resource" set:html={JSON.stringify(byResource)}></script>
<script type="application/json" id="mapping-by-schema-path" set:html={JSON.stringify(bySchemaPath)}></script>

<script slot="scripts" is:inline data-astro-rerun src="/ui/data-browser.js"></script>
<script slot="scripts" is:inline data-astro-rerun>
  if (window._opdaTriplesmapMount) {
    document.removeEventListener('astro:page-load', window._opdaTriplesmapMount);
  }
  window._opdaTriplesmapMount = function () {
    function esc(s) { return String(s == null ? '' : s).replace(/[<>&"]/g, c => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[c])); }
    function readJson(id) {
      var el = document.getElementById(id);
      if (!el) return [];
      try { return JSON.parse(el.textContent); } catch (e) { return []; }
    }
    function joinCode(arr) {
      if (!arr || !arr.length) return '<span class="muted tiny">—</span>';
      return arr.map(function (v) { return '<code>' + esc(v) + '</code>'; }).join(' ');
    }

    var byResource = readJson('mapping-by-resource');
    var resourceMount = document.getElementById('resource-browser');
    if (resourceMount && byResource.length) {
      OPDA.DataBrowser.mount({
        mount: resourceMount,
        heading: { id: 'by-resource-browse', text: 'Browse by ontology resource' },
        data: byResource,
        itemLabel: 'resources',
        searchPlaceholder: 'Search class or property name…',
        searchKeys: ['resource'],
        pageSize: 25,
        defaultSort: { key: 'resource', dir: 'asc' },
        facets: [{ key: 'kind', label: 'Kind' }],
        columns: [
          { key: 'resource', label: 'Ontology resource', sortable: true, width: '25%',
            render: function (v) { return '<code>' + esc(v) + '</code>'; } },
          { key: 'kind', label: 'Kind', sortable: true, width: '10%' },
          { key: 'triplesmaps', label: 'TriplesMap(s)', sortable: false, width: '25%',
            render: function (v) { return joinCode(v); } },
          { key: 'json_paths', label: 'JSON Schema path(s)', sortable: false, width: '40%',
            render: function (v) { return joinCode(v); } },
        ],
      });
    }

    var bySchemaPath = readJson('mapping-by-schema-path');
    var pathMount = document.getElementById('schema-path-browser');
    if (pathMount && bySchemaPath.length) {
      OPDA.DataBrowser.mount({
        mount: pathMount,
        heading: { id: 'by-path-browse', text: 'Browse by JSON Schema path' },
        data: bySchemaPath,
        itemLabel: 'schema paths',
        searchPlaceholder: 'Search a JSON Schema path…',
        searchKeys: ['json_path'],
        pageSize: 25,
        defaultSort: { key: 'json_path', dir: 'asc' },
        facets: [],
        columns: [
          { key: 'json_path', label: 'JSON Schema path', sortable: true, width: '35%',
            render: function (v) { return '<code>' + esc(v) + '</code>'; } },
          { key: 'triplesmaps', label: 'TriplesMap(s)', sortable: false, width: '25%',
            render: function (v) { return joinCode(v); } },
          { key: 'resources', label: 'Ontology resource(s)', sortable: false, width: '40%',
            render: function (v) { return joinCode(v); } },
        ],
      });
    }
  };
  document.addEventListener('astro:page-load', window._opdaTriplesmapMount);
</script>
</Layout>
