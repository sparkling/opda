---
/**
 * ADR-0044 §Decisions(a) — the IRI *is* the page. Canonical, dereferenceable
 * per-resource page served at `/pdtf/{id}` (the path after the opda base), so
 * `https://opda.org.uk/pdtf/Property` resolves to a real web page.
 *
 * Phase 2: classes + object/datatype properties. Phase 3 extends getStaticPaths
 * with shapes/concepts/schemes/contexts; Phase 6 adds the `.ttl` alternate.
 * Pure SSG — getStaticPaths reads the committed model JSON; no runtime query.
 */
import Layout from '@/layouts/Layout.astro';
import ClassDetail from '@/components/ontology/ClassDetail.astro';
import PropertyDetail from '@/components/ontology/PropertyDetail.astro';
import { allTerms } from '@/lib/ontology-model';

export function getStaticPaths() {
  return allTerms().map((term) => ({
    params: { name: term.id },
    props: { term },
  }));
}

const { term } = Astro.props;
const title = term.label || term.localName;
const description = (term.comment || '').replace(/\s+/g, ' ').trim().slice(0, 160);
---
<Layout title={title} description={description} hideComments={true}>
  {term.entryKind === 'class'
    ? <ClassDetail cls={term} />
    : <PropertyDetail prop={term} />}
</Layout>
