---
/**
 * ADR-0044 — render a cross-reference to another ontology resource.
 * Links to the resource's canonical `/pdtf/{id}` page when that page exists.
 * Classes and SKOS schemes have `/pdtf` pages (Phase 2 + 3), so they link;
 * datatypes and external IRIs render as plain code. Predicates link directly
 * (always a built property page).
 */
interface Props {
  id: string;
  localName: string;
  kind?: string | null;
}
const { id, localName, kind } = Astro.props;
const linkable = kind === 'class' || kind === 'scheme';
---
{linkable
  ? <a href={`/pdtf/${id}`}><code>{localName}</code></a>
  : <code class="ref-plain">{localName}</code>}
<style>
  .ref-plain { color: var(--color-text-muted); }
</style>
