---
/**
 * ADR-0044 — shared header for a canonical ontology term page (/pdtf/{id}).
 * Back-nav into the /ontology section, a kind + bounded-context badge, the
 * label, the dereferenceable IRI (selectable), and the rdfs:comment.
 */
interface Props {
  kind: string;
  label: string;
  localName: string;
  iri: string;
  comment?: string;
  context?: string | null;
  indexUrl: string;
  indexLabel: string;
}
const { kind, label, localName, iri, comment, context, indexUrl, indexLabel } = Astro.props;
---
<nav class="term-nav" aria-label="Breadcrumb">
  <a href="/ontology">Ontology</a>
  <span class="sep" aria-hidden="true">›</span>
  <a href={indexUrl}>{indexLabel}</a>
  <span class="sep" aria-hidden="true">›</span>
  <span aria-current="page">{label}</span>
</nav>

<header class="term-header">
  <p class="term-kind">
    <span class="pill pill--brand">{kind}</span>
    {context && <span class="term-context">{context} context</span>}
  </p>
  <h1>{label}</h1>
  <p class="term-iri"><code>{iri}</code></p>
  {comment && <p class="term-comment">{comment}</p>}
</header>

<style>
  .term-nav {
    font: 500 var(--text-sm) / 1.4 var(--font-sans);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .term-nav .sep { color: var(--color-border-strong); }
  .term-header { margin: 0 0 var(--space-6); }
  .term-kind {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin: 0 0 var(--space-2);
  }
  .term-context {
    font: 500 var(--text-xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .term-iri code {
    font: 400 var(--text-sm) / 1.4 var(--font-mono);
    color: var(--color-text-muted);
    word-break: break-all;
  }
  .term-comment {
    font: 400 var(--text-base) / var(--leading-relaxed) var(--font-sans);
    color: var(--color-text);
    margin: var(--space-3) 0 0;
  }
</style>
