---
/**
 * ADR-0044 — shared header for a canonical ontology term page (/pdtf/{id}).
 * Back-nav into the /ontology section, a kind + bounded-context badge, the
 * label, the dereferenceable IRI (selectable), and the term's meaning.
 *
 * Meaning cascade (ADR-0049 decision-4 / ODR-0042): `definition`
 * (skos:definition) is the PRIMARY meaning, rendered prominently; `comment`
 * (rdfs:comment) is the secondary short hint. When only `comment` is given it
 * stands alone as the lead text (the Concept/Scheme pages pass their definition
 * via `comment`, which keeps that behaviour). A `comment` identical to the
 * `definition` is suppressed so the same sentence is never shown twice.
 */
import { contextUrl, NS } from '@/lib/ontology-model';
interface Props {
  kind: string;
  label: string;
  localName: string;
  iri: string;
  definition?: string;
  comment?: string;
  context?: string | null;
  indexUrl: string;
  indexLabel: string;
}
const { kind, label, localName, iri, definition, comment, context, indexUrl, indexLabel } = Astro.props;
const ctxHref = contextUrl(context);
const ttlHref = iri.startsWith(NS) ? `/pdtf/${iri.slice(NS.length)}.ttl` : null;
const def = definition?.trim() || '';
// Secondary hint: the rdfs:comment, unless it duplicates the definition.
const hint = comment?.trim() && comment.trim() !== def ? comment.trim() : '';
---
<nav class="term-nav" aria-label="Breadcrumb">
  <a href="/ontology">Ontology</a>
  <span class="sep" aria-hidden="true">›</span>
  <a href={indexUrl}>{indexLabel}</a>
  <span class="sep" aria-hidden="true">›</span>
  <span aria-current="page">{label}</span>
</nav>

<header class="term-header">
  <p class="term-kind">
    <span class="pill pill--brand">{kind}</span>
    {context && (ctxHref
      ? <a class="term-context" href={ctxHref}>{context} context</a>
      : <span class="term-context">{context}</span>)}
  </p>
  <h1>{label}</h1>
  <p class="term-iri"><code>{iri}</code>{ttlHref && <a class="term-ttl" href={ttlHref}>Turtle ↓</a>}</p>
  {def && <p class="term-definition">{def}</p>}
  {hint && <p class="term-comment">{hint}</p>}
</header>

<style>
  .term-nav {
    font: 500 var(--text-sm) / 1.4 var(--font-sans);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .term-nav .sep { color: var(--color-border-strong); }
  .term-header { margin: 0 0 var(--space-6); }
  .term-kind {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin: 0 0 var(--space-2);
  }
  .term-context {
    font: 500 var(--text-xs) / 1 var(--font-sans);
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .term-iri code {
    font: 400 var(--text-sm) / 1.4 var(--font-mono);
    color: var(--color-text-muted);
    word-break: break-all;
  }
  .term-ttl {
    margin-left: var(--space-3);
    font: 500 var(--text-xs) / 1 var(--font-sans);
    white-space: nowrap;
  }
  .term-definition {
    font: 400 var(--text-base) / var(--leading-relaxed) var(--font-sans);
    color: var(--color-text);
    margin: var(--space-3) 0 0;
  }
  .term-comment {
    font: 400 var(--text-sm) / var(--leading-relaxed) var(--font-sans);
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }
</style>
