---
/**
 * Page comments — Artalk backend on Railway with Auth0 OIDC SSO.
 *
 * - Anonymous comments are disabled on the backend (`auth.anonymous=false`),
 *   so the widget shows its own "Login" button. Login routes through
 *   /api/v2/auth/auth0 → Auth0 Universal Login → callback → Artalk session.
 * - Auth0's Post-Login allowlist Action restricts SSO to authorised emails,
 *   so the gate runs server-side rather than in OPDA's client code.
 * - Tracks <html data-theme> and pushes setDarkMode() on every change.
 * - Re-runs on `astro:page-load` so view transitions reset cleanly.
 *
 * Backend: `opda-artalk` Railway project.
 * Auth0 OAuth app: jkTCdjC29lKz0oZOsTZ1ZcSqCo1JnTA3 (Regular Web App).
 */
---
<section class="comments-section" aria-label="Comments">
  <h2 class="comments-section__heading">Comments</h2>
  <div id="opda-comments" class="comments-section__widget">
    <div class="comments-section__loading" role="status">Loading comments…</div>
  </div>
</section>

<script>
  import Artalk from 'artalk';
  import 'artalk/Artalk.css';

  const ARTALK_SERVER = 'https://artalk-production-4ade.up.railway.app';
  const ARTALK_SITE = 'OPDA Knowledge Base';

  let artalkInstance: ReturnType<typeof Artalk.init> | null = null;
  let themeObserver: MutationObserver | null = null;

  function isDark(): boolean {
    return document.documentElement.getAttribute('data-theme') === 'dark';
  }

  function tearDown() {
    if (themeObserver) {
      themeObserver.disconnect();
      themeObserver = null;
    }
    if (artalkInstance) {
      try { artalkInstance.destroy(); } catch { /* ignore */ }
      artalkInstance = null;
    }
  }

  function init() {
    const container = document.getElementById('opda-comments');
    if (!container) return;

    tearDown();
    container.innerHTML = '';

    artalkInstance = Artalk.init({
      el: '#opda-comments',
      server: ARTALK_SERVER,
      site: ARTALK_SITE,
      pageKey: window.location.pathname,
      pageTitle: document.title,
      darkMode: isDark(),
      placeholder: 'Share your thoughts…',
      noComment: 'No comments yet — be the first.',
      sendBtn: 'Post comment',
    });

    themeObserver = new MutationObserver(() => {
      if (!artalkInstance) return;
      try { artalkInstance.setDarkMode(isDark()); } catch { /* ignore */ }
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', tearDown);
</script>
