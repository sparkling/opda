---
/**
 * Page comments — Artalk backend on AWS Fargate, same-origin via CloudFront,
 * SSO via the edge gate's session (ADR-0038).
 *
 * Architecture:
 * - The edge gate (Lambda@Edge) owns the Auth0 session. On init we ask it
 *   for the session surface at /_auth/me; if authenticated it returns the
 *   Auth0 access token, which we POST to /api/v2/sso/exchange (the fork's
 *   SSO bridge, reached same-origin — CloudFront routes /api/v2/* to the
 *   Artalk task). The returned Artalk JWT goes to localStorage["ArtalkUser"]
 *   and the widget mounts fully logged-in — no popup, no password prompt.
 * - On gated pages /_auth/me always succeeds (the gate already authenticated
 *   the page load); a 401 just shows the signed-out prompt (dev servers).
 * - Theme follows OPDA's html[data-theme] via MutationObserver.
 * - Re-runs on `astro:page-load` so view transitions reset cleanly.
 */
---
<section class="comments-section" aria-label="Comments">
  <h2 class="comments-section__heading">Comments</h2>
  <div id="opda-comments" class="comments-section__widget">
    <div class="comments-section__loading" role="status">Loading comments…</div>
  </div>
</section>

<script>
  import Artalk from 'artalk';
  import 'artalk/Artalk.css';

  // Same origin: CloudFront routes /api/v2/* to the Artalk Fargate task
  // (no CORS, and the edge gate covers the API too).
  const ARTALK_SERVER = window.location.origin;
  const ARTALK_SITE = 'OPDA';
  const SSO_ENDPOINT = '/api/v2/sso/exchange';
  const LOCAL_USER_KEY = 'ArtalkUser';

  let artalkInstance: ReturnType<typeof Artalk.init> | null = null;
  let themeObserver: MutationObserver | null = null;
  let initPromise: Promise<void> | null = null;
  let initedPageKey: string | null = null;

  function isDark(): boolean {
    return document.documentElement.getAttribute('data-theme') === 'dark';
  }

  function tearDown() {
    if (themeObserver) {
      themeObserver.disconnect();
      themeObserver = null;
    }
    if (artalkInstance) {
      try { artalkInstance.destroy(); } catch { /* ignore */ }
      artalkInstance = null;
    }
    initedPageKey = null;
  }

  function getStoredUser(): { token?: string; email?: string } {
    try {
      return JSON.parse(window.localStorage.getItem(LOCAL_USER_KEY) || '{}');
    } catch {
      return {};
    }
  }

  function writeStoredUser(user: Record<string, unknown>) {
    try {
      window.localStorage.setItem(LOCAL_USER_KEY, JSON.stringify(user));
    } catch { /* ignore quota / disabled */ }
  }

  // Decode the exp claim from a JWT without verifying — for client-side
  // "is this still valid?" check before reusing it.
  function jwtExp(token: string): number | null {
    try {
      const [, payload] = token.split('.');
      const padded = payload.replace(/-/g, '+').replace(/_/g, '/');
      const json = atob(padded + '==='.slice((padded.length + 3) % 4));
      const claims = JSON.parse(json);
      return typeof claims.exp === 'number' ? claims.exp : null;
    } catch {
      return null;
    }
  }

  async function exchangeForArtalkToken(auth0Token: string) {
    const r = await fetch(SSO_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: auth0Token }),
    });
    if (!r.ok) {
      const text = await r.text();
      throw new Error(`SSO exchange failed (${r.status}): ${text}`);
    }
    // Artalk returns { data: { token, user } }; older shapes also { token, user }.
    const body = (await r.json()) as
      | { token: string; user: Record<string, unknown> }
      | { data: { token: string; user: Record<string, unknown> } };
    if ('data' in body && body.data) return body.data;
    return body as { token: string; user: Record<string, unknown> };
  }

  async function ensureArtalkSession(): Promise<boolean> {
    // Already have a non-expired token? Use it.
    const existing = getStoredUser();
    if (existing.token) {
      const exp = jwtExp(existing.token);
      if (exp && exp > Math.floor(Date.now() / 1000) + 60) return true;
    }

    // Need a fresh token. The edge gate holds the Auth0 session — ask it
    // for the access token (same-origin; cookies ride automatically).
    let auth0Token: string;
    try {
      const r = await fetch('/_auth/me', { credentials: 'same-origin' });
      if (!r.ok) return false;
      const me = (await r.json()) as { token?: string | null };
      if (!me.token) return false;
      auth0Token = me.token;
    } catch (err) {
      console.warn('[OPDA] comments: gate session fetch failed', err);
      return false;
    }

    try {
      const { token, user } = await exchangeForArtalkToken(auth0Token);
      // Only treat the session as valid if we actually got a JWT. A response
      // without a token (e.g. a captcha challenge or an error shape) must NOT
      // be written as a logged-in user — that left Artalk in a broken
      // half-logged-in state. Fall back to the signed-out prompt instead.
      if (!token || typeof token !== 'string') {
        console.warn('[OPDA] comments: SSO exchange returned no token', user);
        return false;
      }
      writeStoredUser({ ...user, token });
      return true;
    } catch (err) {
      console.warn('[OPDA] comments: SSO bridge failed', err);
      return false;
    }
  }

  function init(): Promise<void> {
    // init() fires from BOTH our DOMContentLoaded/immediate path AND
    // astro:page-load, so it can be called twice for the same page load.
    // Coalesce by tracking the in-flight promise + the pageKey we've
    // already initialised for. A previous generation-counter guard wasn't
    // enough: Artalk's own init does multiple async steps (config fetch,
    // plugin load), and a second init() that arrived between those would
    // tearDown the in-flight instance and leave a half-rendered widget.
    const pageKey = window.location.pathname;
    if (initedPageKey === pageKey && artalkInstance) return Promise.resolve();
    if (initPromise) return initPromise;
    initPromise = doInit(pageKey).finally(() => { initPromise = null; });
    return initPromise;
  }

  async function doInit(pageKey: string) {
    const container = document.getElementById('opda-comments');
    if (!container) return;

    tearDown();

    const signedIn = await ensureArtalkSession();
    // If the user navigated away while we were exchanging tokens, drop out
    // — a fresh init() will run for the new page via astro:page-load.
    if (window.location.pathname !== pageKey) return;

    container.innerHTML = '';

    // Gated: Artalk renders only for signed-in users. Sign-in is restricted to
    // allowlisted member e-mails by the edge gate (ADR-0038), so a valid
    // session implies an authorised user. Everyone else gets a prompt.
    if (!signedIn) {
      container.innerHTML =
        '<p class="comments-section__gated" role="status">Sign in with an authorised OPDA account to view and post comments.</p>';
      return;
    }

    artalkInstance = Artalk.init({
      el: '#opda-comments',
      server: ARTALK_SERVER,
      site: ARTALK_SITE,
      pageKey,
      pageTitle: document.title,
      darkMode: isDark(),
      placeholder: 'Share your thoughts…',
      noComment: 'No comments yet — be the first.',
      sendBtn: 'Post comment',
      // The backend's frontend.conf has empty labels and lists an OAuth
      // login plugin we don't want — comments are gated to signed-in
      // Auth0 users via our own SSO bridge, so the plugin's popup-login
      // UI is dead weight and was leaving the widget half-rendered.
      // useBackendConf:false keeps our client-side labels and skips
      // the plugin load.
      useBackendConf: false,
    });
    initedPageKey = pageKey;

    themeObserver = new MutationObserver(() => {
      if (!artalkInstance) return;
      try { artalkInstance.setDarkMode(isDark()); } catch { /* ignore */ }
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', tearDown);
</script>
