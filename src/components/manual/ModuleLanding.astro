---
/**
 * Realises ADR-0017 (manual component library) per ADR-0015.
 * Module overview header for module-readme entries.
 * Slot receives the rendered markdown body.
 */
interface Props {
  /** Tier key. */
  tier: string;
  /** Module slug, e.g. "property". */
  module: string | null;
  /** Display title. */
  title: string;
}

const { tier, module: mod, title } = Astro.props;

const tierLabel: Record<string, string> = {
  concept: 'Concept tier',
  logical: 'Logical tier',
  'physical-database': 'Physical — deployment',
  'physical-ontology': 'Physical — ontology',
  'physical-relational': 'Physical — relational',
};
---

<div class="module-landing">
  <header class="module-landing__header">
    <div class="module-landing__meta">
      <span class={`module-landing__tier-badge tier-badge--${tier}`}>
        {tierLabel[tier] ?? tier}
      </span>
      {mod && <span class="module-landing__module-label">Module: {mod}</span>}
    </div>
    <h1 class="module-landing__title">{title}</h1>
  </header>
  <div class="module-landing__body">
    <slot />
  </div>
</div>

<style>
  .module-landing__header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .module-landing__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .module-landing__tier-badge {
    display: inline-block;
    padding: 0.1em var(--space-2);
    border-radius: var(--radius-sm);
    font: 500 var(--text-xs) / 1.4 var(--font-sans);
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
  }

  .tier-badge--concept {
    background: var(--accent-tier-concept-bg);
    color: var(--accent-tier-concept-text);
  }

  .tier-badge--logical {
    background: var(--accent-tier-logical-bg);
    color: var(--accent-tier-logical-text);
  }

  .tier-badge--physical-database {
    background: var(--accent-tier-physical-database-bg);
    color: var(--accent-tier-physical-database-text);
  }

  .tier-badge--physical-ontology {
    background: var(--accent-tier-physical-ontology-bg);
    color: var(--accent-tier-physical-ontology-text);
  }

  .tier-badge--physical-relational {
    background: var(--accent-tier-physical-relational-bg);
    color: var(--accent-tier-physical-relational-text);
  }

  .module-landing__module-label {
    font: 400 var(--text-sm) / 1 var(--font-sans);
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  .module-landing__title {
    margin: 0;
    font: 700 var(--text-3xl) / var(--leading-tight) var(--font-serif);
    letter-spacing: var(--tracking-display);
    color: var(--color-text-strong);
  }
</style>
