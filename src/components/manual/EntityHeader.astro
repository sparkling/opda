---
/**
 * Realises ADR-0017 (manual component library) per ADR-0015.
 * UFO meta-category badge + module breadcrumb + optional cross-tier link strip.
 *
 * `entityUri` is populated by ADR-0018 (Phase 3, rehypeFrontmatterUriExtraction).
 * When undefined the URI row is silently suppressed.
 */
interface Props {
  /** OPDA entity URI, e.g. "https://opda.org.uk/pdtf/Property". Supplied by Phase 3. */
  entityUri?: string;
  /** Tier identifier for badge colouring. */
  tier: string;
  /** Module name, e.g. "property". */
  module: string | null;
  /** Human-readable entity title. */
  title: string;
}

const { entityUri, tier, module: mod, title } = Astro.props;

const tierLabel: Record<string, string> = {
  concept: 'Concept tier',
  logical: 'Logical tier',
  'physical-database': 'Physical — deployment',
  'physical-ontology': 'Physical — ontology',
};
---

<div class="entity-header">
  <div class="entity-header__meta">
    <span class={`entity-header__tier-badge tier-badge--${tier}`}>{tierLabel[tier] ?? tier}</span>
    {mod && <span class="entity-header__module">{mod}</span>}
  </div>
  <h1 class="entity-header__title">{title}</h1>
  {entityUri && (
    <div class="entity-header__uri">
      <code class="entity-header__uri-code">{entityUri}</code>
    </div>
  )}
</div>

<style>
  .entity-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .entity-header__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .entity-header__tier-badge {
    display: inline-block;
    padding: 0.1em var(--space-2);
    border-radius: var(--radius-sm);
    font: 500 var(--text-xs) / 1.4 var(--font-sans);
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
    background: var(--accent-tier-concept-bg);
    color: var(--accent-tier-concept-text);
  }

  .tier-badge--concept {
    background: var(--accent-tier-concept-bg);
    color: var(--accent-tier-concept-text);
  }

  .tier-badge--logical {
    background: var(--accent-tier-logical-bg);
    color: var(--accent-tier-logical-text);
  }

  .tier-badge--physical-database {
    background: var(--accent-tier-physical-database-bg);
    color: var(--accent-tier-physical-database-text);
  }

  .tier-badge--physical-ontology {
    background: var(--accent-tier-physical-ontology-bg);
    color: var(--accent-tier-physical-ontology-text);
  }

  .entity-header__module {
    font: 400 var(--text-sm) / 1 var(--font-sans);
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  .entity-header__title {
    margin: 0 0 var(--space-2);
    font: 700 var(--text-3xl) / var(--leading-tight) var(--font-serif);
    letter-spacing: var(--tracking-display);
    color: var(--color-text-strong);
  }

  .entity-header__uri {
    margin-top: var(--space-2);
  }

  .entity-header__uri-code {
    font: 400 var(--text-sm) / 1 var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-surface-tint);
    padding: 0.15em var(--space-2);
    border-radius: var(--radius-sm);
  }
</style>
