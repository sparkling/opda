---
/**
 * Realises ADR-0017 (manual component library) per ADR-0015.
 * Footer strip linking the 4 tier versions of the same entity.
 *
 * `entityUri` is populated by ADR-0018 (Phase 3).
 * When undefined (Phase 2 runtime) this component renders nothing.
 * `entityName` is a human-readable fallback when entityUri is unavailable.
 */
interface Props {
  /** OPDA entity URI — undefined until Phase 3 lands. */
  entityUri?: string;
  /** Current tier — to mark the active link. */
  tier: string;
  /** Module slug, e.g. "property". */
  module: string | null;
  /** Human-readable entity name for link text, e.g. "Property". */
  entityName?: string;
}

const { entityUri, tier, module: mod, entityName } = Astro.props;

// Without a URI or module, there is nothing useful to link — render nothing.
if (!entityUri && !mod) return;

// The physical-ontology TBox documentation pages (`<module>/classes`,
// `/shapes`, `/annotations`, `foundation/meta-shapes`) carry synthetic entity
// URIs (opda:Classes / opda:Shapes / opda:Annotations / opda:MetaShapes) and
// fall through deriveKind() to kind="entity", so they reach this component —
// but they are aggregate docs, not entities, and have NO per-entity page in any
// other tier. Synthesising cross-tier links for them only produces 404s, so
// render nothing (their bodies already carry hand-authored tier links).
const AGGREGATE_DOCS = new Set(['Classes', 'Shapes', 'Annotations', 'MetaShapes']);
const aggLocalName = entityUri ? entityUri.split(/[/#:]/).pop() : null;
if (aggLocalName && AGGREGATE_DOCS.has(aggLocalName)) return;

const tiers = [
  { key: 'concept', label: 'Concept', path: '/model/concept' },
  { key: 'logical', label: 'Logical', path: '/model/logical' },
  { key: 'physical-database', label: 'Physical — deployment', path: '/model/physical-database' },
  { key: 'physical-ontology', label: 'Physical — ontology', path: '/model/physical-ontology' },
] as const;

// Best-effort identity keys. `localName` is the camel/PascalCase URI local
// name (e.g. "NameChangeEvent"); `name` is the human title (e.g. "Name Change
// Event"). Either yields the same kebab page slug.
const localName: string | null = entityUri ? (entityUri.split(/[/#:]/).pop() ?? null) : null;
const name = entityName ?? localName;

// Kebab slug used by the concept/logical entity routes — slugify the title the
// same way the manual content collection derives a page slug from its filename
// (lowercase, non-alphanumerics → "-"). "Name Change Event" → "name-change-event".
const slug = name
  ? name.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
  : null;

// Per-tier URL builder mirroring src/lib/cross-tier.ts's scheme. The concept and
// logical tiers expose one page per entity (kebab slug). The physical tiers do
// NOT — they expose one page per module, with the entity addressed by fragment.
// Building the right shape per tier is what keeps these links resolving when the
// API-less build falls back to this component (a flat /<tier>/<module>/<name>
// path 404s on the physical tiers and breaks on un-slugified names).
function tierHref(key: string, path: string): string {
  if (!mod) return path;
  switch (key) {
    case 'concept':
    case 'logical':
      return slug ? `${path}/${mod}/${slug}` : path;
    case 'physical-database':
      // The per-module deployment page has no per-entity anchors — link bare.
      return `${path}/modules/${mod}`;
    case 'physical-ontology':
      // The classes page emits one anchor per term as id="opda<lowercased-localName>"
      // (e.g. opda:NameChangeEvent → "opdanamechangeevent"). Match it so the link
      // lands on the term; fall back to the bare page when localName is unknown.
      return localName
        ? `${path}/${mod}/classes#opda${localName.toLowerCase()}`
        : `${path}/${mod}/classes`;
    default:
      return path;
  }
}
---

{(entityUri || mod) && (
  <aside class="cross-tier-links">
    <p class="cross-tier-links__label">This entity across tiers</p>
    <ul class="cross-tier-links__list">
      {tiers.map((t) => {
        const isCurrent = t.key === tier;
        const href = tierHref(t.key, t.path);
        return (
          <li>
            {isCurrent
              ? <span class="cross-tier-links__current" aria-current="page">{t.label}</span>
              : <a href={href} class="cross-tier-links__link">{t.label}</a>
            }
          </li>
        );
      })}
    </ul>
  </aside>
)}

<style>
  .cross-tier-links {
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .cross-tier-links__label {
    font: 600 var(--text-sm) / 1 var(--font-sans);
    letter-spacing: var(--tracking-meta);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .cross-tier-links__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cross-tier-links__link,
  .cross-tier-links__current {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-md);
    font: 500 var(--text-sm) / 1.4 var(--font-sans);
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease);
  }

  .cross-tier-links__link {
    background: var(--color-surface-tint);
    color: var(--color-link);
    border: 1px solid var(--color-border);
  }

  .cross-tier-links__link:hover {
    background: var(--color-surface-inset);
    text-decoration: none;
  }

  .cross-tier-links__current {
    background: var(--color-surface-inset);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-strong);
    cursor: default;
  }
</style>
