---
/**
 * Page footer — prev / next links derived from site.ts SECTIONS order.
 * No props needed; reads from Astro.url.pathname.
 *
 * Renders nothing for pages not in a section (top-level reference pages,
 * 404s) or section roots that have no prev/next.
 */
import { getPrevNext } from '@/lib/site';

const { prev, next } = getPrevNext(Astro.url.pathname);
---
{(prev || next) && (
  <div class="page-footer">
    {prev && <a href={prev.url}>← {prev.title}</a>}
    {next && <a href={next.url}>{next.title} →</a>}
  </div>
)}
