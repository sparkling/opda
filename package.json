{
  "name": "opda-kb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OPDA Knowledge Base — Astro shell over a static HTML/CSS/JS docs site for the Property Data Trust Framework.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:bare": "astro dev",
    "start": "node scripts/dev.mjs",
    "build": "pnpm run css && astro build",
    "build:data": "node scripts/build-with-data.mjs",
    "serve:data": "node scripts/build-with-data.mjs --serve",
    "api": "FUSEKI_ENDPOINT=http://localhost:3031/opda/sparql node --watch src/api/server.js",
    "jena:load": "node scripts/fuseki-load.mjs --clear",
    "ontology:model": "node scripts/ontology-model.mjs",
    "ontology:graph": "node scripts/ontology-graph.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "css": "tailwindcss -i src/styles/global.css -o public/ui/tailwind.built.css --minify",
    "css:watch": "tailwindcss -i src/styles/global.css -o public/ui/tailwind.built.css --watch",
    "tailwindplus:download": "bash scripts/tailwindplus-download.sh",
    "test": "node --test tests/lib/remark/*.test.mjs",
    "test:smoke": "npx playwright test scripts/smoke-test.mjs",
    "clean": "rm -rf dist .astro",
    "resources:manifest": "node scripts/resources-manifest.mjs",
    "publish:resources": "bash scripts/publish-resources.sh",
    "deploy": "bash deploy.sh",
    "deploy:ci": "git push origin main"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "artalk": "^2.9.1",
    "astro": "^6.3.3",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "jiti": "^2.7.0",
    "marked": "^18.0.4",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
