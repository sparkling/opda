# Quarterly Accreditation Directory publish — EXAMPLE workflow
#
# This file is intentionally named `.yml.example` so GitHub Actions does NOT run it.
# Rename to `accreditation-quarterly.yml` ONLY when:
#   1. `scripts/build-accreditation-directory.mjs` is no longer a throwing stub
#   2. `source/04-governance-bodies/accreditation/credentials/` contains real VCs
#   3. The Technical WG signs off (per ADR-0005 register item F4)
#
# Source: ADR-0005 register item F4 (Quarterly publishing automation).
# Owner: Technical WG.
# Package manager: pnpm (confirmed from package.json).
# Node version: 20 (LTS that runs Astro 6.x cleanly; confirm with WG at rename time).

name: Quarterly Accreditation Publish

on:
  # Quarterly-ish: 09:00 UTC on the 1st of every 3rd month.
  # The exact cron is a WG decision — this is a starting point, not a commitment.
  schedule:
    - cron: '0 9 1 */3 *'
  # Manual trigger for ad-hoc runs (e.g. on-demand re-publish per ADR-0004 §4).
  workflow_dispatch:
    inputs:
      quarter:
        description: 'Quarter tag (e.g. 2026-Q2). Leave blank to auto-derive.'
        required: false
        type: string

jobs:
  publish:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 9

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: 'pnpm'

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Build Accreditation Directory data
        env:
          QUARTER: ${{ github.event.inputs.quarter }}
        run: |
          QUARTER_TAG="${QUARTER:-$(date -u +%Y-Q$(( ($(date -u +%-m) - 1) / 3 + 1 )))}"
          echo "Building for quarter: $QUARTER_TAG"
          node scripts/build-accreditation-directory.mjs --quarter "$QUARTER_TAG"
          echo "QUARTER_TAG=$QUARTER_TAG" >> "$GITHUB_ENV"

      - name: Open PR with refreshed data
        uses: peter-evans/create-pull-request@v6
        with:
          commit-message: "Accreditation Directory — quarterly publish for ${{ env.QUARTER_TAG }}"
          title: "Accreditation Directory — quarterly publish for ${{ env.QUARTER_TAG }}"
          branch: "accreditation/${{ env.QUARTER_TAG }}"
          body: |
            Automated quarterly refresh of `src/data/accreditation/current.json`
            for quarter **${{ env.QUARTER_TAG }}**.

            Built from VCs under `source/04-governance-bodies/accreditation/credentials/`.

            Reviewers: see ADR-0005 register item F4 for the WG decisions still to be made.
          add-paths: |
            src/data/accreditation/current.json

# WG decisions still required before this workflow is activated:
#   - Cron schedule: exact day and time (placeholder above is "1st of every 3rd month, 09:00 UTC"). Quarterly cadence is the ADR-0004 §4 default but the day-of-month and timezone are unspecified.
#   - PR vs direct-commit: this example opens a PR. Direct-commit-to-main might be acceptable for trusted automation; WG decides.
#   - Required reviewers on the PR: C&R WG chair? Technical WG chair? Either?
#   - Failure handling: Slack notification, GitHub issue, both, or rely on the failed workflow surfacing in the Actions tab?
#   - Secrets: none expected — the build script reads VCs from the local repo and validates against the Trust Registry, which is a public lookup. Confirm at activation time.
