# Node / Astro
node_modules/
package-lock.json
dist/
.astro/
.DS_Store
*.log

# Local research archive — too large to push (≈ 500 MB, hosts cloned repos)
# The deployed site only needs dist/. See README.
# Leading slash anchors to repo root so public/data/resources/source/ is still tracked.
/source/*
# Schema-pipeline inputs and design docs we author + ship
!/source/_content/
!/source/_examples/
!/source/_working/
/source/_working/*
!/source/_working/schema-section-ia.md
!/source/_working/schema-content-generation-spec.md
!/source/00-deliverables/
/source/00-deliverables/*
!/source/00-deliverables/semantic-models/
/source/00-deliverables/semantic-models/*
!/source/00-deliverables/semantic-models/provenance-map.yaml
!/source/00-deliverables/semantic-models/theme-map.yaml
# OPDA ontology — parent-repo path per ODR-0004 §8a (peer to nested schemas/ sub-repo).
# Track the ontology authoring tree (exemplars, future foundation.ttl, etc.).
!/source/03-standards/
/source/03-standards/*
!/source/03-standards/ontology/
!/source/03-standards/ontology/**

# Build intermediates (regenerated; not tracked)
/_build/
/public/ui/tailwind.built.css
/src/generated/
/public/data/diagram-links.json

# TailwindPlus downloader workspace (credentials, session, component dump)
# — see tailwindplus plugin in legacybridge-tech/claude-plugins
/.tailwindplus/
.tailwindplus-downloader-credentials.json
.tailwindplus-downloader-session.json
tailwindplus-components-*.json

# Local environment
.env
.env.local

# IDE
.vscode/
.idea/

# OS junk
Thumbs.db

# Python bytecode
__pycache__/
*.pyc

# Generated HTML/PDF exports from docs/manual/ (via sc:markdown-export skill).
# Source markdown is canonical; export/ folders are rebuilt on demand.
# Covers both default per-directory layout (**/export/) and consolidated-tree
# layout (--out=docs/manual/_export → docs/manual/_export/).
docs/manual/**/export/
docs/manual/_export/

# Agent tooling artefacts (ruflo + claude-flow + swarm + ruvector)
# .claude/ is tracked — curated config + ruflo-init resources (agents, commands,
# helpers, scripts). Agent memory (memory.db*) and machine-local overrides are ignored.
.claude/settings.local.json
.claude/memory.db*
.claude/*.lock
.claude/settings.json.before-*
.claude-flow/
.swarm/
ruvector.db
