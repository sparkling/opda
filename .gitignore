# Node / Astro
node_modules/
package-lock.json
dist/
.astro/
.DS_Store
*.log

# Local research archive — too large to push (≈ 500 MB, hosts cloned repos)
# The deployed site only needs dist/. See README.
# Leading slash anchors to repo root so public/data/resources/source/ is still tracked.
/source/*
# Schema-pipeline inputs and design docs we author + ship
!/source/_content/
!/source/_examples/
!/source/_working/
/source/_working/*
!/source/_working/schema-section-ia.md
!/source/_working/schema-content-generation-spec.md
!/source/00-deliverables/
/source/00-deliverables/*
!/source/00-deliverables/semantic-models/
/source/00-deliverables/semantic-models/*
!/source/00-deliverables/semantic-models/provenance-map.yaml
!/source/00-deliverables/semantic-models/theme-map.yaml
# OPDA ontology — parent-repo path per ODR-0004 §8a (peer to nested schemas/ sub-repo).
# Track the ontology authoring tree (exemplars, future foundation.ttl, etc.).
!/source/03-standards/
/source/03-standards/*
!/source/03-standards/ontology/
!/source/03-standards/ontology/**
# RML provenance-mapping standard (ODR-0035/ADR-0057) — hand-authored, peer to ontology/.
# (source/03-standards/rml/.gitignore handles build/__pycache__/.metaharness locally.)
!/source/03-standards/rml/
!/source/03-standards/rml/**

# Build intermediates (regenerated; not tracked)
/_build/
/public/ui/tailwind.built.css
/src/generated/
/public/data/diagram-links.json
# Council-session corpus mirror (generated by generate-council.mjs from
# docs/ontology/odr/council/; ships to dist/ but never committed).
/public/council/

# Local Jena 6.1.0 runtime (ADR-0036/0037): self-provisioned Fuseki + SHACL CLI
# dists + TDB2 data. Rebuilt on demand (build-with-data.mjs / opda_gen.jena_shacl);
# never tracked or shipped.
/.fuseki/
/.jena/
/run/

# RMLMapper (ADR-0057 Amendments — the RML mapping's execution engine,
# replacing morph-kgc): self-provisioned official release JAR, never tracked
# or shipped.
/.rmlmapper/

# RMLMapper FnO function build artifacts (compiled from
# source/03-standards/rml/mapping/functions/OpdaFunctions.java by
# harness/run_mapping.py) — never tracked, rebuilt on demand.
source/03-standards/rml/mapping/functions/*.class
source/03-standards/rml/mapping/functions/*.jar

# Local ruflo/AgentDB runtime state (RVF container + lock) — machine-local, never tracked.
/agentdb.rvf
/agentdb.rvf.lock

# TailwindPlus downloader workspace (credentials, session, component dump)
# — see tailwindplus plugin in legacybridge-tech/claude-plugins
/.tailwindplus/
.tailwindplus-downloader-credentials.json
.tailwindplus-downloader-session.json
tailwindplus-components-*.json

# Local environment
.env
.env.local

# IDE
.vscode/
.idea/

# OS junk
Thumbs.db

# Python bytecode
__pycache__/
*.pyc

# Generated HTML/PDF exports from docs/manual/ (via sc:markdown-export skill).
# Source markdown is canonical; export/ folders are rebuilt on demand.
# Covers both default per-directory layout (**/export/) and consolidated-tree
# layout (--out=docs/manual/_export → docs/manual/_export/).
docs/manual/**/export/
docs/manual/_export/

# Ontology bake-off renders (ADR-0041 — regenerable tool output; heavy, esp. Ontospy ~87MB).
# The composition pages (src/pages/ontology/), the M6 COMPARISON.md, and the lightweight
# tool READMEs / skosmos schemes list ARE tracked; the generated HTML render trees + the
# copied TTL artefacts are regenerated on demand and not committed.
public/ontology/tools/ontospy/
public/ontology/tools/widoco/
public/ontology/tools/pylode/
public/ontology/tools/shaclplay/
public/ontology/artefacts/

# Agent tooling artefacts (ruflo + claude-flow + swarm + ruvector)
# .claude/ is tracked — curated config + ruflo-init resources (agents, commands,
# helpers, scripts). Agent memory (memory.db*) and machine-local overrides are ignored.
.claude/settings.local.json
.claude/memory.db*
.claude/*.lock
.claude/settings.json.before-*
.claude-flow/
.swarm/
ruvector.db

# Local scratch / probe outputs (bake-off renders, runtime probes, presentation
# runs) — regenerable, ~275MB; never tracked.
/outputs/
