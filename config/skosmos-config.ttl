# Skosmos configuration for the OPDA PDTF vocabularies (ADR-0041 §Hosting B2 —
# localhost-link). One umbrella vocabulary over the whole /opda dataset; the
# dataset is union-default-graph (ADR-0035), so omitting skosmos:sparqlGraph
# surfaces all 48 concept schemes / 314 concepts (47 in graph/vocabularies + the
# BoundedContextScheme in graph/contexts).
#
# Schema targets Skosmos 3.x (quay.io/natlibfi/skosmos — the relocated official
# image; Docker Hub natlibfi/skosmos is retired). Two things differ from the old
# 2.x recipe and MUST stay: skosmos:languages is a list of
# [ rdfs:label ; rdf:value ] resources (plain "en" literals fatal-error in
# GlobalConfig::getLanguages), and the per-vocabulary endpoint is
# void:sparqlEndpoint. Mirror config.ttl.dist inside the image when in doubt.
#
# Run:  make serve-data   (Fuseki on :3031/opda)  then  make skosmos
# Browse: http://localhost:9090/
@prefix skosmos: <http://purl.org/net/skosmos#> .
@prefix void:    <http://rdfs.org/ns/void#> .
@prefix dc:      <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix :        <#> .

# ── Global configuration ────────────────────────────────────────────────────
:config a skosmos:Configuration ;
    skosmos:sparqlEndpoint <http://host.docker.internal:3031/opda/sparql> ;
    skosmos:sparqlDialect "Generic" ;
    skosmos:sparqlTimeout 20 ;
    skosmos:httpTimeout 5 ;
    skosmos:serviceName "OPDA PDTF — SKOS browser" ;
    skosmos:languages (
        [ rdfs:label "en" ; rdf:value "en-GB" ]
    ) ;
    skosmos:searchResultsSize 20 ;
    skosmos:transitiveLimit 1000 ;
    skosmos:logCaughtExceptions false ;
    skosmos:logBrowserConsole true ;
    skosmos:templateCache "/tmp/skosmos-template-cache" ;
    skosmos:feedbackAddress "" ;
    skosmos:globalPlugins () .

# ── Vocabulary: the whole OPDA scheme space ─────────────────────────────────
:opda a skosmos:Vocabulary, void:Dataset ;
    dc:title "OPDA PDTF Vocabularies"@en ;
    skosmos:shortName "OPDA" ;
    dc:subject :cat_opda ;
    void:uriSpace "https://opda.org.uk/pdtf/" ;
    skosmos:language "en" ;
    skosmos:defaultLanguage "en" ;
    skosmos:showTopConcepts "true" ;
    skosmos:groupClass skos:Collection ;
    void:sparqlEndpoint <http://host.docker.internal:3031/opda/sparql> .

# ── Front-page category (Skosmos groups vocabularies under dc:subject) ───────
:categories a skos:ConceptScheme ;
    skos:prefLabel "OPDA Vocabulary Categories"@en .

:cat_opda a skos:Concept ;
    skos:topConceptOf :categories ;
    skos:inScheme :categories ;
    skos:prefLabel "OPDA PDTF"@en .
