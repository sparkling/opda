{#- aggregate-page.html.j2 ─────────────────────────────────────────────
    Template for the aggregate Schema pages (slots 35, 36, 37, 38a-38g/38b1-7/
    38e1-8b/38f1-5, 39a-e/39c1-10/39d1-13, 45, 46, 47, 48). (Page 34 uses
    overview-page.html.j2; page 49 uses crosscut-page.html.j2.)

    Emits a real .astro file — frontmatter + <Layout>, not a standalone HTML
    document. Layout.astro already provides design-system.css/tailwind.css,
    the Tailwind Plus Elements CDN script (<el-popover> etc.), and site-wide
    client.js — none of that is repeated here. The only page-specific script
    is schema-leaf-table.js's mountLeafTable(), wired the same
    data-astro-rerun + astro:page-load pattern used elsewhere on this site so
    it re-mounts correctly on client-side view-transition navigation, not
    just on a hard reload.

    Context the renderer supplies:
      page             — { slot, id, title, voice, generated_on }
      regions          — { intro, why_this_exists, pull_quote, worked_example,
                           gap_notes, er_diagram, mentioned_but_not_owned }
      sections         — list of { id, title, objects } (already grouped + sorted)
      ancestor_objects — list of object records that render on this page but
                         don't belong to any of its named sections (the page
                         root + any ancestor container that exists only so a
                         deeper section's own prefix has somewhere to live) —
                         rendered separately, never mislabeled under a real
                         section's heading (2026-07-06 design critique fix).
      stats            — { total, decl_pct, evid_pct, deriv_pct,
                           with_overlays, with_examples, envelope_total }
      show_envelopes   — bool, True only when page.slot == "48"

    All five regions are markdown-rendered to HTML by render_pages.py
    BEFORE reaching the template. The template treats them as `safe`.
    Sidecar markdown frontmatter must define every region — missing
    regions fail CI invariant 4 (sidecar region symmetry).
-#}
{%- import "_macros/stat-strip.html.j2" as ss -%}
{%- import "_macros/pull-quote.html.j2" as pq -%}
{%- import "_macros/object-table.html.j2" as ot -%}
{%- import "_macros/er-diagram.html.j2" as er -%}
---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title={{ ("Schema · " ~ page.title)|astro_str }}
  description={{ regions.intro_plain|default(page.title, true)|astro_str }}
>
      <div class="page-meta">
        <span class="pill pill--info">Schema</span>
        <span>Page {{ page.slot }}</span>
        <span>Generated {{ page.generated_on }}</span>
        {%- if page.dama_ka %}
        <span title="DAMA-DMBOK2 Knowledge Area — per ADR-0001">DAMA · {{ page.dama_ka|join(' · ')|e }}</span>
        {%- endif %}
      </div>

      <h1>{{ page.title }}</h1>

      {{ ss.stat_strip(stats.total, stats.decl_pct, stats.evid_pct, stats.deriv_pct,
                       stats.with_overlays, stats.with_examples, stats.envelope_total) }}

      {{ regions.intro|safe }}

      {%- if regions.mentioned_but_not_owned %}
      <p class="muted tiny"><strong>Mentioned but not owned here.</strong> {{ regions.mentioned_but_not_owned|safe }}</p>
      {%- endif %}

      {{ pq.pull_quote(regions.pull_quote) }}

      {%- if regions.why_this_exists %}
      <aside class="callout callout--note" role="note">
        <p class="callout__label">Why this aggregate exists</p>
        {{ regions.why_this_exists|safe }}
      </aside>
      {%- endif %}

      {%- if regions.er_diagram %}
      <h2 id="er">Entity relationships</h2>
      {{ er.er_diagram(regions.er_diagram, regions.er_caption|default('', true)) }}
      {%- endif %}

      {%- if regions.diagrams %}
      {%- set _diagram_titles = {'state': 'Lifecycle state machine', 'sequence': 'Sequence', 'flowchart': 'Process flow', 'gantt': 'Timeline', 'class': 'Class structure', 'er': 'Entity relationships'} %}
      {%- for d in regions.diagrams %}
      <h2 id="diagram-{{ loop.index }}">{{ _diagram_titles.get(d.type, 'Diagram') }}</h2>
      {{ er.er_diagram(d.source, d.caption) }}
      {%- endfor %}
      {%- endif %}

      {# Object-model header. Buttongroup follows the Tailwind Plus
         "isolate inline-flex + inset-ring + -ml-px" pattern (button-groups /
         Icon only variant), adapted for [search input + 2 icon buttons].
         The two icon buttons use the native popovertarget attribute to
         trigger <el-popover> panels from @tailwindplus/elements — the
         element handles open/close, focus, click-outside, and ESC.
         <el-popover-group> keeps focus movement between the two popovers
         from collapsing either. #}
      <div class="objects-header flex items-center gap-4 flex-wrap pt-6 mt-8 border-t border-[var(--color-border)]">
        <h2 id="objects" class="m-0! p-0! border-0! shrink-0">Object model</h2>

        <el-popover-group class="isolate flex flex-1 mx-auto max-w-3xl rounded-md shadow-xs" role="toolbar" aria-label="Sub-table filtering">
          <input type="search"
                 id="objects-search"
                 class="relative flex-1 min-w-0 rounded-l-md bg-[var(--button-bg)] px-3 py-2 text-sm text-[var(--color-text-strong)] placeholder:text-[var(--color-text-muted)] inset-ring-1 inset-ring-[var(--ring-subtle)] focus:z-10 focus:outline-2 focus:-outline-offset-2 focus:outline-[var(--focus-ring)]"
                 placeholder="Search title, field or path…"
                 aria-label="Search object tables">

          <button type="button"
                  id="filter-overlay-btn"
                  popovertarget="filter-overlay-panel"
                  class="relative -ml-px inline-flex items-center bg-[var(--button-bg)] px-2 py-2 text-[var(--color-text-muted)] inset-ring-1 inset-ring-[var(--ring-subtle)] hover:bg-[var(--button-bg-hover)] focus:z-10 focus:outline-2 focus:-outline-offset-2 focus:outline-[var(--focus-ring)] aria-expanded:z-10 aria-expanded:bg-[var(--button-bg-active)] cursor-pointer"
                  title="Filter by overlay">
            <span class="sr-only">Filter by overlay</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
            </svg>
            <span class="db-filter-badge ml-1" id="filter-overlay-count" hidden>0</span>
          </button>

          <el-popover id="filter-overlay-panel" anchor="bottom end" popover
                      class="mt-2 rounded-md bg-[var(--button-bg)] outline-1 outline-[var(--ring-subtle)] shadow-lg p-5 transition transition-discrete data-closed:opacity-0 data-closed:scale-95 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
            {# Populated by schema-leaf-table.js mountLeafTable() #}
          </el-popover>

          <button type="button"
                  id="objects-config-btn"
                  popovertarget="objects-config-panel"
                  class="relative -ml-px inline-flex items-center rounded-r-md bg-[var(--button-bg)] px-2 py-2 text-[var(--color-text-muted)] inset-ring-1 inset-ring-[var(--ring-subtle)] hover:bg-[var(--button-bg-hover)] focus:z-10 focus:outline-2 focus:-outline-offset-2 focus:outline-[var(--focus-ring)] aria-expanded:z-10 aria-expanded:bg-[var(--button-bg-active)] cursor-pointer"
                  title="Columns">
            <span class="sr-only">Columns</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </button>

          <el-popover id="objects-config-panel" anchor="bottom end" popover
                      class="mt-2 rounded-md bg-[var(--button-bg)] outline-1 outline-[var(--ring-subtle)] shadow-lg p-5 transition transition-discrete data-closed:opacity-0 data-closed:scale-95 data-enter:duration-100 data-enter:ease-out data-leave:duration-75 data-leave:ease-in">
            {# Populated by schema-leaf-table.js wireConfig() #}
          </el-popover>
        </el-popover-group>
      </div>

      {%- if ancestor_objects %}
      {# Ancestor containers (the page root, and any object that exists only
         so a deeper section's own prefix has somewhere to live) — deliberately
         NOT filed under any real section's heading, which used to misrepresent
         that section's own contents (e.g. "Address" opening with Transaction
         and Property Pack object blocks that have nothing to do with address). #}
      <p class="muted tiny object-ancestors-note">Parent containers — shown for reference; their own content lives in the sections below.</p>
      {%- for obj in ancestor_objects %}
      {{ ot.object_table(obj, show_envelopes) }}
      {%- endfor %}
      {%- endif %}

      {%- for section in sections %}
      {%- if section.objects %}
      <h3 id="{{ section.id }}">{{ section.title }}</h3>
      {%- for obj in section.objects %}
      {{ ot.object_table(obj, show_envelopes) }}
      {%- endfor %}
      {%- endif %}
      {%- endfor %}

      {%- if regions.worked_example %}
      <aside class="callout callout--note" role="note">
        <p class="callout__label">Worked example</p>
        {{ regions.worked_example|safe }}
      </aside>
      {%- endif %}

      {%- if regions.gap_notes and regions.gap_notes|trim %}
      <aside class="callout callout--warn" role="note">
        <p class="callout__label">Gap notes</p>
        {{ regions.gap_notes|safe }}
      </aside>
      {%- endif %}

<script slot="scripts" is:inline data-astro-rerun src="/ui/schema-leaf-table.js"></script>
<script slot="scripts" is:inline data-astro-rerun>
  if (window._opdaSchemaLeafMount) {
    document.removeEventListener('astro:page-load', window._opdaSchemaLeafMount);
  }
  window._opdaSchemaLeafMount = function () {
    if (typeof mountLeafTable === 'function') {
      mountLeafTable({
        page: '{{ page.slot }}',
        showEnvelopes: {{ 'true' if show_envelopes else 'false' }},
        filterButtonId: 'filter-overlay-btn',
        filterCountId: 'filter-overlay-count'
      });
    }
  };
  document.addEventListener('astro:page-load', window._opdaSchemaLeafMount);
</script>
</Layout>
