{# object-table.html.j2 ──────────────────────────────────────────────────
   Emits ONE table for a JSON-schema object. Rows are the object's direct
   scalar fields. Nested object children get their own table elsewhere on
   the page; here we just link to them via the ER diagram.

   Inputs:
     obj      — object record from _build/objects.json:
                  { path, id, display, field_name, is_array, fields[], children[] }
     show_envelopes  — bool. Suppress envelope rows on pages 35–42.

   Columns:
     Title · Type · Kind · Field · Required · Overlays · Affordance

   No pill formatting; descriptive Kind values; Field column shows the
   schema property name on this object (last segment of leaf path).
─────────────────────────────────────────────────────────────────────── #}
{% macro object_table(obj, show_envelopes=false) -%}
{%- set visible_fields = obj.fields | rejectattr('is_envelope') | list if not show_envelopes else obj.fields -%}
<div class="object-block" id="obj-{{ obj.id }}" data-display-id="{{ (obj.display_id or obj.id)|lower }}">
  <header class="object-block__head">
    <div class="object-block__title-row">
      <h4 id="{{ obj.id|lower }}" class="object-block__title" data-display-id="{{ (obj.display_id or obj.id)|lower }}">
        <span class="object-block__display">{{ obj.display }}</span>
        {%- if obj.is_array %}<span class="object-block__cardinality" title="array of objects">[]</span>{% endif %}
      </h4>
      <code class="object-block__path">{{ obj.path or 'transaction (root)' }}</code>
    </div>
    {%- if obj.children %}
    <ul class="object-block__children">
      {%- for c in obj.children %}
      <li>
        <a href="{{ c.href or ('#' ~ (c.id|lower)) }}" class="object-block__child-link">
          <svg class="object-block__child-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="13 17 18 12 13 7"/>
            <polyline points="6 17 11 12 6 7"/>
          </svg>
          <span>{{- c.display }}{% if c.is_array %}[]{% endif -%}</span>
        </a>
      </li>
      {%- endfor %}
    </ul>
    {%- endif %}
  </header>

  {%- if visible_fields %}
  <div class="db-table-wrap full-bleed"
       data-object-path="{{ obj.path }}"
       data-field-count="{{ visible_fields|length }}">
    <table class="db-table db-table--fixed">
      <thead>
        <tr>
          <th style="width: 14%;">Title</th>
          <th style="width: 22%;">Description</th>
          <th style="width: 6rem;">Type</th>
          <th style="width: 7rem;">Kind</th>
          <th style="width: 14%;">Field</th>
          <th class="align-center" style="width: 5rem;">Required</th>
          <th style="width: 18%;">Overlays</th>
          <th style="width: 6rem;">Affordance</th>
        </tr>
      </thead>
      <tbody>
      {%- for f in visible_fields %}
        <tr data-leaf-path="{{ f.path }}"
            data-overlays="{{ (f.overlays or [])|map(attribute='key')|join(',') }}"
            {%- if f.is_envelope %} data-envelope="1" style="opacity: 0.6;"{% endif %}>
          <td>{{ f.title|default('', true) }}</td>
          <td>{% if f.description %}{{ f.description }}{% else %}<span class="muted">—</span>{% endif %}</td>
          <td><code>{{ f.type }}</code></td>
          <td>
            {%- if f.is_envelope -%}envelope
            {%- elif f.kind == 'declaration' -%}Declaration
            {%- elif f.kind == 'evidence' -%}Evidence
            {%- elif f.kind == 'derivation' -%}Derivation
            {%- else -%}<span class="muted">—</span>
            {%- endif %}
          </td>
          <td>
            {%- if f.is_envelope -%}
            <span aria-label="VC envelope leaf" title="VC envelope leaf — see page 48">🔒</span>
            <code><em>{{ f.name }}</em></code>
            {%- else -%}
            <code>{{ f.name }}</code>{% if f.required %}<span aria-label="required" title="required" style="color: var(--terracotta-700); font-weight: 700; margin-left: 0.25em;">*</span>{% endif %}
            {%- endif %}
          </td>
          <td class="align-center">{% if f.required %}yes{% else %}<span class="muted">—</span>{% endif %}</td>
          <td class="overlay-cell">
            {%- set ovs = f.overlays or [] -%}
            {%- if ovs -%}
              {%- for o in ovs %}
              <div class="overlay-line">{{ o.name or o.label }} <span class="overlay-key">({{ o.label }})</span></div>
              {%- endfor -%}
            {%- else -%}
            <span class="muted">—</span>
            {%- endif %}
          </td>
          <td>
            {%- if f.has_example %}example{% else %}<span class="muted">—</span>{% endif %}
          </td>
        </tr>
      {%- endfor %}
      </tbody>
    </table>
  </div>
  {%- elif obj.children %}
  <p class="muted tiny">No scalar fields on this object — pure container.</p>
  {%- endif %}
</div>
{%- endmacro %}
