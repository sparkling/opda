{# leaf-table.html.j2 ──────────────────────────────────────────────────
   Emits one sub-table for a section on an aggregate page.
   Columns (desktop):
     Title · Type · Kind · Path · Required · Overlays · Affordance

   Plain-text values: no pill spans. Kind uses descriptive words
   (Declaration / Evidence / Derivation / envelope), not shortcuts.

   Inputs:
     section          — { id, title, prefixes } from theme-map.yaml.
     leaves           — list of leaf dicts (already classified, theme-assigned,
                        example-bound) for THIS section.
                        Each leaf carries:
                          path, name, required (bool), type, kind, title,
                          overlays (list of {key, label}), is_envelope (bool),
                          has_example (bool).
     show_envelopes   — bool. False on pages 35–42; True only on page 48.

   Row attributes:
     data-leaf-path   — the schema path.
     data-overlays    — comma-separated overlay keys.
─────────────────────────────────────────────────────────────────────── #}
{% macro leaf_table(section, leaves, show_envelopes=false) -%}
<div class="db-table-wrap full-bleed"
     data-section-id="{{ section.id }}"
     data-leaf-count="{{ leaves|length }}">
  <table class="db-table db-table--fixed" id="table-{{ section.id }}">
    <thead>
      <tr>
        <th style="width: 22%;">Title</th>
        <th style="width: 7rem;">Type</th>
        <th style="width: 8rem;">Kind</th>
        <th class="sortable" style="width: 26%;">Path</th>
        <th class="align-center" style="width: 6rem;">Required</th>
        <th style="width: 18%;">Overlays</th>
        <th style="width: 7rem;">Affordance</th>
      </tr>
    </thead>
    <tbody>
    {%- for leaf in leaves %}
      {%- if leaf.is_envelope and not show_envelopes %}{# Suppressed on pages 35–42. #}{% continue %}{% endif %}
      <tr data-leaf-path="{{ leaf.path }}"
          data-overlays="{{ leaf.overlays|map(attribute='key')|join(',') }}"
          {%- if leaf.is_envelope %} data-envelope="1" style="opacity: 0.6;"{% endif %}>
        <td>{{ leaf.title|default('', true) }}</td>
        <td><code>{{ leaf.type }}</code></td>
        <td>
          {%- if leaf.is_envelope -%}
          envelope
          {%- elif leaf.kind == 'declaration' -%}
          Declaration
          {%- elif leaf.kind == 'evidence' -%}
          Evidence
          {%- elif leaf.kind == 'derivation' -%}
          Derivation
          {%- else -%}
          <span class="muted">—</span>
          {%- endif %}
        </td>
        <td>
          {%- if leaf.is_envelope -%}
          <span aria-label="VC envelope leaf" title="VC envelope leaf — see page 48">🔒</span>
          <code><em>{{ leaf.path }}</em></code>
          {%- else -%}
          <code>{{ leaf.path }}</code>{% if leaf.required %}<span aria-label="required" title="required" style="color: var(--terracotta-700); font-weight: 700; margin-left: 0.25em;">*</span>{% endif %}
          {%- endif %}
        </td>
        <td class="align-center">{% if leaf.required %}yes{% else %}<span class="muted">—</span>{% endif %}</td>
        <td>
          {%- set ovs = leaf.overlays -%}
          {%- if ovs -%}
            {%- for o in ovs %}{{ o.label }}{% if not loop.last %}, {% endif %}{% endfor -%}
          {%- else -%}
          <span class="muted">—</span>
          {%- endif %}
        </td>
        <td>
          {%- if leaf.has_example %}example{% else %}<span class="muted">—</span>{% endif %}
        </td>
      </tr>
    {%- endfor %}
    </tbody>
  </table>
</div>
{%- endmacro %}
