{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" pre-bash'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" pre-edit'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" pre-task'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" post-edit'",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" post-command'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" post-task'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" compact-manual'"
          },
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" session-end'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" compact-auto'"
          },
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" session-end'",
            "timeout": 6000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" session-restore'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/auto-memory-hook.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/auto-memory-hook.mjs\" import'",
            "timeout": 8000
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)\"/.claude/scripts/check-patches.sh --global",
            "timeout": 30000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" route'",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'D=\"${CLAUDE_PROJECT_DIR:-.}\"; [ -f \"$D/.claude/helpers/hook-handler.mjs\" ] || D=\"${HOME}\"; exec node \"$D/.claude/helpers/hook-handler.mjs\" status'",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
