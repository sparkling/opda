  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:transportType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/National-rail-station> ] ] .

<#TransportTypeTrunkRoadMotorway> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Trunk road/motorway\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:transportType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Trunk-road-motorway> ] ] .

<#TransportTypeAirport> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Airport\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:transportType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Airport> ] ] .

<#TransportTypeHelipad> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Helipad\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:transportType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Helipad> ] ] .

<#TransportTypeOther> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Other\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:transportType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Other> ] ] .

<#TransportTypeTramway> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Tramway\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
