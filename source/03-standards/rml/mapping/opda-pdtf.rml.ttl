  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:schoolType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/schoolType/Primary> ] ] .  # <- propertyPack.nearbyFacilities.schools[].schoolType.primary

