# M14c — opda:schoolType -> opda:SchoolTypeScheme member IRI. Nested filter
#   on schoolType.{phase}.yesNoNotKnown == "Yes" (all 5 real schema phases);
#   same subject reuse as M14a/M14b. A school with multiple Yes phases emits
#   one opda:schoolType triple per phase (not single-valued — the ontology's
#   comment says "ONE shared datatype property", not "one value per node").
<#SchoolTypeNursery> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[?(@.schoolType.nursery.yesNoNotKnown==\"Yes\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:schoolType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/schoolType/Nursery> ] ] .  # <- propertyPack.nearbyFacilities.schools[].schoolType.nursery

