<#NearbyFacility_HealthCare> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.healthCare[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/healthcare/{name}" ;
                  rr:class opda:NearbyFacility ] ;
  rr:predicateObjectMap [ rr:predicate opda:name ;
      rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.healthCare[].name
  rr:predicateObjectMap [ rr:predicate opda:distanceInMiles ;
      rr:objectMap [ rml:reference "distanceInMiles" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.nearbyFacilities.healthCare[].distanceInMiles
  rr:predicateObjectMap [ rr:predicate opda:typeOfHealthCare ;
      rr:objectMap [ rml:reference "typeOfHealthCare" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.healthCare[].typeOfHealthCare
  rr:predicateObjectMap [ rr:predicate opda:specialties ;
      rr:objectMap [ rml:reference "specialties" ; rr:datatype xsd:string ] ] .  # <- propertyPack.nearbyFacilities.healthCare[].specialties

# ---------------------------------------------------------------------------
# M15 — RoomDimension (propertyPack.buildInformation.roomDimensions.rooms[*])
#   opda:hasRoomDimension (domain opda:Property, range opda:RoomDimension) is
#   now mapped on M4's own Property TriplesMap: an array-projected rr:template
#   placeholder (buildInformation.roomDimensions.rooms.roomName, plain dot
#   notation, no brackets) reaches into rooms[*] from M4's $.propertyPack
#   iterator — the same technique proven for opda:hasParticipant/opda:concerns.
#   This supersedes an earlier "no shared key" conclusion that only tried a
#   bracket-INDEXED reference (rooms[0].roomName, a fixed position, not a
#   projection over the whole array) — a different, narrower technique that
#   does still fail; the unindexed array-projection is what works.
# ---------------------------------------------------------------------------
<#RoomDimension> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.buildInformation.roomDimensions.rooms[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/room/{roomName}" ;
                  rr:class opda:RoomDimension ] ;
  rr:predicateObjectMap [ rr:predicate opda:roomName ;
      rr:objectMap [ rml:reference "roomName" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.buildInformation.roomDimensions.rooms[].roomName
  rr:predicateObjectMap [ rr:predicate opda:length ;
      rr:objectMap [ rml:reference "length" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.buildInformation.roomDimensions.rooms[].length
  rr:predicateObjectMap [ rr:predicate opda:width ;
      rr:objectMap [ rml:reference "width" ; rr:datatype xsd:decimal ] ] .  # <- propertyPack.buildInformation.roomDimensions.rooms[].width

# ---------------------------------------------------------------------------
# M16 — AttachedDocument (propertyPack.titlesToBeSold[*].additionalDocuments[*])
#   Two-level array nesting: morph-kgc's JSONPath iterator handles the nested
#   path directly (no separate parent TriplesMap/join needed for this case,
#   since nothing here needs to reference the enclosing titlesToBeSold item).
# ---------------------------------------------------------------------------
<#TitleAdditionalDocument> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.titlesToBeSold[*].additionalDocuments[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/document/{documentTypeCode}-{retrievedOn}" ;
                  rr:class opda:AttachedDocument ] ;
  rr:predicateObjectMap [ rr:predicate opda:documentTypeCode ;
      rr:objectMap [ rml:reference "documentTypeCode" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].additionalDocuments[].documentTypeCode
  rr:predicateObjectMap [ rr:predicate opda:filedUnder ;
      rr:objectMap [ rml:reference "filedUnder" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].additionalDocuments[].filedUnder
  rr:predicateObjectMap [ rr:predicate opda:retrievedOn ;
      rr:objectMap [ rml:reference "retrievedOn" ; rr:datatype xsd:date ] ] .  # <- propertyPack.titlesToBeSold[].additionalDocuments[].retrievedOn

# M17 — Search provider reference: merged into M5's existing <#Search>
# TriplesMap above (same subject, same iterator) rather than duplicated here.

# M18 — Survey construction type: now mapped on M4's own Property TriplesMap
#   (opda:constructionType, below), via the array-projected reference
#   `surveys.misc.constructionType` (plain dot notation, no brackets) COMBINED
#   with the M30 FNML mechanism (opda:scheme_member_iri) — constructionType is
#   rdfs:range skos:Concept, and surveys[] is a real array, so the enum value
#   needs the same slugify-to-scheme-IRI treatment as M30's single-object
#   enums, just reached through an array projection instead. This supersedes
#   the earlier "no shared key back to the property" conclusion, which only
#   tried a bracket-INDEXED reference (surveys[0].misc...) and a real R2RML
#   join — the unindexed array-projection needs neither. Proven correct via a
#   standalone scratch instance (surveys[0].misc.constructionType =
#   "Timber frame" -> .../scheme/constructionType/Timber-frame, an exact
#   match against the real ontology member) — testdata/01-04 don't exercise
#   propertyPack.surveys[] at all, so this is not exercised by the standard
#   regression suite, same caveat as the managedFreeholdOrCommonhold branch
#   documented near M27.

# ---------------------------------------------------------------------------
# M19 — Chain selling agent + opda:TransactionChain (chain.onwardPurchase[*])
#   domain=Transaction. Each onwardPurchase[] item is a STUB reference to a
#   DIFFERENT transaction in the same chain (transactionId/address/uprn/
#   sellingAgent only — not a full record); minted here as a real, if thin,
#   opda:Transaction individual (M19's own established pattern, unchanged) —
#   the honest reading of "real but partial" source data, matching this
#   mapping's own established idiom of minting sparse-but-real nodes rather
#   than inventing structure.
#
#   opda:TransactionChain design decision — RESOLVED (2026-07-04): opda:
#   TransactionChain's own rdfs:comment names a "dual-mechanism" — (a) a
#   recursive opda:dependsOnTransaction predicate between Transactions; (b)
#   opda:chainMembers list-of-Transactions on a TransactionChain parent.
#   Neither had ever actually been declared as a real owl:ObjectProperty —
#   both existed only as prose in the class comment and as candidate usage
#   in the exemplar source/03-standards/ontology/exemplars/chain-of-
#   transactions.ttl, whose own note said "the Council picks the canonical
#   shape". Per the user's own framing of the decision ("what was the
#   intention of the JSON schemas?"): PDTF's chain.onwardPurchase/buyersSale
#   shape, and chain's own description ("the data through which the chain
#   for this transaction can be built"), shows each instance carries only
#   its own LOCAL pairwise link(s) to adjacent chain transactions — never a
#   global membership list. A recursive predicate matches this; opda:
#   chainMembers remains a legitimate future DERIVED-aggregate target (built
#   by traversing dependsOnTransaction edges across a full instance corpus)
#   but was not declared since nothing populates it yet. opda:
#   dependsOnTransaction WAS declared for real (tools/opda-gen, property.py
#   — see git history) and is now asserted directly on M1's own Transaction
#   node, pointing at this TriplesMap's minted stub Transaction.
#
#   Retained alongside it: the pre-existing opda:hasChainPosition + minted
#   opda:TransactionChain aggregate-node mechanism (mint ONE
#   opda:TransactionChain node PER onwardPurchase[] member, keyed on THAT
#   member's own transactionId; BOTH the current transaction (M1) and the
#   stub Transaction (this TriplesMap) assert opda:hasChainPosition to that
#   SAME node). This is NOT superseded by dependsOnTransaction — the two
#   serve different purposes (a direct pairwise dependency edge vs. an
#   aggregate chain-membership marker reachable without traversing the
#   recursive chain) and both are now real, declared predicates.
#
#   chain.buyersSale[] is NOT mapped: verified against both the real v3
#   schema and the generated canonical data dictionary — buyersSale is a
#   SIBLING of chain's own "properties" key in the source JSON Schema (a
#   schema-authoring bug: it sits outside "properties", so opda-gen's own
#   flattening walker never emits a data-dictionary location for it). Citing
#   a dct:source path that does not resolve in the canonical dictionary would
#   fail ADR-0057 check 2; this is a schema-repo defect (source/03-standards/
#   schemas, a separate nested git repo) out of this mapping's scope to fix.
# ---------------------------------------------------------------------------
<#ChainSellingAgent> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.chain.onwardPurchase[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ;
                  rr:class opda:Transaction ] ;
  rr:predicateObjectMap [ rr:predicate opda:sellingAgent ;
      rr:objectMap [ rml:reference "sellingAgent" ; rr:datatype xsd:string ] ] ;  # <- chain.onwardPurchase[].sellingAgent
  rr:predicateObjectMap [ rr:predicate opda:concernsProperty ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ] ] ;  # <- chain.onwardPurchase[].uprn (join to <#ChainProperty>'s minted opda:Property node)
  rr:predicateObjectMap [ rr:predicate opda:hasChainPosition ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/transactionchain/onwardPurchase/{transactionId}" ] ] .  # <- chain.onwardPurchase[].transactionId (join to <#ChainLink>'s minted opda:TransactionChain node; see design-decision comment above)

<#ChainProperty> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.chain.onwardPurchase[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ;
                  rr:class opda:Property ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasUPRN ;
      rr:objectMap [ rml:reference "uprn" ; rr:datatype xsd:string ] ] .  # <- chain.onwardPurchase[].uprn (address sub-fields are NOT mapped: no opda: predicate exists anywhere in the ontology for a postal address — out of this mapping's scope, would be new ontology design work)

<#ChainLink> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.chain.onwardPurchase[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/transactionchain/onwardPurchase/{transactionId}" ;
                  rr:class opda:TransactionChain ] .  # <- chain.onwardPurchase[].transactionId (class-instantiating join target; see design-decision comment above)

# opda:hasChainPosition on the CURRENT transaction (M1's own node): asserted
# from M1's root iterator via an array-projected object template, pointing at
# the SAME <#ChainLink> node(s) minted above — one triple per onwardPurchase
# member, safe under RMLMapper because it is the ONLY array-projected
# placeholder in that single predicateObjectMap (the proven-safe idiom;
# combining it with a SECOND, independently-varying array-projected
# placeholder in the same TriplesMap was tested and confirmed to silently
# cross-product — see M19's own comment, above, and ADR-0057's Amendments).
# See M1's <#Transaction> TriplesMap for the actual predicateObjectMap (added there,
# not repeated here, to keep M1 as the single source of the root
# Transaction's own triples).

# ---------------------------------------------------------------------------
# M20 — Planning permission record (localSearches[*])  (opda:Search)
#   iterator: propertyPack.localSearches.localAuthoritySearches
#     .planningAndBuildingRegulations.decisionsAndPendingApplications
#     .planningPermission[*]
#   buildingControlStartDate/planningStartDate (also domain=Search, one level
#   up in decisionsAndPendingApplications) are now mapped at M20a below, via a
#   NEW Search node minted at $.propertyPack (where {uprn} lives) rather than
#   from within planningPermission[*]'s own iterator — the same "mint a
#   synthetic parent node on a stable ambient key" idiom used for M24a's
#   RiskAssessment parents. Supersedes the earlier "no natural key at that
#   container level" conclusion, which is true of the container itself but
#   doesn't rule out keying the node on {uprn} + the field's own value (the
#   skip-together technique, ADR-0057 Amendment 1).
# ---------------------------------------------------------------------------
<#PlanningPermission> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planning/{refNumber}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planning/{refNumber}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:refNumber ;
      rr:objectMap [ rml:reference "refNumber" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].refNumber
  rr:predicateObjectMap [ rr:predicate opda:applicationDate ;
      rr:objectMap [ rml:reference "applicationDate" ; rr:datatype xsd:date ] ] ;  # <- ...planningPermission[].applicationDate
  rr:predicateObjectMap [ rr:predicate opda:applicationType ;
      rr:objectMap [ rml:reference "applicationType" ; rr:datatype xsd:string ] ] ;  # <- ...planningPermission[].applicationType
  rr:predicateObjectMap [ rr:predicate opda:decision ;
      rr:objectMap [ rml:reference "decision" ; rr:datatype xsd:string ] ] ;  # <- ...planningPermission[].decision
  rr:predicateObjectMap [ rr:predicate opda:decisionDate ;
      rr:objectMap [ rml:reference "decisionDate" ; rr:datatype xsd:date ] ] .  # <- ...planningPermission[].decisionDate

<#PlanningPermissionRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planning/{refNumber}/run" ;
                  rr:class prov:Activity ] .

# M20a — decisionsAndPendingApplications' OWN scalar fields (planningStartDate/
#   buildingControlStartDate), one level up from M20's planningPermission[*]
#   array. Keyed on {uprn} (from M4's own iterator, $.propertyPack) + the
#   planningStartDate value itself (skip-together: the node only mints when
#   planningStartDate is present). Honest asymmetry: if buildingControlStartDate
#   is present but planningStartDate is absent, this node does not mint at all
#   (the subject template's placeholder fails) and buildingControlStartDate is
#   lost too — no PDTF v3 schema constraint ties the two together, so a
#   real-world instance could hit this; not exercised by testdata/01-04
#   (neither field occurs in any tracked fixture), proven via a standalone
#   scratch instance instead (same caveat as M18/constructionType above).
<#PlanningBuildingRegsRecord> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planningbuildingregs-{uprn}-{localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planningbuildingregs-{uprn}-{localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:planningStartDate ;
      rr:objectMap [ rml:reference "localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate" ; rr:datatype xsd:date ] ] ;  # <- propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate
  rr:predicateObjectMap [ rr:predicate opda:buildingControlStartDate ;
      rr:objectMap [ rml:reference "localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.buildingControlStartDate" ; rr:datatype xsd:date ] ] .  # <- propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.buildingControlStartDate

<#PlanningBuildingRegsRecordRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planningbuildingregs-{uprn}-{localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M21 — Planning designation plan (localSearches[*].designationsAndProposals.plans[*])
#   (opda:Search)  statusDate on the plan itself.
# ---------------------------------------------------------------------------
<#PlanningDesignationPlan> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{name}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{name}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:statusDate ;
      rr:objectMap [ rml:reference "statusDate" ; rr:datatype xsd:date ] ] .  # <- ...designationsAndProposals.plans[].statusDate

<#PlanningDesignationPlanRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{name}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M22 — Planning designation entry (…plans[*].designations[*])  (opda:Search)
#   A distinct, independent Search-typed node from M21's plan-level node —
#   opda:Search is a general class with many valid instances (M5/M6/M9/M20
#   are all different Search records too); unlike M18's constructionType
#   (whose domain required THE SPECIFIC Property node), minting a separate
#   Search node here for the designation entry is semantically sound, not a
#   domain violation. Two-level array iterator (proven pattern; see M16).
# ---------------------------------------------------------------------------
<#PlanningDesignationEntry> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*].designations[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{designationType}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{designationType}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:designationType ;
      rr:objectMap [ rml:reference "designationType" ; rr:datatype xsd:string ] ] .  # <- ...designationsAndProposals.plans[].designations[].designationType

<#PlanningDesignationEntryRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*].designations[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{designationType}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M23 — valuationComparisonData (a top-level structure, PEER to propertyPack,
#   not nested under it). Two independent subtrees, each needing its own
#   TriplesMap iterator (morph-kgc: one iterator per TriplesMap), and — per
#   rdfs:domain, below — BOTH subtrees bear on opda:Valuation, not
#   opda:Comparable:
#
#     valuationComparisonData.propertyDetails[*]   — an array of comparable
#       properties, each with a real natural key (uprn). Instantiates
#       opda:Comparable (class-promoted; ODR-0008 Q4a) for the comparable
#       record itself, AND opda:soldPrice/opda:soldDate/opda:listPrice/
#       opda:listedDate — which the ontology's own rdfs:domain assigns to
#       opda:Valuation, not opda:Comparable ("Bearer opda:Valuation...flat
#       per §Q6a" — a deliberate ODR-0008 Q6a flattening decision, not
#       something this mapping invents). Comparable itself carries NO
#       rdfs:domain-bound datatype/object property in the current ontology
#       (verified: zero grep hits) — it is typed + given prov:wasGeneratedBy
#       only.
#
#     valuationComparisonData.propertyPricing      — a SINGLETON object (not
#       an array) with the subject property's own market-estimate figures
#       (estimatedPrice, rentalEstimate.estimatedAmount, yield,
#       priceEstimationDetails.*). Also opda:Valuation. Has no natural key of
#       its own; keyed on {estimatedPrice} itself (same optional-field-in-
#       template technique as M4b/M4d/M4e — this doubles as the "skip
#       together" guard AND the entity's own identity key, since no other
#       stable field exists here).
#
#   Because propertyDetails[*] and propertyPricing are different subtrees
#   with no shared key in the JSON, and rdfs:domain assigns fields from BOTH
#   onto opda:Valuation, this mapping mints TWO independent opda:Valuation-
#   typed nodes per transaction (valuation/estimate-{estimatedPrice} and
#   valuation/comparable-{uprn}) rather than fabricate a shared key that
#   doesn't exist in the data — each independently satisfies the
#   ValuationIdentityKeyShape (prov:wasGeneratedBy minCount 1).
# ---------------------------------------------------------------------------
<#Comparable> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/comparable/{uprn}" ;
                  rr:class opda:Comparable ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/comparable/{uprn}/run" ] ] .  # SHACL: class-promoted opda:Comparable requires prov:wasGeneratedBy

<#ComparableRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/comparable/{uprn}/run" ;
                  rr:class prov:Activity ] .

<#ValuationComparableListing> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}" ;
                  rr:class opda:Valuation ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/run" ] ] ;  # SHACL: class-promoted opda:Valuation requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:soldDate ;
      rr:objectMap [ rr:datatype xsd:date ;
        fnml:functionValue [
          rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:truncate_to_date> ] ] ;
          rr:predicateObjectMap [ rr:predicate <urn:opda:param:datetime> ; rr:objectMap [ rml:reference "propertyListingInfo.soldDate" ] ] ] ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.soldDate (oneOf branch: Recently Sold; dateTime lexical truncated to xsd:date)
  rr:predicateObjectMap [ rr:predicate opda:listedDate ;
      rr:objectMap [ rml:reference "propertyListingInfo.listedDate" ; rr:datatype xsd:date ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.listedDate (oneOf branch: Currently On Sale; not instance-exercised, path verified)
  rr:predicateObjectMap [ rr:predicate opda:soldPrice ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/soldPrice-{propertyListingInfo.soldPrice}" ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.soldPrice (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:listPrice ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/listPrice-{propertyListingInfo.listPrice}" ] ] .  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.listPrice (MonetaryAmount join, see below; not instance-exercised)

<#ValuationComparableListingRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/run" ;
                  rr:class prov:Activity ] .

<#SoldPriceAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/soldPrice-{propertyListingInfo.soldPrice}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "propertyListingInfo.soldPrice" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.soldPrice
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#ListPriceAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/listPrice-{propertyListingInfo.listPrice}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "propertyListingInfo.listPrice" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.listPrice
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#Valuation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}" ;
                  rr:class opda:Valuation ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/run" ] ] ;  # SHACL: class-promoted opda:Valuation requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:estimatedPrice ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/estimatedPrice-{estimatedPrice}" ] ] ;  # <- valuationComparisonData.propertyPricing.estimatedPrice (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:estimatedAmount ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/rentalEstimate-{rentalEstimate.estimatedAmount}" ] ] ;  # <- valuationComparisonData.propertyPricing.rentalEstimate.estimatedAmount (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:yield ;
      rr:objectMap [ rml:reference "yield" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyPricing.yield
  rr:predicateObjectMap [ rr:predicate opda:pricingMethodology ;
      rr:objectMap [ rml:reference "priceEstimationDetails.pricingMethodology" ; rr:datatype xsd:string ] ] ;  # <- valuationComparisonData.propertyPricing.priceEstimationDetails.pricingMethodology
  rr:predicateObjectMap [ rr:predicate opda:credibilitySources ;
      rr:objectMap [ rml:reference "priceEstimationDetails.credibilitySources" ; rr:datatype xsd:string ] ] .  # <- valuationComparisonData.propertyPricing.priceEstimationDetails.credibilitySources (array of strings)

<#ValuationRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/run" ;
                  rr:class prov:Activity ] .

<#EstimatedPriceAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/estimatedPrice-{estimatedPrice}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "estimatedPrice" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyPricing.estimatedPrice
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#RentalEstimateAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/rentalEstimate-{rentalEstimate.estimatedAmount}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "rentalEstimate.estimatedAmount" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyPricing.rentalEstimate.estimatedAmount
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

# ---------------------------------------------------------------------------
# M24 — RiskAssessment (environmental-peril riskSubcategories[])  (opda:RiskAssessment)
#   opda:subCategory (domain opda:RiskAssessment) cites TWO real occurrences —
#   flooding.floodRisk.riskSubcategories[] and climate.climateRisk
#   .riskSubcategories[] — both bound (ODR-0035: trace every real occurrence,
#   not just one dct:source citation). Each riskSubcategories[] item carries
#   its own genuine key (subCategory itself — a per-item distinguishing
#   name), unlike the parent floodRisk/climateRisk block (which has no key of
#   its own — closed below at M24a, once thought permanently blocked by the
#   since-fixed morph-kgc dropna bug; see M24a's own comment). Class-promoted (shares
#   RiskAssessment's identity shape with Comparable/Survey/Valuation, above)
#   so each sub-assessment node gets its own prov:wasGeneratedBy + RunActivity.
#   opda:actionAlertRating (plain xsd:integer) and opda:riskIndicator
#   (rdfs:range skos:Concept, opda:YesNoNotKnownScheme) are also real,
#   sibling fields on each riskSubcategories[] item (verified: real schema
#   enum here is Yes/No only, no "Not known" — the 3-value scheme is shared
#   more broadly). riskIndicator uses the per-value-filter pattern (M3c/
#   M14a/M14b), NOT the M30 FNML mechanism — riskSubcategories[] is a real
#   array, so the filter technique works, and ADR-0057 prefers it over FNML
#   when both are viable (single-file auditability; FNML is the escape
#   hatch for single-object contexts only, per M30's own comment).
# ---------------------------------------------------------------------------
<#FloodRiskSubcategory> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:subCategory ;
      rr:objectMap [ rml:reference "subCategory" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[].subCategory
  rr:predicateObjectMap [ rr:predicate opda:actionAlertRating ;
      rr:objectMap [ rml:reference "actionAlertRating" ; rr:datatype xsd:integer ] ] ;  # <- propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[].actionAlertRating
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Flooding> ] .  # constant: this TriplesMap only ever iterates the flooding container

<#FloodRiskSubcategoryRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ;
                  rr:class prov:Activity ] .

<#FloodRiskSubcategoryIndicatorYes> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[?(@.riskIndicator==\"Yes\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/Yes> ] ] .

<#FloodRiskSubcategoryIndicatorNo> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[?(@.riskIndicator==\"No\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/No> ] ] .

<#ClimateRiskSubcategory> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:subCategory ;
      rr:objectMap [ rml:reference "subCategory" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[].subCategory
  rr:predicateObjectMap [ rr:predicate opda:actionAlertRating ;
      rr:objectMap [ rml:reference "actionAlertRating" ; rr:datatype xsd:integer ] ] ;  # <- propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[].actionAlertRating
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Climate> ] .  # constant: this TriplesMap only ever iterates the climate container

<#ClimateRiskSubcategoryRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ;
                  rr:class prov:Activity ] .

<#ClimateRiskSubcategoryIndicatorYes> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[?(@.riskIndicator==\"Yes\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/Yes> ] ] .

<#ClimateRiskSubcategoryIndicatorNo> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[?(@.riskIndicator==\"No\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/No> ] ] .

# M24a — RiskAssessment PARENT nodes (the floodRisk/climateRisk container
#   itself, one level up from M24's riskSubcategories[] children) — closes
#   opda:hasSubAssessment (ODR-0008d Rule 4's result-recursion axis: a parent
#   RiskAssessment -> each riskSubcategories[] child, itself a leaf
#   RiskAssessment per M24). Previously undiscussed as mappable at all: the
#   container has no own JSON key, but IS mintable on a stable ambient key
#   ({uprn}, already M4's Property identity key) plus a CONSTANT peril-name
#   segment (fixed per TriplesMap, not a JSON value) — same idiom as M7a/M23's
#   {titleNumber}-adjacent keying. Node existence is made conditional on the
#   container actually being present by embedding its own riskIndicator VALUE
#   in the subject template (the established skip-together technique, ADR-0057
#   Amendment 1): if floodRisk/climateRisk is entirely absent (e.g. testdata/02
#   minimal), the whole subject template placeholder fails to resolve and the
#   row is dropped — no spurious RiskAssessment minted for a peril that was
#   never assessed. hasSubAssessment then reaches the child's {subCategory} key
#   via the array-projected rr:template placeholder technique (proven for
#   opda:hasParticipant/opda:concerns) — cheap here because the iterator is
#   $.propertyPack (shared with M4/M7/etc), so the first path segment pulled is
#   "environmentalIssues", not the whole propertyPack subtree; when
#   riskSubcategories[] itself is absent (e.g. testdata/01, which has
#   floodRisk.riskIndicator but no riskSubcategories), only the
#   hasSubAssessment triple is dropped — the parent node itself still mints.
<#FloodRiskParent> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Flooding-{environmentalIssues.flooding.floodRisk.riskIndicator}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Flooding-{environmentalIssues.flooding.floodRisk.riskIndicator}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Flooding> ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasSubAssessment ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{environmentalIssues.flooding.floodRisk.riskSubcategories[*].subCategory}" ] ] .  # <- propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[] (result-recursion parent->child, ODR-0008d Rule 4)

<#FloodRiskParentRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Flooding-{environmentalIssues.flooding.floodRisk.riskIndicator}/run" ;
                  rr:class prov:Activity ] .

<#ClimateRiskParent> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Climate-{environmentalIssues.climate.climateRisk.riskIndicator}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Climate-{environmentalIssues.climate.climateRisk.riskIndicator}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Climate> ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasSubAssessment ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{environmentalIssues.climate.climateRisk.riskSubcategories[*].subCategory}" ] ] .  # <- propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[] (result-recursion parent->child, ODR-0008d Rule 4)

<#ClimateRiskParentRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Climate-{environmentalIssues.climate.climateRisk.riskIndicator}/run" ;
                  rr:class prov:Activity ] .

# M25 — typeOfConstruction.buildingSafety.potentialCost: NOT mapped. rdfs:range
#   is opda:MonetaryAmount, but the real JSON field is free text (type:
#   string, "What will the potential cost be?" — no numeric constraint at
#   all). A ratified, pre-existing tension (council session-028 Q3; see the
#   term's own rdfs:comment), not something RML can bridge without
#   fabricating a numeric parse of free text. Left as a genuine, documented
#   gap — same shape as M14/M18/M20's gaps above.
#
# M26 — surveys[].misc.constructionType, localSearches
#   buildingControlStartDate/planningStartDate: already documented as genuine
#   gaps at M18, M20 respectively (re-verified this session — still true, no
#   new technique found for either). nearbyFacilities.schools[].schoolType
#   is NO LONGER in this list — re-verified this session and fixed at M14c
#   above (the per-value nested-filter idiom applies; not a genuine gap).

# ---------------------------------------------------------------------------
# M27 — propertyPack.ownership (leasehold branch): remaining LegalEstate-
#   domain leaves already added directly to M7's <#LegalEstate> TriplesMap,
#   above (same subject, same iterator — matching the M4/M7a established
#   style of one TriplesMap per node, many predicateObjectMaps). This block
#   covers the leaves whose rdfs:domain is NOT opda:LegalEstate:
#     - opda:certificateOfComplianceFee's MonetaryAmount value node (M27a)
#     - opda:dateRemedialActionRequired (domain opda:RiskAssessment) — a
#       SINGLETON risk-assessment block nested in managedAreasCoveredByPolicy
#       (not an array), keyed on the SAME titleNumber (M27b)
#     - opda:confirmation / opda:costsApplicableToTheDeed / opda:feeIncludingVAT
#       / opda:response (domain opda:Transaction) — CORRECTED (2026-07-04,
#       post-RMLMapper-migration stale-claim audit): now bound directly on
#       M1's <#Transaction> TriplesMap via array-projected references/
#       templates into this array (the same technique already proven for
#       opda:concerns/opda:hasParticipant/opda:hasRoomDimension), verified
#       empirically to resolve onto the real opda:Transaction node with the
#       correct MonetaryAmount join IRIs. The old "expensive in practice"
#       framing (M1's own comment) was a morph-kgc-era cost citation never
#       re-verified after the engine migration — RMLMapper has no such cost
#       (measured within noise, matching M1b's own already-corrected finding).
#       The formerly-untyped <#OwnershipTransactionRecord> TriplesMap and its
#       validate_shacl.sh allowlist entries are removed (M27c retired).
#     - opda:accountName/accountNumber/sortCode/reference (domain
#       opda:Organisation) — the landlord contact IS a real Organisation,
#       keyed on its own genuine name (contact.nameOrOrganisation) (M27d)
#     - opda:hasFixedRentcharge/dealsWithDayToDayMaintenanceOfManagedArea/
#       fromTheOwners/forTheManagedAreas — the managedFreeholdOrCommonhold
#       oneOf branch's own exclusive leaves (domain opda:LegalEstate, plain
#       xsd:string/xsd:decimal, no Concept-range issue). The SAME M7
#       <#LegalEstate> TriplesMap (above) already picks these up (no separate
#       TriplesMap needed). STALE CLAIM RETRACTED (2026-07-04, post-RMLMapper-
#       migration audit): a 2-item ownershipsToBeTransferred[] array with
#       heterogeneous top-level keys (one leasehold-shaped, one
#       managedFreeholdOrCommonhold-shaped) was previously avoided in the
#       tracked test fixture on the strength of a real morph-kgc defect (its
#       pandas-based normalize_hierarchical_data cartesian-product flattening,
#       ADR-0057 Amendments 2026-07-04 entry 2) — that defect was specific to
#       morph-kgc's implementation and does not exist in RMLMapper's Jayway-
#       JsonPath-based engine. Re-verified empirically this session with a
#       genuinely heterogeneous 2-item scratch instance: M4's sibling
#       "ownership.isFirstRegistration" reference resolves correctly and both
#       array items emit only their own item-specific properties, no cross-
#       contamination. Leasehold remains the sole array item in the tracked
#       test fixture (not required by any remaining limitation — a fixture-
#       coverage choice now, not an engine constraint) — this branch's
#       correctness is proven both via scratch instance and this re-test.
#   NOT mapped in this batch: opda:numberOfSellers/opda:numberOfNonUkResidentSellers
#   (domain opda:Proprietorship) remain a genuine gap pending the Proprietor/
#   Proprietorship Relator design — see M27f, below.
# ---------------------------------------------------------------------------
<#CertificateOfComplianceFeeAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/certificateOfComplianceFee-{leaseholdInformation.requiredDocuments.certificateOfComplianceFee}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.requiredDocuments.certificateOfComplianceFee" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.requiredDocuments.certificateOfComplianceFee
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#OwnershipRiskAssessment> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/estate-{titleNumber}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/estate-{titleNumber}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:dateRemedialActionRequired ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.dateRemedialActionRequired" ; rr:datatype xsd:date ] ] .  # <- …leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.dateRemedialActionRequired

<#OwnershipRiskAssessmentRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/estate-{titleNumber}/run" ;
                  rr:class prov:Activity ] .

<#CostsApplicableToTheDeedAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}/amount/costsApplicableToTheDeed-{leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#FeeIncludingVATAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}/amount/feeIncludingVAT-{leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#LandlordOrganisation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/org/{leaseholdInformation.contactDetails.contacts.landlord.contact.nameOrOrganisation}" ;
                  rr:class opda:Organisation ] ;
  rr:predicateObjectMap [ rr:predicate opda:accountName ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountName" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountName
  rr:predicateObjectMap [ rr:predicate opda:accountNumber ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountNumber" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountNumber
  rr:predicateObjectMap [ rr:predicate opda:sortCode ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.sortCode" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.sortCode
  rr:predicateObjectMap [ rr:predicate opda:reference ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.reference" ; rr:datatype xsd:string ] ] .  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.reference

# M27f — opda:numberOfSellers / opda:numberOfNonUkResidentSellers (domain
#   opda:Proprietorship): NOT mapped. Tried minting a Proprietorship node
#   keyed on uprn with just these two counts — caught by the (post-harness-
#   fix) SHACL run: ProprietorshipMediationShape requires ANY opda:Proprietorship
#   individual to carry opda:mediates -> >=2 opda:Proprietor individuals (a
#   UFO Relator, ODR-0006 §Q3 — "a relator that binds fewer than two bearers
#   is not a relator"). Properly satisfying this means identifying which
#   participants/legalOwners play the Proprietor role and linking them via
#   opda:mediates — a real Relator-modelling decision, not a mechanical
#   "add a predicateObjectMap" gap like the rest of this region. Left as a
#   genuine, documented gap pending that design (not attempted here to avoid
#   shipping a node that mechanically fails a hard SHACL constraint).

# M30 — the M28/M29 cluster, closed via RML-FNML (mapping/opda-udfs.py).
#   Every property below has rdfs:range skos:Concept but sits in a single,
#   always-present JSON object ($.propertyPack, or one leasehold
#   ownershipsToBeTransferred[] item), not a real array — the per-value-
#   filter technique that fixed M14's ofstedRating/transportType needs
#   `[?(...)]` JSONPath filter brackets, which only work on arrays.
#   Proven empirically this session: a single generic UDF
#   (opda:scheme_member_iri, value+scheme params) replicates opda_gen's own
#   `_slugify_for_uri` exactly (verified against real scheme members,
#   including the punctuation-stripping case "FTTC (Fibre to the Cabinet)"
#   -> ".../FTTC-Fibre-to-the-Cabinet") and constructs the correct
#   scheme-member IRI directly — output rr:termType rr:IRI (not the default
#   literal; morph-kgc's literal-output code path for rmlf:functionExecution
#   has an internal bug unconditionally touching a 'reference_results'
#   dataframe column that a bare function execution never populates).
#
#   opda:ownerType (domain opda:Proprietor) is NOT included here — Proprietor
#   is the same deferred Relator-modelling class flagged near M27 above (no
#   node minted yet; a real design decision, not an FNML gap).
#   opda:tenureKind (ODR-0008 §Q5a) has NO real JSON occurrence at all
#   (verified: zero matches anywhere in the v3 schema) — a genuinely
#   conceptual, ODR-only term, not a gap of this kind.
<#Property_FNMLEnums> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:isInsured ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "insurance.isInsured" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.insurance.isInsured
  rr:predicateObjectMap [ rr:predicate opda:hasBeenFlooded ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "environmentalIssues.flooding.historicalFlooding.hasBeenFlooded" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.environmentalIssues.flooding.historicalFlooding.hasBeenFlooded
  rr:predicateObjectMap [ rr:predicate opda:hasSmartHomeSystems ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "smartHomeSystems.hasSmartHomeSystems" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.smartHomeSystems.hasSmartHomeSystems
  rr:predicateObjectMap [ rr:predicate opda:hasSprayFoamInstalled ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "typeOfConstruction.sprayFoamInsulation.hasSprayFoamInstalled" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.typeOfConstruction.sprayFoamInsulation.hasSprayFoamInstalled
  rr:predicateObjectMap [ rr:predicate opda:hasValidGuaranteesOrWarranties ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "guaranteesWarrantiesAndIndemnityInsurances.hasValidGuaranteesOrWarranties" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.guaranteesWarrantiesAndIndemnityInsurances.hasValidGuaranteesOrWarranties
  rr:predicateObjectMap [ rr:predicate opda:isLocatedOverCommercialPremises ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "buildInformation.building.overCommercialPremises.isLocatedOverCommercialPremises" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.buildInformation.building.overCommercialPremises.isLocatedOverCommercialPremises
  rr:predicateObjectMap [ rr:predicate opda:isSupplyMetered ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "waterAndDrainage.water.mainsWater.waterMeter.isSupplyMetered" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.waterAndDrainage.water.mainsWater.waterMeter.isSupplyMetered
  rr:predicateObjectMap [ rr:predicate opda:areBoundariesUniform ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "legalBoundaries.ownership.areBoundariesUniform" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.legalBoundaries.ownership.areBoundariesUniform
  rr:predicateObjectMap [ rr:predicate opda:soldWithVacantPossession ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "occupiers.othersAged17OrOver.vacantPossession.soldWithVacantPossession" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.occupiers.othersAged17OrOver.vacantPossession.soldWithVacantPossession
  rr:predicateObjectMap [ rr:predicate opda:offMainsDrainageSystemType ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "waterAndDrainage.drainage.mainsFoulDrainage.offMainsDrainageSystem.offMainsDrainageSystemType" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "offMainsDrainageSystemType" ] ] ] ] ] ;  # <- propertyPack.waterAndDrainage.drainage.mainsFoulDrainage.offMainsDrainageSystem.offMainsDrainageSystemType
  rr:predicateObjectMap [ rr:predicate opda:propertyType ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "buildInformation.building.propertyType" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "propertyType" ] ] ] ] ] ;  # <- propertyPack.buildInformation.building.propertyType
  rr:predicateObjectMap [ rr:predicate opda:builtForm ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "buildInformation.building.builtForm" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "builtForm" ] ] ] ] ] ;  # <- propertyPack.buildInformation.building.builtForm
  rr:predicateObjectMap [ rr:predicate opda:priceQualifier ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "priceInformation.priceQualifier" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "priceQualifier" ] ] ] ] ] ;  # <- propertyPack.priceInformation.priceQualifier
  rr:predicateObjectMap [ rr:predicate opda:currentEnergyRating ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "energyEfficiency.certificate.currentEnergyRating" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "currentEnergyRating" ] ] ] ] ] ;  # <- propertyPack.energyEfficiency.certificate.currentEnergyRating
  rr:predicateObjectMap [ rr:predicate opda:typeOfConnection ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "connectivity.broadband.typeOfConnection" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "broadbandConnectionType" ] ] ] ] ] ;  # <- propertyPack.connectivity.broadband.typeOfConnection
  rr:predicateObjectMap [ rr:predicate opda:centralHeatingFuelType ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.centralHeatingFuelType" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "centralHeatingFuelType" ] ] ] ] ] ;  # <- propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.centralHeatingFuelType
  rr:predicateObjectMap [ rr:predicate opda:heatingType ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "heating.heatingSystem.heatingType" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "heatingType" ] ] ] ] ] ;  # <- propertyPack.heating.heatingSystem.heatingType
  rr:predicateObjectMap [ rr:predicate opda:marketingTenure ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "marketingTenure" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "tenureKind" ] ] ] ] ] .  # <- propertyPack.marketingTenure (reuses TenureKindScheme, ODR-0024 R6)

# M30a — LegalEstate-domain FNML enums (ownershipsToBeTransferred[*], same
#   iterator/subject as M7's <#LegalEstate>).
<#LegalEstate_FNMLEnums> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:isSharedOwnership ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "leaseholdInformation.sharedOwnership.isSharedOwnership" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- …leaseholdInformation.sharedOwnership.isSharedOwnership
  rr:predicateObjectMap [ rr:predicate opda:isGroundRentPayable ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "leaseholdInformation.groundRent.isGroundRentPayable" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- …leaseholdInformation.groundRent.isGroundRentPayable
  rr:predicateObjectMap [ rr:predicate opda:sellerContributesToServiceCharge ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.sellerContributesToServiceCharge" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "yesNo" ] ] ] ] ] ;  # <- …leaseholdInformation.serviceCharge.sellerContributesToServiceCharge
  rr:predicateObjectMap [ rr:predicate opda:ownershipType ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "ownershipType" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "ownershipType" ] ] ] ] ] .  # <- propertyPack.ownership.ownershipsToBeTransferred[].ownershipType

# ---------------------------------------------------------------------------
# M31 — Fixtures-and-fittings item (propertyPack.fixturesAndFittings.
#   basicFittings.boilerImmersionHeater, representative of ~90 structurally
#   identical items across basicFittings/kitchen/bathroom/carpets/etc.) —
#   domain-less opda:price (xsd:decimal) and opda:inclusionStatus
#   (rdfs:range skos:Concept, opda:InclusionStatusScheme — Included/
#   Excluded/None). Per ODR-0022's own inclusionStatus comment: "bound on a
#   transaction-scoped fixtures-list node (NEVER rdfs:domain opda:Property)"
#   — this item object has no field of its own to key on (no name/id, only
#   isIncludedExcludedOrNone/comments/price), but it's a SINGLE, non-array
#   JSON object (one per file), so a genuinely CONSTANT subject IRI (no
#   template placeholder at all) is honest and correct — the iterator
#   naturally yields zero rows when the item is absent from an instance,
#   one row when present; no fabricated identity needed. Same untyped-node
#   reasoning as M1b/M12 (a bearer exists, deliberately not typed
#   opda:Property). opda:inclusionStatus uses the M30 FNML mechanism (single-
#   object context, same as M30's other properties).
#   Only ONE of the ~90 structurally identical fixturesAndFittings items is
#   bound here (matching the opda:supplier/opda:location precedent of
#   tracing a representative real occurrence, not literally all ~90).
# ---------------------------------------------------------------------------
<#FixturesBoilerImmersionHeater> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.fixturesAndFittings.basicFittings.boilerImmersionHeater" ] ;
  rr:subjectMap [ rr:constant <https://opda.org.uk/pdtf/harness/data/fixtures/boilerImmersionHeater> ] ;
  rr:predicateObjectMap [ rr:predicate opda:price ;
      rr:objectMap [ rml:reference "price" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.fixturesAndFittings.basicFittings.boilerImmersionHeater.price
  rr:predicateObjectMap [ rr:predicate opda:inclusionStatus ;
      rr:objectMap [ rr:termType rr:IRI ; fnml:functionValue [
        rr:predicateObjectMap [ rr:predicate fno:executes ; rr:objectMap [ rr:constant <urn:opda:scheme_member_iri> ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:value> ; rr:objectMap [ rml:reference "isIncludedExcludedOrNone" ] ] ;
        rr:predicateObjectMap [ rr:predicate <urn:opda:param:scheme> ; rr:objectMap [ rr:constant "inclusionStatus" ] ] ] ] ] .  # <- propertyPack.fixturesAndFittings.basicFittings.boilerImmersionHeater.isIncludedExcludedOrNone

# ---------------------------------------------------------------------------
# M32 — Milestone (opda:Milestone)  iterator: root ($, same as M1)
#   Real JSON: milestones.{listed,legalForms,soldSubjectToContract,searches,
#   enquiries,exchangeOfContracts,completion} — the complete key set in the
#   real v3 schema (enumerated via opda-gen's own venv, not guessed from a
#   partial read). Each sub-object carries SOME of {expected,started,
#   completed} (all xsd:dateTime-format strings).
#
#   Classification is per opda:Milestone's own rdfs:comment (S007 Q2 hybrid
#   PROV-O typing), determined from the SCHEMA's own shape (which of
#   started/completed the milestone HAS at all, not which are populated in
#   any one instance):
#     INSTANT  (no "started" in the schema): listed, soldSubjectToContract,
#       exchangeOfContracts -> prov:atTime (+ opda:occurredAtTime, the
#       declared "informational alias") from .completed.
#     INTERVAL (schema has "started"): legalForms, searches, enquiries,
#       completion -> prov:startedAtTime from .started, prov:endedAtTime
#       from .completed (independent optional field, present once the
#       interval has actually closed — ordinary property-level skip, no
#       special technique needed since the Activity node already exists).
#   Each Milestone's OWN existence is gated on its defining occurrence field
#   (completed for instant; started for interval — an interval milestone
#   that has started but not yet completed is still a real, ongoing PROV-O
#   Activity) via the standard subject-template null-skip technique.
#
#   opda:plannedAtTime (domain prov:Plan — plannedAtTimeDomainShape is
#   sh:Violation-severity closed-world: the subject of opda:plannedAtTime
#   MUST be typed prov:Plan, verified against opda-shapes-merged.ttl before
#   choosing this design) is carried on a SEPARATE prov:Plan node, linked
#   from the Activity via prov:qualifiedAssociation -> prov:Association ->
#   prov:hadPlan, exactly as opda:Milestone's own rdfs:comment specifies —
#   for the 4 milestones whose schema shape has "expected" (listed, searches,
#   exchangeOfContracts, completion), gated independently on that field.
#
#   RESOLVED (2026-07-04): the ontology-internal inconsistency flagged here
#   (MilestoneVarianceRule's CONSTRUCT querying opda:plannedAtTime directly
#   on the Milestone, conflicting with plannedAtTimeDomainShape's
#   Violation-severity requirement that its subject be typed prov:Plan) has
#   been fixed at the source — Council session-007 Q6 (10-0 FOR) already
#   ratified the Plan-vs-Activity design this mapping implements; the rule's
#   own WHERE clause was simply never refactored after that decision.
#   Corrected in tools/opda-gen (shapes.py) to traverse
#   prov:qualifiedAssociation -> prov:Association -> prov:hadPlan ->
#   opda:plannedAtTime, matching this mapping's own triple shape exactly.
#   Verified: the rule's corrected WHERE clause returns the right variance
#   (24 days) when run directly against a scratch instance's materialised
#   triples.
#
#   None of testdata/01-04 carry any "milestones" data (verified via direct
#   JSON inspection); path-verified via a scratch instance instead, matching
#   the established, accepted precedent elsewhere in this mapping (M1's own
#   opda:response comment) for leaves the shipped fixtures don't exercise.
# ---------------------------------------------------------------------------

# --- INSTANT milestones: listed, soldSubjectToContract, exchangeOfContracts

<#MilestoneListed> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/listed-{milestones.listed.completed}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId (join back to M1's opda:Transaction node)
  rr:predicateObjectMap [ rr:predicate prov:atTime ;
      rr:objectMap [ rml:reference "milestones.listed.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.listed.completed
  rr:predicateObjectMap [ rr:predicate opda:occurredAtTime ;
      rr:objectMap [ rml:reference "milestones.listed.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.listed.completed (opda-namespaced alias per its own rdfs:comment)
  rr:predicateObjectMap [ rr:predicate prov:qualifiedAssociation ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/listed/association-{milestones.listed.expected}" ] ] .  # <- milestones.listed.expected (independent gate; join to <#MilestoneListedAssociation>)

<#MilestoneListedAssociation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/listed/association-{milestones.listed.expected}" ;
                  rr:class prov:Association ] ;
  rr:predicateObjectMap [ rr:predicate prov:hadPlan ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/listed/plan-{milestones.listed.expected}" ] ] .

<#MilestoneListedPlan> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/listed/plan-{milestones.listed.expected}" ;
                  rr:class prov:Plan ] ;
  rr:predicateObjectMap [ rr:predicate opda:plannedAtTime ;
      rr:objectMap [ rml:reference "milestones.listed.expected" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.listed.expected

<#MilestoneSoldSubjectToContract> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/soldSubjectToContract-{milestones.soldSubjectToContract.completed}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId
  rr:predicateObjectMap [ rr:predicate prov:atTime ;
      rr:objectMap [ rml:reference "milestones.soldSubjectToContract.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.soldSubjectToContract.completed
  rr:predicateObjectMap [ rr:predicate opda:occurredAtTime ;
      rr:objectMap [ rml:reference "milestones.soldSubjectToContract.completed" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.soldSubjectToContract.completed (no "expected" in this milestone's schema shape — no Plan chain)

<#MilestoneExchangeOfContracts> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/exchangeOfContracts-{milestones.exchangeOfContracts.completed}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId
  rr:predicateObjectMap [ rr:predicate prov:atTime ;
      rr:objectMap [ rml:reference "milestones.exchangeOfContracts.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.exchangeOfContracts.completed
  rr:predicateObjectMap [ rr:predicate opda:occurredAtTime ;
      rr:objectMap [ rml:reference "milestones.exchangeOfContracts.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.exchangeOfContracts.completed
  rr:predicateObjectMap [ rr:predicate prov:qualifiedAssociation ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/exchangeOfContracts/association-{milestones.exchangeOfContracts.expected}" ] ] .  # <- milestones.exchangeOfContracts.expected

<#MilestoneExchangeOfContractsAssociation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/exchangeOfContracts/association-{milestones.exchangeOfContracts.expected}" ;
                  rr:class prov:Association ] ;
  rr:predicateObjectMap [ rr:predicate prov:hadPlan ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/exchangeOfContracts/plan-{milestones.exchangeOfContracts.expected}" ] ] .

<#MilestoneExchangeOfContractsPlan> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/exchangeOfContracts/plan-{milestones.exchangeOfContracts.expected}" ;
                  rr:class prov:Plan ] ;
  rr:predicateObjectMap [ rr:predicate opda:plannedAtTime ;
      rr:objectMap [ rml:reference "milestones.exchangeOfContracts.expected" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.exchangeOfContracts.expected

# --- INTERVAL milestones: legalForms, searches, enquiries, completion

<#MilestoneLegalForms> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/legalForms-{milestones.legalForms.started}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId
  rr:predicateObjectMap [ rr:predicate prov:startedAtTime ;
      rr:objectMap [ rml:reference "milestones.legalForms.started" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.legalForms.started
  rr:predicateObjectMap [ rr:predicate prov:endedAtTime ;
      rr:objectMap [ rml:reference "milestones.legalForms.completed" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.legalForms.completed (independent optional field; no "expected" in this milestone's schema shape)

<#MilestoneSearches> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/searches-{milestones.searches.started}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId
  rr:predicateObjectMap [ rr:predicate prov:startedAtTime ;
      rr:objectMap [ rml:reference "milestones.searches.started" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.searches.started
  rr:predicateObjectMap [ rr:predicate prov:endedAtTime ;
      rr:objectMap [ rml:reference "milestones.searches.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.searches.completed
  rr:predicateObjectMap [ rr:predicate prov:qualifiedAssociation ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/searches/association-{milestones.searches.expected}" ] ] .  # <- milestones.searches.expected

<#MilestoneSearchesAssociation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/searches/association-{milestones.searches.expected}" ;
                  rr:class prov:Association ] ;
  rr:predicateObjectMap [ rr:predicate prov:hadPlan ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/searches/plan-{milestones.searches.expected}" ] ] .

<#MilestoneSearchesPlan> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/searches/plan-{milestones.searches.expected}" ;
                  rr:class prov:Plan ] ;
  rr:predicateObjectMap [ rr:predicate opda:plannedAtTime ;
      rr:objectMap [ rml:reference "milestones.searches.expected" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.searches.expected

<#MilestoneEnquiries> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/enquiries-{milestones.enquiries.started}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId
  rr:predicateObjectMap [ rr:predicate prov:startedAtTime ;
      rr:objectMap [ rml:reference "milestones.enquiries.started" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.enquiries.started
  rr:predicateObjectMap [ rr:predicate prov:endedAtTime ;
      rr:objectMap [ rml:reference "milestones.enquiries.completed" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.enquiries.completed (no "expected" in this milestone's schema shape)

<#MilestoneCompletion> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/completion-{milestones.completion.started}" ;
                  rr:class opda:Milestone ] ;
  rr:predicateObjectMap [ rr:predicate opda:partOfTransaction ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ] ] ;  # <- transactionId
  rr:predicateObjectMap [ rr:predicate prov:startedAtTime ;
      rr:objectMap [ rml:reference "milestones.completion.started" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.completion.started
  rr:predicateObjectMap [ rr:predicate prov:endedAtTime ;
      rr:objectMap [ rml:reference "milestones.completion.completed" ; rr:datatype xsd:dateTime ] ] ;  # <- milestones.completion.completed
  rr:predicateObjectMap [ rr:predicate prov:qualifiedAssociation ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/completion/association-{milestones.completion.expected}" ] ] .  # <- milestones.completion.expected

<#MilestoneCompletionAssociation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/completion/association-{milestones.completion.expected}" ;
                  rr:class prov:Association ] ;
  rr:predicateObjectMap [ rr:predicate prov:hadPlan ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/completion/plan-{milestones.completion.expected}" ] ] .

<#MilestoneCompletionPlan> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}/milestone/completion/plan-{milestones.completion.expected}" ;
                  rr:class prov:Plan ] ;
  rr:predicateObjectMap [ rr:predicate opda:plannedAtTime ;
      rr:objectMap [ rml:reference "milestones.completion.expected" ; rr:datatype xsd:dateTime ] ] .  # <- milestones.completion.expected

# ---------------------------------------------------------------------------
# M33 — Claim / Evidence / VerificationActivity (opda-claim.ttl / ODR-0009)
#   iterator: participants[*] (same as M2/M3/M3b).
#   Real JSON: participants[].verification.{identity,antiMoneyLaundering} —
#   each has a top-level .result (pass/fail/consider) AND a .reports[] array
#   (reportName/result/details per report).
#
#   GRANULARITY — a real, empirically-forced design decision, not a
#   preference: per-REPORT Claim/Evidence nodes (one per reports[] item) were
#   attempted first and REJECTED after empirical testing exposed a serious
#   RMLMapper defect, not just a missing feature:
#     - A genuine per-element TriplesMap at the deep iterator
#       ($.participants[*].verification.identity.reports[*]) gives correct,
#       uncorrupted per-report access (reportName/result pair up correctly)
#       but CANNOT reach the enclosing participant's own "email" — confirmed
#       empirically (neither a relative "email" nor an absolute "$.email"
#       reference resolves an ancestor field from within a nested iterator).
#       Without "email", two different participants' identically-named
#       reports (plausible in practice — the same automated check service
#       often reuses the same reportName for every participant) would
#       collide into the same IRI.
#     - The obvious workaround — iterate at the shallow $.participants[*]
#       level (which HAS "email") and reach into reports[*] via
#       ARRAY-PROJECTED placeholders for both the subject (reportName) and a
#       property (result) — was tested and found to silently CROSS-PRODUCT:
#       2 reports produced 4 triples, each report wrongly wasDerivedFrom-
#       linked to the OTHER report's Evidence too, not just its own (verified
#       with a minimal scratch mapping + RMLMapper 8.1.0 directly, isolated
#       from this file). This holds even when every placeholder in the
#       TriplesMap uses the IDENTICAL JSONPath reference string — RMLMapper
#       does not deduplicate/zip multiple array-projected slots by position;
#       it cross-products whenever a TriplesMap has more than one place
#       where a multi-valued array is projected. This is DIFFERENT from (and
#       more dangerous than) the single-placeholder array-projection idiom
#       ADR-0057 already documents as safe (M1's opda:concerns,
#       opda:hasChainPosition above, etc., each use exactly ONE varying
#       placeholder per TriplesMap) — silently WRONG data, not just missing
#       data. Not previously documented in ADR-0057; recorded here and
#       should be added to its Amendments.
#   Given neither approach is both correct AND participant-disambiguating,
#   this cluster is modelled at CATEGORY granularity instead: one
#   opda:Claim + one opda:Evidence + one opda:VerificationActivity per
#   participant per verification category (identity / antiMoneyLaundering),
#   keyed on {email} + the category's own top-level .result (present exactly
#   when the category was actually assessed — the standard skip-together
#   technique, ADR-0057 Amendment 1). This is SAFE because every placeholder
#   in each TriplesMap resolves the SAME single SCALAR (never an array) —
#   verified empirically (a scalar reused across a subject and multiple
#   predicateObjectMaps behaves correctly, no cross-product risk applies to
#   non-array references). Individual reports[].reportName/.result/.details
#   are NOT separately addressable under this constraint; there is also no
#   opda: predicate for them regardless (see below), so nothing is lost by
#   not reaching per-report granularity.
#
#   opda:evidenceType / opda:attestedBy / opda:digest are DELIBERATELY NOT
#   mapped — a genuine, flagged design question, not an oversight:
#     - opda:evidenceType's value-space (opda:EvidenceMethodScheme:
#       Document / Electronic-Record / Vouch, per OIDC4IDA) is NOT honestly
#       derivable from this data. The real field that DOES carry exactly
#       that 3-way enum is a DIFFERENT, standalone PDTF schema —
#       source/03-standards/schemas/.../verifiedClaims/pdtf-verified-
#       claims.json's verification.evidence[].type — confirmed NOT embedded
#       in a pdtf-transaction.json instance (no $ref from the transaction
#       schema to it) and therefore out of ODR-0035's single-PDTF-instance
#       mapping scope. The participants[].verification.*.reports[].
#       reportName field actually available here is a free-text service
#       name (e.g. "electoral-roll-check") that does not disclose the
#       acquisition kind. Guessing a reportName -> evidenceType mapping was
#       rejected per this session's discipline (flag, don't fabricate).
#     - opda:attestedBy (Vouch-only, EvidenceFacetShape) and opda:digest
#       (no cryptographic hash anywhere in this schema's verification
#       structure) have no real source data regardless of the evidenceType
#       question.
#     - The per-report/per-category `result` (pass/fail/consider) itself
#       ALSO has nowhere to land: no opda: predicate carries a Claim's or a
#       VerificationActivity's own verdict/outcome value at all — a real,
#       separate ontology gap (out of this task's scope to fix). The
#       `.result` field is used ONLY as an existence-gate placeholder here,
#       its value is not otherwise asserted as a triple (other than being
#       baked into the node's own IRI, matching the M24 peril/{value}
#       precedent).
#
#   None of testdata/01-04 carry any "verification" data (verified via
#   direct JSON inspection); path-verified via a scratch instance instead,
#   matching the established, accepted precedent used elsewhere in this
#   mapping (M1's own opda:response comment) for leaves the shipped fixtures
#   don't exercise.
#
#   opda:TrustFramework — CLOSED (2026-07-04): every opda:VerificationActivity
#   here asserts dct:conformsTo opda:UKPropertyDataTrustFramework (below,
#   <#UKPropertyDataTrustFramework> mints that IRI as a real opda:TrustFramework
#   instance). This is a fixed CONSTANT, not data extraction — no PDTF field
#   states which trust framework governs a transaction — but it is not a
#   fabrication: the exact same IRI is already used identically in 3 ratified
#   exemplars (claim-with-{document,electronic-record,vouch}-evidence.ttl),
#   and Council session-003c Item 3 ("OPDA TF authoritative scope") ratifies
#   that every transaction processed under this schema is, by definition,
#   governed by the OPDA/UK Property Data Trust Framework.
#
#   opda:AssuranceLevel — DELIBERATELY NOT mapped, a genuine gap, not an
#   oversight: its value-space (eIDAS Low/Substantial/High) grades the RIGOR
#   of a verification METHOD, whereas the real field available
#   (participants[].verification.*.result / reports[].result: pass/fail/
#   consider) is an OUTCOME judgement on a different axis entirely — a "pass"
#   from a low-rigor check is not automatically "Substantial" assurance, and
#   "fail"/"consider" have no eIDAS-level equivalent at all. Mapping
#   result -> assuranceLevel would assert a compliance-consequential judgement
#   the source data does not honestly support (unlike TrustFramework's
#   constant above, which asserts an always-true institutional fact, not a
#   per-instance judgement). Left unmapped per this session's discipline
#   (flag, don't fabricate).
#
#   opda:Verifier — NOT instantiated here, a confirmed gap, checked directly
#   against both schemas rather than assumed: ODR-0009's qualified-attribution
#   rule ("Qualified attribution (verifier-as-prov:Agent)") names the real
#   field it expects — `verifier.organization` (prov:Organization) / a human
#   voucher (prov:Person), attributed via prov:qualifiedAttribution ->
#   prov:Attribution + prov:hadRole. That `verifier`/`verifier.organization`/
#   `verifier.txn` field IS real (confirmed by direct grep — it appears 4x in
#   src/schemas/verifiedClaims/pdtf-verified-claims.json, once per evidence-
#   type sub-schema and its EvidenceOf variant, always paired with
#   organization/txn) — but it lives in the OTHER envelope, the one M33's own
#   comment above already established is NOT $ref'd from pdtf-
#   transaction.json anywhere (same check that ruled out evidenceType) and is
#   therefore out of ODR-0035's single-PDTF-instance mapping scope. Within
#   pdtf-transaction.json itself, participants[].verification.
#   {identity,antiMoneyLaundering} and its reports[] carry only result
#   (pass/fail/consider, category- and per-report-level), reportName
#   (free-text service name) and details — verified directly against the
#   schema (lines ~195-269), not assumed from field names: no organisation,
#   person, vendor or service-provider leaf exists anywhere in that subtree
#   that could honestly be read as "the agent that performed this
#   verification". participants[].organisation (the one organisation-shaped
#   field participants[*] does carry) is the PARTICIPANT's own affiliation
#   (Seller/Buyer/Conveyancer etc., already bound above to opda:Organisation
#   for that purpose) — not the verifying agent, and reusing it as one would
#   assert a role it does not hold. No opda:Verifier node is minted by this
#   mapping; the class stands in opda-claim.ttl with no instance data
#   reachable from a single pdtf-transaction.json instance to populate it.
# ---------------------------------------------------------------------------

<#IdentityClaim> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.participants[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/identity-{verification.identity.result}" ;
                  rr:class opda:Claim ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasDerivedFrom ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/identity-{verification.identity.result}/evidence" ] ] ;  # <- participants[].verification.identity (container; class-instantiating join). SHACL: UnprovenancedClaimShape requires prov:wasDerivedFrom (minCount 1, Violation)
  rr:predicateObjectMap [ rr:predicate opda:supportedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/identity-{verification.identity.result}/evidence" ] ] ;  # <- participants[].verification.identity (opda-namespaced counterpart to prov:wasDerivedFrom, same target, per its own rdfs:comment)
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/identity-{verification.identity.result}/run" ] ] .  # <- participants[].verification.identity.result (existence gate; join to <#IdentityVerificationActivity>)

<#IdentityEvidence> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.participants[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/identity-{verification.identity.result}/evidence" ;
                  rr:class opda:Evidence ] .  # <- participants[].verification.identity (reports[] bundle; opda:evidenceType/opda:attestedBy/opda:digest deliberately unmapped, see comment above)

<#IdentityVerificationActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.participants[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/identity-{verification.identity.result}/run" ;
                  rr:class opda:VerificationActivity ] ;  # <- participants[].verification.identity.result (prov:wasGeneratedBy's range is prov:Activity; opda:VerificationActivity is rdfs:subClassOf prov:Activity — type the referenced node, EPC/Search precedent)
  rr:predicateObjectMap [ rr:predicate dct:conformsTo ;
      rr:object opda:UKPropertyDataTrustFramework ] .  # constant (see M33's own comment: precedented 3x in ratified exemplars, Session 003c "OPDA TF authoritative scope")

<#AntiMoneyLaunderingClaim> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.participants[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/antiMoneyLaundering-{verification.antiMoneyLaundering.result}" ;
                  rr:class opda:Claim ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasDerivedFrom ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/antiMoneyLaundering-{verification.antiMoneyLaundering.result}/evidence" ] ] ;  # <- participants[].verification.antiMoneyLaundering (container; class-instantiating join). SHACL: UnprovenancedClaimShape requires prov:wasDerivedFrom (minCount 1, Violation)
  rr:predicateObjectMap [ rr:predicate opda:supportedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/antiMoneyLaundering-{verification.antiMoneyLaundering.result}/evidence" ] ] ;  # <- participants[].verification.antiMoneyLaundering (opda-namespaced counterpart to prov:wasDerivedFrom, same target)
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/antiMoneyLaundering-{verification.antiMoneyLaundering.result}/run" ] ] .  # <- participants[].verification.antiMoneyLaundering.result (existence gate; join to <#AntiMoneyLaunderingVerificationActivity>)

<#AntiMoneyLaunderingEvidence> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.participants[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/antiMoneyLaundering-{verification.antiMoneyLaundering.result}/evidence" ;
                  rr:class opda:Evidence ] .  # <- participants[].verification.antiMoneyLaundering (reports[] bundle; opda:evidenceType/opda:attestedBy/opda:digest deliberately unmapped, see comment above)

<#AntiMoneyLaunderingVerificationActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.participants[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/claim/{email}/antiMoneyLaundering-{verification.antiMoneyLaundering.result}/run" ;
                  rr:class opda:VerificationActivity ] ;  # <- participants[].verification.antiMoneyLaundering.result (prov:wasGeneratedBy's range is prov:Activity; type the referenced node, EPC/Search precedent)
  rr:predicateObjectMap [ rr:predicate dct:conformsTo ;
      rr:object opda:UKPropertyDataTrustFramework ] .  # constant (see M33's own comment: precedented 3x in ratified exemplars, Session 003c "OPDA TF authoritative scope")

<#UKPropertyDataTrustFramework> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ; rml:iterator "$" ] ;
  rr:subjectMap [ rr:constant opda:UKPropertyDataTrustFramework ;
                  rr:class opda:TrustFramework ] .  # closes the opda:TrustFramework CLASS gap — a fixed, always-true institutional fact (every VerificationActivity in this dataset is governed by the OPDA/UK PDTF), not data extraction; the same IRI already used via dct:conformsTo in 3 ratified exemplars (claim-with-{document,electronic-record,vouch}-evidence.ttl)

# ---------------------------------------------------------------------------
# M34 — opda:Address (ODR-0015, unblocked 2026-07-05 once opda-gen declared
#   line1/line2/postTown/postcode/country/inspireFeatureId as real properties
#   — see ADR-0057 Amendments, 2026-07-05 entry). Two of the ~9 real PDTF
#   address occurrences honestly fit one of the 3 closed addressVariant
#   values ("title"|"marketing"|"inspire"); the rest do not and are left
#   unmapped (see the "NOT mapped" note below, not a gap register entry —
#   these are checked-and-rejected, not overlooked).
#
#   "marketing" — propertyPack.address. ODR-0015's own Decision Outcome
#   (§More Information) names propertyPack.address / titleAddress /
#   marketingAddress as the three addresses it settles; the real v3 schema
#   has no literal titleAddress/marketingAddress leaves (the ODR's naming
#   predates the current schema revision), so by elimination against the
#   other two variants: titlesToBeSold[].registerExtract...propertyAddress
#   is unambiguously the HMLR register extract ("title"), and inspire has NO
#   real source field anywhere in pdtf-transaction.json (confirmed by direct
#   grep — no "inspireId"/"inspireFeatureId" leaf exists in v3). That leaves
#   propertyPack.address — schema title "Property Address", no HMLR/INSPIRE
#   framing in its own text — as the property's general/display address,
#   which is the "marketing" slot by elimination and by real-world PDTF
#   convention (the property-portal/listing-agent-populated address used
#   across the transaction, distinct from the register-held one).
#
#   "title" — propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.
#   propertyAddress. Confirmed via schema traversal: titlesToBeSold's own
#   title is "Title(s) as registered with HMLR" and registerExtract's is
#   "HMLR Official Copy Register Extract" — this is unambiguously the
#   register-held address, honestly "title".
#
#   Both keyed from M4's own $.propertyPack iterator (NOT a nested
#   titlesToBeSold[*]/participants[*] iterator) so the join back to
#   <#Property> (keyed on {uprn}) needs no ancestor-context jump — the same
#   constraint M33's own comment documents as a genuine RMLMapper limitation
#   (no relative OR absolute reference reaches an ancestor field from within
#   a nested iterator). <#PropertyTitleAddress> reaches into
#   titlesToBeSold[0] by a fixed array index from that shared root, matching
#   M9's own titleNumber-keying precedent; this only binds the FIRST title's
#   address on a multi-title property (a documented simplification, not a
#   correctness bug — multi-title properties are rare and no test fixture
#   exercises one).
#
#   registerExtract.ocSummaryData.propertyAddress is schema oneOf(single
#   object | array of objects); testdata/01-conformant-full exercises the
#   array form with a genuinely heterogeneous split — one item carries only
#   postcodeZone, the other only addressLine (verified via direct JSON
#   inspection, not assumed) — so a fixed-index reference into the array
#   would silently miss whichever facet isn't at that index. Handled with
#   the ADR-0057 Amendment 1 filter technique (bare existence-test filters
#   ARE proven safe on arrays under RMLMapper/Jayway, per M1's own
#   opda:concerns precedent): one predicateObjectMap per predicate keyed on
#   `[?(@.postcodeZone)]`/`[?(@.addressLine)]` for the array shape, plus a
#   second, dot-path predicateObjectMap for the plain-object oneOf branch
#   (a dotted reference through what's actually an array throws
#   PathNotFoundException under Jayway JsonPath, per ADR-0057 Amendment 4 —
#   caught per-reference the same way every other optional-field reference
#   in this mapping degrades to "no triple", not a crash; only one of the
#   two shapes can ever match a given real instance, so no double-binding
#   risk). opda:postTown/opda:country have no source data in this register-
#   extract region (no town/country leaf anywhere under ocSummaryData) and
#   are correctly left unbound for the "title" variant.
#
#   NOT mapped (checked against real schema title/description text, not
#   assumed from field names — this session's established discipline):
#     - participants[].address — schema title "Address", no authority
#       framing; this is a participant's own home/contact address, not an
#       HMLR/listing-agent/INSPIRE artefact. Does not honestly fit any of
#       the 3 closed addressVariant values.
#     - propertyPack.nearbyFacilities.{schools,healthCare}[*].contact.address
#       — schema title "Address", same reasoning: a facility's own contact
#       address, not one of the 3 authority variants.
#     - propertyPack.localSearches.localLandCharges[*].applicantAddress,
#       titlesToBeSold[*].registerExtract...leaseParty[*].address,
#       ...charityDetails.charityAddress, surveys[*].declaration.
#       companyAddress — all party-contact addresses (LLC applicant, lease
#       party, charity, surveying company) embedded inside the HMLR register
#       extract's OWN substructure, not the Property's address; binding them
#       would additionally require minting Person/Organisation nodes for
#       each party, a separate, deeper gap outside this batch's scope.
#   None of the above invent a plausible-sounding tag to force required-
#   field satisfaction (CONTRACT's bind-only-what-exists discipline); they
#   are genuinely not addressVariant-shaped data.
# ---------------------------------------------------------------------------
<#PropertyMarketingAddress> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/address/marketing-{uprn}-{address.line1}" ;
                  rr:class opda:Address ] ;
  rr:predicateObjectMap [ rr:predicate opda:addressVariant ;
      rr:objectMap [ rr:constant "marketing" ] ] ;
  rr:predicateObjectMap [ rr:predicate opda:line1 ;
      rr:objectMap [ rml:reference "address.line1" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.address.line1
  rr:predicateObjectMap [ rr:predicate opda:line2 ;
      rr:objectMap [ rml:reference "address.line2" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.address.line2
  rr:predicateObjectMap [ rr:predicate opda:postTown ;
      rr:objectMap [ rml:reference "address.town" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.address.town
  rr:predicateObjectMap [ rr:predicate opda:postcode ;
      rr:objectMap [ rml:reference "address.postcode" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.address.postcode
  rr:predicateObjectMap [ rr:predicate opda:country ;
      rr:objectMap [ rml:reference "address.countryCode" ; rr:datatype xsd:string ] ] .  # <- propertyPack.address.countryCode (ISO 3166-1 alpha-3; buildingNumber/buildingName/subBuilding/street/line3/homeNation have no opda:Address structural-field target — genuine layer-2 sub-gap, CONTRACT's "address parts" callout)

<#PropertyMarketingAddressJoin> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasAddress ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/address/marketing-{uprn}-{address.line1}" ] ] .  # <- propertyPack.address (container; class-instantiating join, same PropertyEPCJoin idiom as M4a)

<#PropertyTitleAddress> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/address/title-{titlesToBeSold[0].titleNumber}" ;
                  rr:class opda:Address ] ;
  rr:predicateObjectMap [ rr:predicate opda:addressVariant ;
      rr:objectMap [ rr:constant "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate opda:postcode ;
      rr:objectMap [ rml:reference "titlesToBeSold[0].registerExtract.ocSummaryData.propertyAddress[?(@.postcodeZone)].postcodeZone.postcode" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.propertyAddress[].postcodeZone.postcode (array oneOf branch; ADR-0057 Amendment 1 filter technique)
  rr:predicateObjectMap [ rr:predicate opda:postcode ;
      rr:objectMap [ rml:reference "titlesToBeSold[0].registerExtract.ocSummaryData.propertyAddress.postcodeZone.postcode" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.propertyAddress.postcodeZone.postcode (plain-object oneOf branch)
  rr:predicateObjectMap [ rr:predicate opda:line1 ;
      rr:objectMap [ rml:reference "titlesToBeSold[0].registerExtract.ocSummaryData.propertyAddress[?(@.addressLine)].addressLine.line[0]" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.propertyAddress[].addressLine.line (array oneOf branch, first line)
  rr:predicateObjectMap [ rr:predicate opda:line1 ;
      rr:objectMap [ rml:reference "titlesToBeSold[0].registerExtract.ocSummaryData.propertyAddress.addressLine.line[0]" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.propertyAddress.addressLine.line (plain-object oneOf branch, first line)
  rr:predicateObjectMap [ rr:predicate opda:line2 ;
      rr:objectMap [ rml:reference "titlesToBeSold[0].registerExtract.ocSummaryData.propertyAddress[?(@.addressLine)].addressLine.line[1]" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.propertyAddress[].addressLine.line (array oneOf branch, second line)
  rr:predicateObjectMap [ rr:predicate opda:line2 ;
      rr:objectMap [ rml:reference "titlesToBeSold[0].registerExtract.ocSummaryData.propertyAddress.addressLine.line[1]" ; rr:datatype xsd:string ] ] .  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.propertyAddress.addressLine.line (plain-object oneOf branch, second line)

<#PropertyTitleAddressJoin> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasAddress ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/address/title-{titlesToBeSold[0].titleNumber}" ] ] .  # <- propertyPack.titlesToBeSold[0].titleNumber (container; class-instantiating join, same PropertyEPCJoin idiom as M4a)

