        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.typeOfConstruction.sprayFoamInsulation.hasSprayFoamInstalled
  rr:predicateObjectMap [ rr:predicate opda:hasValidGuaranteesOrWarranties ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "guaranteesWarrantiesAndIndemnityInsurances.hasValidGuaranteesOrWarranties" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.guaranteesWarrantiesAndIndemnityInsurances.hasValidGuaranteesOrWarranties
  rr:predicateObjectMap [ rr:predicate opda:isLocatedOverCommercialPremises ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "buildInformation.building.overCommercialPremises.isLocatedOverCommercialPremises" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.buildInformation.building.overCommercialPremises.isLocatedOverCommercialPremises
  rr:predicateObjectMap [ rr:predicate opda:isSupplyMetered ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "waterAndDrainage.water.mainsWater.waterMeter.isSupplyMetered" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.waterAndDrainage.water.mainsWater.waterMeter.isSupplyMetered
  rr:predicateObjectMap [ rr:predicate opda:areBoundariesUniform ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "legalBoundaries.ownership.areBoundariesUniform" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.legalBoundaries.ownership.areBoundariesUniform
  rr:predicateObjectMap [ rr:predicate opda:soldWithVacantPossession ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "occupiers.othersAged17OrOver.vacantPossession.soldWithVacantPossession" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.occupiers.othersAged17OrOver.vacantPossession.soldWithVacantPossession
  rr:predicateObjectMap [ rr:predicate opda:offMainsDrainageSystemType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "waterAndDrainage.drainage.mainsFoulDrainage.offMainsDrainageSystem.offMainsDrainageSystemType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "offMainsDrainageSystemType" ] ] ] ] ] ;  # <- propertyPack.waterAndDrainage.drainage.mainsFoulDrainage.offMainsDrainageSystem.offMainsDrainageSystemType
  rr:predicateObjectMap [ rr:predicate opda:propertyType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "buildInformation.building.propertyType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "propertyType" ] ] ] ] ] ;  # <- propertyPack.buildInformation.building.propertyType
  rr:predicateObjectMap [ rr:predicate opda:builtForm ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "buildInformation.building.builtForm" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "builtForm" ] ] ] ] ] ;  # <- propertyPack.buildInformation.building.builtForm
  rr:predicateObjectMap [ rr:predicate opda:priceQualifier ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "priceInformation.priceQualifier" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "priceQualifier" ] ] ] ] ] ;  # <- propertyPack.priceInformation.priceQualifier
  rr:predicateObjectMap [ rr:predicate opda:currentEnergyRating ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "energyEfficiency.certificate.currentEnergyRating" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "currentEnergyRating" ] ] ] ] ] ;  # <- propertyPack.energyEfficiency.certificate.currentEnergyRating
  rr:predicateObjectMap [ rr:predicate opda:typeOfConnection ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "connectivity.broadband.typeOfConnection" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "broadbandConnectionType" ] ] ] ] ] ;  # <- propertyPack.connectivity.broadband.typeOfConnection
  rr:predicateObjectMap [ rr:predicate opda:centralHeatingFuelType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.centralHeatingFuelType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "centralHeatingFuelType" ] ] ] ] ] ;  # <- propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.centralHeatingFuelType
  rr:predicateObjectMap [ rr:predicate opda:heatingType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "heating.heatingSystem.heatingType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "heatingType" ] ] ] ] ] ;  # <- propertyPack.heating.heatingSystem.heatingType
  rr:predicateObjectMap [ rr:predicate opda:marketingTenure ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "marketingTenure" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "tenureKind" ] ] ] ] ] .  # <- propertyPack.marketingTenure (reuses TenureKindScheme, ODR-0024 R6)

# M30a — LegalEstate-domain FNML enums (ownershipsToBeTransferred[*], same
#   iterator/subject as M7's <#LegalEstate>).
<#LegalEstate_FNMLEnums> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:isSharedOwnership ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "leaseholdInformation.sharedOwnership.isSharedOwnership" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- …leaseholdInformation.sharedOwnership.isSharedOwnership
  rr:predicateObjectMap [ rr:predicate opda:isGroundRentPayable ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "leaseholdInformation.groundRent.isGroundRentPayable" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- …leaseholdInformation.groundRent.isGroundRentPayable
  rr:predicateObjectMap [ rr:predicate opda:sellerContributesToServiceCharge ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "leaseholdInformation.serviceCharge.sellerContributesToServiceCharge" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- …leaseholdInformation.serviceCharge.sellerContributesToServiceCharge
  rr:predicateObjectMap [ rr:predicate opda:ownershipType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "ownershipType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "ownershipType" ] ] ] ] ] .  # <- propertyPack.ownership.ownershipsToBeTransferred[].ownershipType

# ---------------------------------------------------------------------------
# M31 — Fixtures-and-fittings item (propertyPack.fixturesAndFittings.
#   basicFittings.boilerImmersionHeater, representative of ~90 structurally
#   identical items across basicFittings/kitchen/bathroom/carpets/etc.) —
#   domain-less opda:price (xsd:decimal) and opda:inclusionStatus
#   (rdfs:range skos:Concept, opda:InclusionStatusScheme — Included/
#   Excluded/None). Per ODR-0022's own inclusionStatus comment: "bound on a
#   transaction-scoped fixtures-list node (NEVER rdfs:domain opda:Property)"
#   — this item object has no field of its own to key on (no name/id, only
#   isIncludedExcludedOrNone/comments/price), but it's a SINGLE, non-array
#   JSON object (one per file), so a genuinely CONSTANT subject IRI (no
#   template placeholder at all) is honest and correct — the iterator
#   naturally yields zero rows when the item is absent from an instance,
#   one row when present; no fabricated identity needed. Same untyped-node
#   reasoning as M1b/M12 (a bearer exists, deliberately not typed
#   opda:Property). opda:inclusionStatus uses the M30 FNML mechanism (single-
#   object context, same as M30's other properties).
#   Only ONE of the ~90 structurally identical fixturesAndFittings items is
#   bound here (matching the opda:supplier/opda:location precedent of
#   tracing a representative real occurrence, not literally all ~90).
# ---------------------------------------------------------------------------
<#FixturesBoilerImmersionHeater> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.fixturesAndFittings.basicFittings.boilerImmersionHeater" ] ;
  rr:subjectMap [ rr:constant <https://opda.org.uk/pdtf/harness/data/fixtures/boilerImmersionHeater> ] ;
  rr:predicateObjectMap [ rr:predicate opda:price ;
      rr:objectMap [ rml:reference "price" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.fixturesAndFittings.basicFittings.boilerImmersionHeater.price
  rr:predicateObjectMap [ rr:predicate opda:inclusionStatus ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "isIncludedExcludedOrNone" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "inclusionStatus" ] ] ] ] ] .  # <- propertyPack.fixturesAndFittings.basicFittings.boilerImmersionHeater.isIncludedExcludedOrNone

