  rr:predicateObjectMap [ rr:predicate opda:mpan ;
      rr:objectMap [ rml:reference "electricity.mainsElectricity.electricityMeter.mpan" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.electricity.mainsElectricity.electricityMeter.mpan
  rr:predicateObjectMap [ rr:predicate opda:yearInstalled ;
      rr:objectMap [ rml:reference "electricity.solarPanels.yearInstalled" ; rr:datatype xsd:gYear ] ] ;  # <- propertyPack.electricity.solarPanels.yearInstalled
  rr:predicateObjectMap [ rr:predicate opda:annualCostOfPermit ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/parkingPermit-{parking.controlledParking.annualCostOfPermit}" ] ] ;  # <- propertyPack.parking.controlledParking.annualCostOfPermit (MonetaryAmount join, see M4d)
  rr:predicateObjectMap [ rr:predicate opda:holdingDeposit ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/holdingDeposit-{lettingInformation.holdingDeposit}" ] ] ;  # <- propertyPack.lettingInformation.holdingDeposit (MonetaryAmount join, see M4e)
  rr:predicateObjectMap [ rr:predicate opda:rent ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/rent-{lettingInformation.rent}" ] ] ;  # <- propertyPack.lettingInformation.rent (MonetaryAmount join, see M4e)
  rr:predicateObjectMap [ rr:predicate opda:securityDeposit ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/securityDeposit-{lettingInformation.securityDeposit}" ] ] ;  # <- propertyPack.lettingInformation.securityDeposit (MonetaryAmount join, see M4e)
  rr:predicateObjectMap [ rr:predicate opda:hasRoomDimension ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/room/{buildInformation.roomDimensions.rooms.roomName}" ] ] ;  # <- propertyPack.buildInformation.roomDimensions.rooms[] (array-projected rr:template join to M15's RoomDimension node, the same technique proven for opda:hasParticipant/opda:concerns — supersedes M15's old "no shared key" note, which predates the dropna-bug fix and only tried a bracket-indexed rooms[0] reference)
  rr:predicateObjectMap [ rr:predicate opda:constructionType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "surveys.misc.constructionType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "constructionType" ] ] ] ] ] .  # <- propertyPack.surveys[].misc.constructionType (M18: array-projected reference + M30's FNML mechanism; see M18's comment for the "not exercised by 01-04" caveat)

# ---------------------------------------------------------------------------
# M4e — lettingInformation MonetaryAmount value nodes (holdingDeposit, rent,
#   securityDeposit). Same optional-field-in-template technique as M4b/M4d.
# ---------------------------------------------------------------------------
<#HoldingDepositAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/holdingDeposit-{lettingInformation.holdingDeposit}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "lettingInformation.holdingDeposit" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.lettingInformation.holdingDeposit
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#RentAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/rent-{lettingInformation.rent}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "lettingInformation.rent" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.lettingInformation.rent
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#SecurityDepositAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/securityDeposit-{lettingInformation.securityDeposit}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "lettingInformation.securityDeposit" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.lettingInformation.securityDeposit
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

# ---------------------------------------------------------------------------
# M4d — annualCostOfPermit MonetaryAmount value node. Same optional-field-in-
#   template technique as M4b (councilTaxAnnualCharge) — see that comment.
# ---------------------------------------------------------------------------
<#ParkingPermitAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/parkingPermit-{parking.controlledParking.annualCostOfPermit}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "parking.controlledParking.annualCostOfPermit" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.parking.controlledParking.annualCostOfPermit
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

# ---------------------------------------------------------------------------
# M4b — councilTaxAnnualCharge MonetaryAmount value node.
#   councilTaxAnnualCharge is OPTIONAL under the always-present $.propertyPack
#   object (unlike M7a's monetary joins, which iterate an ARRAY that is
#   naturally absent when there's no ownership data). JSONPath filter
#   brackets `[?(...)]` apply to ARRAYS, not single objects — they silently
#   match nothing when applied to a plain object regardless of the condition
#   inside (verified empirically: neither a bare-existence nor an explicit
#   numeric-comparison filter on the councilTax OBJECT produced any triples,
#   even when the field was genuinely present). The reliable technique
#   instead: embed the OPTIONAL field itself in the subject/object template's
#   placeholders — morph-kgc drops a triple/row when ANY placeholder in its
#   own template can't resolve, so keying on {councilTax.councilTaxAnnualCharge}
#   (not the always-present {uprn} alone) makes both this join (above, on M4)
#   and the value node below skip together, cleanly, whenever the field is
#   absent. (An earlier version keyed the value node on {uprn} alone,
#   asserting an empty opda:MonetaryAmount node whenever councilTaxAnnualCharge
#   was absent — a real SHACL violation caught by the instance-based harness.)
# ---------------------------------------------------------------------------
<#CouncilTaxAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}/amount/councilTax-{councilTax.councilTaxAnnualCharge}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "councilTax.councilTaxAnnualCharge" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.councilTax.councilTaxAnnualCharge
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

# ---------------------------------------------------------------------------
# M4c — Media (propertyPack.media[])  domain-less shared property, keyed on
#   the URL itself (a genuine array; morph-kgc needs a real per-element
#   iterator here — a flattened `media[].mediaUrl` reference from M4's own
#   $.propertyPack iterator was tried and empirically produced nothing).
# ---------------------------------------------------------------------------
<#Media> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.media[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/media/{mediaUrl}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:mediaUrl ;
      rr:objectMap [ rml:reference "mediaUrl" ; rr:datatype xsd:anyURI ] ] .  # <- propertyPack.media[].mediaUrl

# ---------------------------------------------------------------------------
# M4a — EPCCertificate (propertyPack.energyEfficiency.certificate)
#   opda:currentEnergyRating stays flat on Property (its rdfs:domain, above);
#   opda:hasEPCCertificate additionally reaches a distinct opda:EPCCertificate
#   PROV-O Entity node (10-year-lifecycle certificate artefact, ODR-0008 §Q4a).
#   EPCCertificateIdentityKeyShape REQUIRES prov:wasGeneratedBy (minCount 1,
#   Violation) — same class-promoted-IO pattern as M5/M6 Search, below.
#   opda:disclosureDetail carries the authority-reference IC component
#   (EPCCertificateInternalStructureShape sh:Info, ODR-0008d Rule 3).
#   Selected via a Darwin-Mode genome/paretoFront proof-of-concept (4 candidate
#   TriplesMap genomes scored by this harness; this is the sole Pareto-optimal
#   one — 0 violations, correctly typed+linked, IC component bound).
# ---------------------------------------------------------------------------
<#EPCCertificate> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.energyEfficiency.certificate" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/epc/{certificateNumber}" ;
                  rr:class opda:EPCCertificate ] ;
  rr:predicateObjectMap [ rr:predicate opda:disclosureDetail ;
      rr:objectMap [ rml:reference "certificateNumber" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.energyEfficiency.certificate.certificateNumber
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/epc/{certificateNumber}/run" ] ] .  # SHACL: class-promoted IO MUST carry prov:wasGeneratedBy (ODR-0008 §Q4a)

# prov:wasGeneratedBy's range is prov:Activity (PROV-O) — type the referenced
# node accordingly. A bare untyped IRI here was a real gap: sound in
# direction (Entity wasGeneratedBy Activity) but incomplete (the Activity
# itself was never described), caught by auditing external-vocabulary usage
# with the same rigor as opda: terms, not exempting it as "just PROV-O".
<#EPCCertificateRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.energyEfficiency.certificate" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/epc/{certificateNumber}/run" ;
                  rr:class prov:Activity ] .

<#PropertyEPCJoin> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasEPCCertificate ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/epc/{energyEfficiency.certificate.certificateNumber}" ] ] .  # <- propertyPack.energyEfficiency.certificate (container; class-instantiating join)

# ---------------------------------------------------------------------------
# M5 — Search (searches[])  (opda:Search)   iterator: propertyPack.searches[*]
#   opda:Search targetClass REQUIRES prov:wasGeneratedBy (minCount 1, Violation)
#   via the class-promotion identity-key shape — minted here.
# ---------------------------------------------------------------------------
<#Search> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.searches[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/{productCode}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/{productCode}/run" ] ] ;  # SHACL: class-promoted IO MUST carry prov:wasGeneratedBy (ODR-0008 §Q4a)
  rr:predicateObjectMap [ rr:predicate opda:displayName ;
      rr:objectMap [ rml:reference "displayName" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.searches[].displayName
  rr:predicateObjectMap [ rr:predicate opda:productCode ;
      rr:objectMap [ rml:reference "productCode" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.searches[].productCode
  rr:predicateObjectMap [ rr:predicate opda:providerName ;
      rr:objectMap [ rml:reference "providerName" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.searches[].providerName
  rr:predicateObjectMap [ rr:predicate opda:status ;
      rr:objectMap [ rml:reference "status" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.searches[].status
  rr:predicateObjectMap [ rr:predicate opda:orderDate ;
      rr:objectMap [ rml:reference "orderDate" ; rr:datatype xsd:date ] ] ;  # <- propertyPack.searches[].orderDate (dateTime lexical; see README)
  rr:predicateObjectMap [ rr:predicate opda:expectedDeliveryDate ;
      rr:objectMap [ rml:reference "expectedDeliveryDate" ; rr:datatype xsd:date ] ] ;  # <- propertyPack.searches[].expectedDeliveryDate (dateTime lexical; see README)
  rr:predicateObjectMap [ rr:predicate opda:reportDate ;
      rr:objectMap [ rml:reference "reportDate" ; rr:datatype xsd:date ] ] ;  # <- propertyPack.searches[].reportDate (dateTime lexical; see README)
  rr:predicateObjectMap [ rr:predicate opda:providerReference ;
      rr:objectMap [ rml:reference "providerReference" ; rr:datatype xsd:string ] ] .  # <- propertyPack.searches[].providerReference

# prov:wasGeneratedBy's range is prov:Activity — type the referenced node
# (was a bare untyped IRI; same gap as EPCCertificate's run node, above).
<#SearchRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.searches[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/{productCode}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M6 — Search (localAuthority)  (opda:Search)  iterator: propertyPack.localAuthority
#   The A1 index gives these leaves domain opda:Search; typed accordingly and
#   given the required prov:wasGeneratedBy.
# ---------------------------------------------------------------------------
<#LocalAuthoritySearch> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localAuthority" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/localauthority/{localAuthorityName}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/localauthority/{localAuthorityName}/run" ] ] ;  # SHACL: prov:wasGeneratedBy required
  rr:predicateObjectMap [ rr:predicate opda:localAuthorityName ;
      rr:objectMap [ rml:reference "localAuthorityName" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localAuthority.localAuthorityName
  rr:predicateObjectMap [ rr:predicate opda:countyCouncil ;
      rr:objectMap [ rml:reference "countyCouncil" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localAuthority.countyCouncil
  rr:predicateObjectMap [ rr:predicate opda:districtCouncil ;
      rr:objectMap [ rml:reference "districtCouncil" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localAuthority.districtCouncil
  rr:predicateObjectMap [ rr:predicate opda:unitaryAuthority ;
      rr:objectMap [ rml:reference "unitaryAuthority" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localAuthority.unitaryAuthority (moved from M4 — domain is opda:Search, not opda:Property)
  rr:predicateObjectMap [ rr:predicate opda:localAuthorityReference ;
      rr:objectMap [ rml:reference "localAuthorityReference" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localAuthority.localAuthorityReference (moved from M4 — domain is opda:Search, not opda:Property)
  rr:predicateObjectMap [ rr:predicate opda:councilSearchTurnaroundTimeInWorkingDays ;
      rr:objectMap [ rml:reference "councilSearchTurnaroundTimeInWorkingDays" ; rr:datatype xsd:integer ] ] ;  # <- propertyPack.localAuthority.councilSearchTurnaroundTimeInWorkingDays (moved from M4 — domain is opda:Search, not opda:Property)
  rr:predicateObjectMap [ rr:predicate opda:regulatedSearchTurnaroundTimeInWorkingDays ;
      rr:objectMap [ rml:reference "regulatedSearchTurnaroundTimeInWorkingDays" ; rr:datatype xsd:integer ] ] .  # <- propertyPack.localAuthority.regulatedSearchTurnaroundTimeInWorkingDays (moved from M4 — domain is opda:Search, not opda:Property)

# prov:wasGeneratedBy's range is prov:Activity — type the referenced node
# (same gap as EPCCertificate's and Search's run nodes, above).
<#LocalAuthoritySearchRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localAuthority" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/localauthority/{localAuthorityName}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M7 — LegalEstate (ownershipsToBeTransferred[])  (opda:LegalEstate)
#   iterator: propertyPack.ownership.ownershipsToBeTransferred[*] ; key titleNumber
#   Monetary leaves route to minted opda:MonetaryAmount nodes (M7a).
# ---------------------------------------------------------------------------
<#LegalEstate> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}" ;
                  rr:class opda:LegalEstate ] ;
  rr:predicateObjectMap [ rr:predicate opda:startYearOfLease ;
      rr:objectMap [ rml:reference "leaseholdInformation.leaseTerm.startYearOfLease" ; rr:datatype xsd:gYear ] ] ;  # <- …leaseholdInformation.leaseTerm.startYearOfLease
  rr:predicateObjectMap [ rr:predicate opda:lengthOfLeaseInYears ;
      rr:objectMap [ rml:reference "leaseholdInformation.leaseTerm.lengthOfLeaseInYears" ; rr:datatype xsd:integer ] ] ;  # <- …leaseholdInformation.leaseTerm.lengthOfLeaseInYears
  rr:predicateObjectMap [ rr:predicate opda:sharedOwnershipPercentage ;
      rr:objectMap [ rml:reference "leaseholdInformation.sharedOwnership.sharedOwnershipPercentage" ; rr:datatype xsd:decimal ] ] ;  # <- …leaseholdInformation.sharedOwnership.sharedOwnershipPercentage
  rr:predicateObjectMap [ rr:predicate opda:rentReviewFrequency ;
      rr:objectMap [ rml:reference "leaseholdInformation.groundRent.rentSubjectToIncrease.rentReviewFrequency" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.groundRent.rentSubjectToIncrease.rentReviewFrequency
  rr:predicateObjectMap [ rr:predicate opda:rentIncreaseCalculated ;
      rr:objectMap [ rml:reference "leaseholdInformation.groundRent.rentSubjectToIncrease.rentIncreaseCalculated" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.groundRent.rentSubjectToIncrease.rentIncreaseCalculated
  # Monetary object-properties -> minted MonetaryAmount IRIs (see M7a). Keys
  # embed the optional value itself (not a fixed suffix) — the same
  # skip-together technique as M4b/M23/M27a; a fixed suffix here was a
  # pre-existing defect (predates this session) that minted an empty
  # opda:MonetaryAmount whenever the field was absent, caught this session
  # by a leasehold test item that doesn't set these three fields.
  rr:predicateObjectMap [ rr:predicate opda:annualGroundRent ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/groundRent-{leaseholdInformation.groundRent.annualGroundRent}" ] ] ;  # <- …leaseholdInformation.groundRent.annualGroundRent
  rr:predicateObjectMap [ rr:predicate opda:annualServiceCharge ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/serviceCharge-{leaseholdInformation.serviceCharge.annualServiceCharge}" ] ] ;  # <- …leaseholdInformation.serviceCharge.annualServiceCharge
  rr:predicateObjectMap [ rr:predicate opda:sharedOwnershipRent ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/sharedOwnershipRent-{leaseholdInformation.sharedOwnership.sharedOwnershipRent}" ] ] ;  # <- …leaseholdInformation.sharedOwnership.sharedOwnershipRent
  rr:predicateObjectMap [ rr:predicate opda:titlePropertyDescription ;
      rr:objectMap [ rml:reference "titlePropertyDescription" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].titlePropertyDescription
  rr:predicateObjectMap [ rr:predicate opda:otherOwnershipDetails ;
      rr:objectMap [ rml:reference "otherOwnershipDetails" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].otherOwnershipDetails
  rr:predicateObjectMap [ rr:predicate opda:groundRentFrequency ;
      rr:objectMap [ rml:reference "leaseholdInformation.groundRent.groundRentFrequency" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.groundRent.groundRentFrequency
  rr:predicateObjectMap [ rr:predicate opda:adHocExpenses ;
      rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.adHocExpenses" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.serviceCharge.adHocExpenses
  rr:predicateObjectMap [ rr:predicate opda:dangerousCladdingOrDefects ;
      rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.dangerousCladdingOrDefects" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.serviceCharge.dangerousCladdingOrDefects
  rr:predicateObjectMap [ rr:predicate opda:propertiesContributingToMaintenanceOfManagedArea ;
      rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.propertiesContributingToMaintenanceOfManagedArea" ; rr:datatype xsd:decimal ] ] ;  # <- …leaseholdInformation.serviceCharge.propertiesContributingToMaintenanceOfManagedArea
  rr:predicateObjectMap [ rr:predicate opda:contributionIncludedInServiceCharge ;
      rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.reserveFund.contributionIncludedInServiceCharge" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.serviceCharge.reserveFund.contributionIncludedInServiceCharge
  rr:predicateObjectMap [ rr:predicate opda:from ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.lastDemandPeriod.from" ; rr:datatype xsd:date ] ] ;  # <- …leaseholdInformation.buildingsInsurance.lastDemandPeriod.from
  rr:predicateObjectMap [ rr:predicate opda:to ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.lastDemandPeriod.to" ; rr:datatype xsd:date ] ] ;  # <- …leaseholdInformation.buildingsInsurance.lastDemandPeriod.to
  rr:predicateObjectMap [ rr:predicate opda:year ;
      rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.lastDecoratedPeriod.externally.year" ; rr:datatype xsd:gYear ] ] ;  # <- …leaseholdInformation.serviceCharge.lastDecoratedPeriod.externally.year
  rr:predicateObjectMap [ rr:predicate opda:buildingsReinstatementCostAssessment ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.buildingsReinstatementCostAssessment" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingsInsurance.buildingsReinstatementCostAssessment
  rr:predicateObjectMap [ rr:predicate opda:freeholdOwner ;
      rr:objectMap [ rml:reference "leaseholdInformation.ownershipAndManagement.freeholdOwner" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.ownershipAndManagement.freeholdOwner
  rr:predicateObjectMap [ rr:predicate opda:hasTenantCompanyDissolved ;
      rr:objectMap [ rml:reference "leaseholdInformation.ownershipAndManagement.hasTenantCompanyDissolved" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.ownershipAndManagement.hasTenantCompanyDissolved
  rr:predicateObjectMap [ rr:predicate opda:isManagingAgentEmployed ;
      rr:objectMap [ rml:reference "leaseholdInformation.ownershipAndManagement.isManagingAgentEmployed" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.ownershipAndManagement.isManagingAgentEmployed
  rr:predicateObjectMap [ rr:predicate opda:headLeaseholderControlled ;
      rr:objectMap [ rml:reference "leaseholdInformation.ownershipAndManagement.hasHeadlease.headLeaseholderControlled" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.ownershipAndManagement.hasHeadlease.headLeaseholderControlled
  rr:predicateObjectMap [ rr:predicate opda:isLeaseQualifying ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingSafetyAct.isLeaseQualifying" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingSafetyAct.isLeaseQualifying
  rr:predicateObjectMap [ rr:predicate opda:landlordNotifiedOfSale ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingSafetyAct.landlordNotifiedOfSale" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingSafetyAct.landlordNotifiedOfSale
  rr:predicateObjectMap [ rr:predicate opda:sellerCompletedDeedOfCertificate ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingSafetyAct.deedOfCertificateServed.sellerCompletedDeedOfCertificate" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingSafetyAct.deedOfCertificateServed.sellerCompletedDeedOfCertificate
  rr:predicateObjectMap [ rr:predicate opda:sellerOwnedProperty ;
      rr:objectMap [ rml:reference "leaseholdInformation.enfranchisement.sellerOwnedProperty" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.enfranchisement.sellerOwnedProperty
  rr:predicateObjectMap [ rr:predicate opda:otherPropertiesInManagedArea ;
      rr:objectMap [ rml:reference "leaseholdInformation.general.otherPropertiesInManagedArea" ; rr:datatype xsd:decimal ] ] ;  # <- …leaseholdInformation.general.otherPropertiesInManagedArea
  rr:predicateObjectMap [ rr:predicate opda:personWhoDealsWithTheDeedOfCovenant ;
      rr:objectMap [ rml:reference "leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.personWhoDealsWithTheDeedOfCovenant" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.personWhoDealsWithTheDeedOfCovenant
  rr:predicateObjectMap [ rr:predicate opda:procedureForObtainingCertificate ;
      rr:objectMap [ rml:reference "leaseholdInformation.transferAndRegistration.procedureForObtainingCertificate" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.transferAndRegistration.procedureForObtainingCertificate
  rr:predicateObjectMap [ rr:predicate opda:requirements ;
      rr:objectMap [ rml:reference "leaseholdInformation.transferAndRegistration.licenceToAssignRequired.requirements" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.transferAndRegistration.licenceToAssignRequired.requirements
  rr:predicateObjectMap [ rr:predicate opda:organisesBuildingInsurance ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.serviceContactAssignments.organisesBuildingInsurance" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.serviceContactAssignments.organisesBuildingInsurance
  rr:predicateObjectMap [ rr:predicate opda:outstandingEnforcementAction ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.outstandingEnforcementAction" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.outstandingEnforcementAction
  rr:predicateObjectMap [ rr:predicate opda:urgentWorksCarriedOut ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.urgentWorksCarriedOut" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.urgentWorksCarriedOut
  rr:predicateObjectMap [ rr:predicate opda:urgentWorksRecommended ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.urgentWorksRecommended" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.urgentWorksRecommended
  rr:predicateObjectMap [ rr:predicate opda:certificateOfComplianceFee ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/certificateOfComplianceFee-{leaseholdInformation.requiredDocuments.certificateOfComplianceFee}" ] ] ;  # <- …leaseholdInformation.requiredDocuments.certificateOfComplianceFee (MonetaryAmount join, see M27a)
  rr:predicateObjectMap [ rr:predicate opda:hasFixedRentcharge ;
      rr:objectMap [ rml:reference "managedFreeholdOrCommonholdInformation.serviceCharge.hasFixedRentcharge" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.hasFixedRentcharge
  rr:predicateObjectMap [ rr:predicate opda:dealsWithDayToDayMaintenanceOfManagedArea ;
      rr:objectMap [ rml:reference "managedFreeholdOrCommonholdInformation.contactDetails.dealsWithDayToDayMaintenanceOfManagedArea" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.contactDetails.dealsWithDayToDayMaintenanceOfManagedArea
  rr:predicateObjectMap [ rr:predicate opda:fromTheOwners ;
      rr:objectMap [ rml:reference "managedFreeholdOrCommonholdInformation.serviceCharge.reserveFund.amount.fromTheOwners" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.reserveFund.amount.fromTheOwners
  rr:predicateObjectMap [ rr:predicate opda:forTheManagedAreas ;
      rr:objectMap [ rml:reference "managedFreeholdOrCommonholdInformation.serviceCharge.reserveFund.amount.forTheManagedAreas" ; rr:datatype xsd:decimal ] ] .  # <- propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.reserveFund.amount.forTheManagedAreas

# M7a — MonetaryAmount value nodes (opda:MonetaryAmount)
#   Each MUST carry opda:amount (xsd:decimal) + opda:currency (scheme IRI).
<#GroundRentAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/groundRent-{leaseholdInformation.groundRent.annualGroundRent}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.groundRent.annualGroundRent" ; rr:datatype xsd:decimal ] ] ;
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#ServiceChargeAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/serviceCharge-{leaseholdInformation.serviceCharge.annualServiceCharge}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.serviceCharge.annualServiceCharge" ; rr:datatype xsd:decimal ] ] ;
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#SharedOwnershipRentAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/sharedOwnershipRent-{leaseholdInformation.sharedOwnership.sharedOwnershipRent}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.sharedOwnership.sharedOwnershipRent" ; rr:datatype xsd:decimal ] ] ;
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

# ---------------------------------------------------------------------------
# M8 — RegisteredTitle (ownershipsToBeTransferred[])  (opda:RegisteredTitle)
# ---------------------------------------------------------------------------
<#OwnershipTitle> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/title/{titleNumber}" ;
                  rr:class opda:RegisteredTitle ] ;
  rr:predicateObjectMap [ rr:predicate opda:titleNumber ;
      rr:objectMap [ rml:reference "titleNumber" ; rr:datatype xsd:string ] ] .  # <- propertyPack.ownership.ownershipsToBeTransferred[].titleNumber

# ---------------------------------------------------------------------------
# M9 — RegisteredTitle + LegalEstate (titlesToBeSold[])
#   titleNumber (RegisteredTitle) and titleExtents (LegalEstate).  IRIs reuse
#   the title/ and estate/ keys so the estate node gains titleExtents.
# ---------------------------------------------------------------------------
<#SoldTitle> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.titlesToBeSold[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/title/{titleNumber}" ;
                  rr:class opda:RegisteredTitle ] ;
  rr:predicateObjectMap [ rr:predicate opda:titleNumber ;
      rr:objectMap [ rml:reference "titleNumber" ; rr:datatype xsd:string ] ] .  # <- propertyPack.titlesToBeSold[].titleNumber

<#SoldEstate> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.titlesToBeSold[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}" ;
                  rr:class opda:LegalEstate ] ;
  rr:predicateObjectMap [ rr:predicate opda:titleExtents ;
      rr:objectMap [ rml:reference "titleExtents" ; rr:datatype xsd:string ] ] .  # <- propertyPack.titlesToBeSold[].titleExtents

# ---------------------------------------------------------------------------
# M10 — AttachedDocument (register extract document)  (opda:AttachedDocument)
# ---------------------------------------------------------------------------
<#AttachedDocument> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.titlesToBeSold[*].registerExtract.ocSummaryData.documentDetails.document" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/attacheddoc/{documentDate}" ;
                  rr:class opda:AttachedDocument ] ;
  rr:predicateObjectMap [ rr:predicate opda:documentDate ;
      rr:objectMap [ rml:reference "documentDate" ; rr:datatype xsd:date ] ] .  # <- propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.documentDetails.document.documentDate

# ---------------------------------------------------------------------------
# M11 — Person (legalOwners)  (opda:Person)   iterator: namesOfLegalOwners[*]
#   Keyed on firstName-lastName (no email on these records).
#   Co-typed opda:Proprietor (a Role that borrows identity from its bearer,
#   per opda:Proprietor's own definition — "carries no identity of its own...
#   never independently keyed" — so this is additional rr:class on the SAME
#   subject, NOT a new node, matching R2RML's support for multiple rr:class
#   values per subjectMap). opda:ownerType (domain opda:Proprietor, range
#   skos:Concept, opda:OwnerTypeScheme) uses the M30 FNML mechanism — a
#   real sibling field on the SAME namesOfLegalOwners[] item, single-object
#   context per item (this array item isn't itself heterogeneous the way
#   ownershipsToBeTransferred[] was). Design per team decision: Proprietor
#   is the legal-owner role (matches legalOwners, NOT participants/sellers).
# ---------------------------------------------------------------------------
<#LegalOwnerPerson> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.legalOwners.namesOfLegalOwners[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/person/{firstName}-{lastName}" ;
                  rr:class opda:Person ;
                  rr:class opda:Proprietor ] ;
  rr:predicateObjectMap [ rr:predicate opda:middleNames ;
      rr:objectMap [ rml:reference "middleNames" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.legalOwners.namesOfLegalOwners[].middleNames
  rr:predicateObjectMap [ rr:predicate opda:ownerType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "ownerType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "ownerType" ] ] ] ] ] .  # <- propertyPack.legalOwners.namesOfLegalOwners[].ownerType

# M11a — Organisation (legalOwners, ownerType=="Organisation" oneOf branch)
#   Same iterator as M11; a distinct opda:Organisation-typed node keyed on
#   organisationName (the oneOf branch has no first/last name to key on).
#   Co-typed opda:Proprietor and carries opda:ownerType, same reasoning as M11.
<#LegalOwnerOrganisation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.legalOwners.namesOfLegalOwners[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/org/{organisationName}" ;
                  rr:class opda:Organisation ;
                  rr:class opda:Proprietor ] ;
  rr:predicateObjectMap [ rr:predicate opda:organisationName ;
      rr:objectMap [ rml:reference "organisationName" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.legalOwners.namesOfLegalOwners[].organisationName
  rr:predicateObjectMap [ rr:predicate opda:ownerType ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "ownerType" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "ownerType" ] ] ] ] ] .  # <- propertyPack.legalOwners.namesOfLegalOwners[].ownerType

# M11b — opda:Proprietorship + opda:mediates: NOT mapped. Team decision:
#   Proprietorship (a UFO Relator) should ONLY be emitted when
#   namesOfLegalOwners[] genuinely has 2+ entries — ProprietorshipMediationShape
#   hard-requires opda:mediates sh:minCount 2 ("a relator that binds fewer
#   than two bearers is not a relator"), so unconditionally minting it from
#   every legal-owner array (most of which are sole-ownership, 1 entry)
#   would ship a node that mechanically fails this shape — same risk
#   avoided earlier this session for numberOfSellers's Proprietorship.
#   Checked empirically whether "only emit if array length >= 2" is
#   expressible: morph-kgc's nested-array flattening (normalize_hierarchical_data,
#   see ADR-0057 Amendments) cartesian-products each array item into its own
#   row BEFORE any TriplesMap/UDF sees it — there is no row-level view of
#   "how many sibling items exist" to gate a conditional template or FNML
#   parameter on (a JSONPath filter `[?(...)]` tests one item's own fields,
#   not the enclosing array's length). No RML/morph-kgc technique was found
#   to express this conditional. Left as a genuine, documented gap — same
#   reasoning as the constructionType/hasRoomDimension keyless-array class,
#   a different flavour of "the JSON shape doesn't give this TriplesMap
#   enough to work with," not a mechanical oversight.
# ---------------------------------------------------------------------------
# M12 — Occupiers record (UNTYPED)  iterator: occupiers.othersAged17OrOver
#   Carries opda:aged17OrOverNames and opda:hasOthersAged17OrOver. A1's index
#   gives these leaves domain opda:Seller, but the occupiers/aged-17+ block
#   is NOT a seller PARTY — typing it opda:Seller would mint a spurious
#   Seller individual (no capacity) that trips Baspi5_SellersCapacityShape
#   under the profile. OPDA domains are DOCUMENTARY, never entailed
#   (ODR-0025/0026), so leaving the bearer untyped is fully consistent — the
#   predicate is emitted, no false Seller is asserted. Same untyped-record
#   pattern as the declaration/signature records (M1b/M1c) — both
#   predicates are named in validate_shacl.sh's allowlist for the resulting
#   closed-world domain violation (ODR-0029 R3), same as M1b's leaves.
# ---------------------------------------------------------------------------
<#OccupierRecord> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.occupiers.othersAged17OrOver" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/occupiers/aged17plus-{hasOthersAged17OrOver}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:aged17OrOverNames ;
      rr:objectMap [ rml:reference "aged17OrOverNames" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.occupiers.othersAged17OrOver.aged17OrOverNames
  rr:predicateObjectMap [ rr:predicate opda:hasOthersAged17OrOver ;
      rr:objectMap [ rml:reference "hasOthersAged17OrOver" ; rr:datatype xsd:string ] ] .  # <- propertyPack.occupiers.othersAged17OrOver.hasOthersAged17OrOver

# ---------------------------------------------------------------------------
# M13 — Contract template  (domain-less opda:name + opda:url)
#   No class fits (both properties are rdfs:domain-less cross-artefact refs);
#   node left untyped. opda:url MUST be xsd:anyURI matching ^https?:// (UrlShape).
# ---------------------------------------------------------------------------
<#ContractTemplate> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.contracts[*].contract.template" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/contract-template/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:name ;
      rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ] ] ;  # <- contracts[].contract.template.name
  rr:predicateObjectMap [ rr:predicate opda:url ;
      rr:objectMap [ rml:reference "url" ; rr:datatype xsd:anyURI ] ] .  # <- contracts[].contract.template.url (UrlShape: anyURI + ^https?://)

# ---------------------------------------------------------------------------
# M14 — NearbyFacility (schools[] / transport[] / healthCare[])  (opda:NearbyFacility)
#   No SHACL shape targets this class (verified: zero sh:targetClass matches),
#   so there is no hard join/provenance requirement like EPCCertificate's
#   wasGeneratedBy. Three iterators, one per PDTF sub-array, all typed
#   opda:NearbyFacility (a shared class across facility kinds).
#   Selected via a Darwin-Mode genome/paretoFront proof-of-concept: this
#   full-coverage genome strictly dominated two narrower candidates (more
#   nodes + more fields, same 0-violation soundness).
#   opda:ofstedRating and opda:transportType are sh:in-restricted to SKOS
#   schemes (real array context — schools[*]/transport[*] — so the per-value
#   JSONPath-filter + constant-scheme-IRI pattern from M3c applies cleanly,
#   unlike the single-object enum properties on Property/LegalEstate).
#   Every scheme member is mapped below (M14a/M14b), matching M3c's
#   exhaustive style. (Earlier in this session, the Darwin harness caught an
#   invented test value — "Rail" — that wasn't a real scheme member;
#   corrected to the schema's own enum, "National rail station".)
#   opda:schoolType is NOT mapped here: the JSON field is a nested per-phase
#   yes/no OBJECT (nursery/primary/secondary/…), not a scalar, while the
#   ontology declares it xsd:string — needs a derivation opda-gen didn't
#   specify and RML alone can't express; left as a genuine, documented gap.
# ---------------------------------------------------------------------------
<#NearbyFacility_Schools> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ;
                  rr:class opda:NearbyFacility ] ;
  rr:predicateObjectMap [ rr:predicate opda:name ;
      rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.schools[].name
  rr:predicateObjectMap [ rr:predicate opda:distanceInMiles ;
      rr:objectMap [ rml:reference "distanceInMiles" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.nearbyFacilities.schools[].distanceInMiles
  rr:predicateObjectMap [ rr:predicate opda:ageRange ;
      rr:objectMap [ rml:reference "ageRange" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.schools[].ageRange
  rr:predicateObjectMap [ rr:predicate opda:pupils ;
      rr:objectMap [ rml:reference "pupils" ; rr:datatype xsd:integer ] ] ;  # <- propertyPack.nearbyFacilities.schools[].pupils
  rr:predicateObjectMap [ rr:predicate opda:religiousCharacter ;
      rr:objectMap [ rml:reference "religiousCharacter" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.schools[].religiousCharacter
  rr:predicateObjectMap [ rr:predicate opda:otherRating ;
      rr:objectMap [ rml:reference "otherRating" ; rr:datatype xsd:string ] ] .  # <- propertyPack.nearbyFacilities.schools[].otherRating

# M14a — opda:ofstedRating -> opda:OfstedRatingScheme member IRI (all 5
#   real schema enum values; same subject reuse as M3c).
<#OfstedRatingOutstanding> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[?(@.ofstedRating==\"Outstanding\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:ofstedRating ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/ofstedRating/Outstanding> ] ] .

<#OfstedRatingGood> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[?(@.ofstedRating==\"Good\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:ofstedRating ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/ofstedRating/Good> ] ] .

<#OfstedRatingRequiresImprovement> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[?(@.ofstedRating==\"Requires Improvement\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:ofstedRating ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/ofstedRating/Requires-Improvement> ] ] .

<#OfstedRatingInadequate> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[?(@.ofstedRating==\"Inadequate\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:ofstedRating ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/ofstedRating/Inadequate> ] ] .

<#OfstedRatingOther> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.schools[?(@.ofstedRating==\"Other\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/school/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:ofstedRating ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/ofstedRating/Other> ] ] .

<#NearbyFacility_Transport> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ;
                  rr:class opda:NearbyFacility ] ;
  rr:predicateObjectMap [ rr:predicate opda:name ;
      rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.transport[].name
  rr:predicateObjectMap [ rr:predicate opda:distanceInMiles ;
      rr:objectMap [ rml:reference "distanceInMiles" ; rr:datatype xsd:decimal ] ] .  # <- propertyPack.nearbyFacilities.transport[].distanceInMiles

# M14b — opda:transportType -> opda:TransportTypeScheme member IRI (all 10
#   real schema enum values; same subject reuse as M3c).
<#TransportTypeLocalConnection> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Local connection\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/transport/{name}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:transportType ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Local-connection> ] ] .

<#TransportTypeFerryTerminal> a rr:TriplesMap ;
