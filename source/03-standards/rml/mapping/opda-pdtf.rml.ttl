        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.environmentalIssues.flooding.historicalFlooding.hasBeenFlooded
  rr:predicateObjectMap [ rr:predicate opda:hasSmartHomeSystems ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "smartHomeSystems.hasSmartHomeSystems" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.smartHomeSystems.hasSmartHomeSystems
  rr:predicateObjectMap [ rr:predicate opda:hasSprayFoamInstalled ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
