      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Tramway> ] ] .

<#TransportTypeUndergroundSubway> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.transport[?(@.transportType==\"Underground/Subway\")]" ] ;
