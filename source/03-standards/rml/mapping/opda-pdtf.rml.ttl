      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/transportType/Underground-Subway> ] ] .

<#NearbyFacility_HealthCare> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.nearbyFacilities.healthCare[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/facility/healthcare/{name}" ;
                  rr:class opda:NearbyFacility ] ;
  rr:predicateObjectMap [ rr:predicate opda:name ;
      rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.healthCare[].name
  rr:predicateObjectMap [ rr:predicate opda:distanceInMiles ;
      rr:objectMap [ rml:reference "distanceInMiles" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.nearbyFacilities.healthCare[].distanceInMiles
  rr:predicateObjectMap [ rr:predicate opda:typeOfHealthCare ;
      rr:objectMap [ rml:reference "typeOfHealthCare" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.nearbyFacilities.healthCare[].typeOfHealthCare
  rr:predicateObjectMap [ rr:predicate opda:specialties ;
      rr:objectMap [ rml:reference "specialties" ; rr:datatype xsd:string ] ] .  # <- propertyPack.nearbyFacilities.healthCare[].specialties

# ---------------------------------------------------------------------------
# M15 — RoomDimension (propertyPack.buildInformation.roomDimensions.rooms[*])
#   opda:hasRoomDimension (domain opda:Property, range opda:RoomDimension) is
#   now mapped on M4's own Property TriplesMap: an array-projected rr:template
#   placeholder (buildInformation.roomDimensions.rooms.roomName, plain dot
#   notation, no brackets) reaches into rooms[*] from M4's $.propertyPack
#   iterator — the same technique proven for opda:hasParticipant/opda:concerns.
#   This supersedes an earlier "no shared key" conclusion that only tried a
#   bracket-INDEXED reference (rooms[0].roomName, a fixed position, not a
#   projection over the whole array) — a different, narrower technique that
#   does still fail; the unindexed array-projection is what works.
# ---------------------------------------------------------------------------
<#RoomDimension> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.buildInformation.roomDimensions.rooms[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/room/{roomName}" ;
                  rr:class opda:RoomDimension ] ;
  rr:predicateObjectMap [ rr:predicate opda:roomName ;
      rr:objectMap [ rml:reference "roomName" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.buildInformation.roomDimensions.rooms[].roomName
  rr:predicateObjectMap [ rr:predicate opda:length ;
      rr:objectMap [ rml:reference "length" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.buildInformation.roomDimensions.rooms[].length
  rr:predicateObjectMap [ rr:predicate opda:width ;
      rr:objectMap [ rml:reference "width" ; rr:datatype xsd:decimal ] ] .  # <- propertyPack.buildInformation.roomDimensions.rooms[].width

# ---------------------------------------------------------------------------
# M16 — AttachedDocument (propertyPack.titlesToBeSold[*].additionalDocuments[*])
#   Two-level array nesting: morph-kgc's JSONPath iterator handles the nested
#   path directly (no separate parent TriplesMap/join needed for this case,
#   since nothing here needs to reference the enclosing titlesToBeSold item).
# ---------------------------------------------------------------------------
<#TitleAdditionalDocument> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.titlesToBeSold[*].additionalDocuments[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/document/{documentTypeCode}-{retrievedOn}" ;
                  rr:class opda:AttachedDocument ] ;
  rr:predicateObjectMap [ rr:predicate opda:documentTypeCode ;
      rr:objectMap [ rml:reference "documentTypeCode" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].additionalDocuments[].documentTypeCode
  rr:predicateObjectMap [ rr:predicate opda:filedUnder ;
      rr:objectMap [ rml:reference "filedUnder" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.titlesToBeSold[].additionalDocuments[].filedUnder
  rr:predicateObjectMap [ rr:predicate opda:retrievedOn ;
      rr:objectMap [ rml:reference "retrievedOn" ; rr:datatype xsd:date ] ] .  # <- propertyPack.titlesToBeSold[].additionalDocuments[].retrievedOn

# M17 — Search provider reference: merged into M5's existing <#Search>
# TriplesMap above (same subject, same iterator) rather than duplicated here.

# M18 — Survey construction type: now mapped on M4's own Property TriplesMap
#   (opda:constructionType, below), via the array-projected reference
#   `surveys.misc.constructionType` (plain dot notation, no brackets) COMBINED
#   with the M30 FNML mechanism (opda:scheme_member_iri) — constructionType is
#   rdfs:range skos:Concept, and surveys[] is a real array, so the enum value
#   needs the same slugify-to-scheme-IRI treatment as M30's single-object
#   enums, just reached through an array projection instead. This supersedes
#   the earlier "no shared key back to the property" conclusion, which only
#   tried a bracket-INDEXED reference (surveys[0].misc...) and a real R2RML
#   join — the unindexed array-projection needs neither. Proven correct via a
#   standalone scratch instance (surveys[0].misc.constructionType =
#   "Timber frame" -> .../scheme/constructionType/Timber-frame, an exact
#   match against the real ontology member) — testdata/01-04 don't exercise
#   propertyPack.surveys[] at all, so this is not exercised by the standard
#   regression suite, same caveat as the managedFreeholdOrCommonhold branch
#   documented near M27.

# ---------------------------------------------------------------------------
# M19 — Chain selling agent (chain.onwardPurchase[*])  domain=Transaction
# ---------------------------------------------------------------------------
<#ChainSellingAgent> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.chain.onwardPurchase[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/txn/{transactionId}" ;
                  rr:class opda:Transaction ] ;
  rr:predicateObjectMap [ rr:predicate opda:sellingAgent ;
      rr:objectMap [ rml:reference "sellingAgent" ; rr:datatype xsd:string ] ] .  # <- chain.onwardPurchase[].sellingAgent

# ---------------------------------------------------------------------------
# M20 — Planning permission record (localSearches[*])  (opda:Search)
#   iterator: propertyPack.localSearches.localAuthoritySearches
#     .planningAndBuildingRegulations.decisionsAndPendingApplications
#     .planningPermission[*]
#   buildingControlStartDate/planningStartDate (also domain=Search, one level
#   up in decisionsAndPendingApplications) are now mapped at M20a below, via a
#   NEW Search node minted at $.propertyPack (where {uprn} lives) rather than
#   from within planningPermission[*]'s own iterator — the same "mint a
#   synthetic parent node on a stable ambient key" idiom used for M24a's
#   RiskAssessment parents. Supersedes the earlier "no natural key at that
#   container level" conclusion, which is true of the container itself but
#   doesn't rule out keying the node on {uprn} + the field's own value (the
#   skip-together technique, ADR-0057 Amendment 1).
# ---------------------------------------------------------------------------
<#PlanningPermission> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planning/{refNumber}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planning/{refNumber}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:refNumber ;
      rr:objectMap [ rml:reference "refNumber" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].refNumber
  rr:predicateObjectMap [ rr:predicate opda:applicationDate ;
      rr:objectMap [ rml:reference "applicationDate" ; rr:datatype xsd:date ] ] ;  # <- ...planningPermission[].applicationDate
  rr:predicateObjectMap [ rr:predicate opda:applicationType ;
      rr:objectMap [ rml:reference "applicationType" ; rr:datatype xsd:string ] ] ;  # <- ...planningPermission[].applicationType
  rr:predicateObjectMap [ rr:predicate opda:decision ;
      rr:objectMap [ rml:reference "decision" ; rr:datatype xsd:string ] ] ;  # <- ...planningPermission[].decision
  rr:predicateObjectMap [ rr:predicate opda:decisionDate ;
      rr:objectMap [ rml:reference "decisionDate" ; rr:datatype xsd:date ] ] .  # <- ...planningPermission[].decisionDate

<#PlanningPermissionRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planning/{refNumber}/run" ;
                  rr:class prov:Activity ] .

# M20a — decisionsAndPendingApplications' OWN scalar fields (planningStartDate/
#   buildingControlStartDate), one level up from M20's planningPermission[*]
#   array. Keyed on {uprn} (from M4's own iterator, $.propertyPack) + the
#   planningStartDate value itself (skip-together: the node only mints when
#   planningStartDate is present). Honest asymmetry: if buildingControlStartDate
#   is present but planningStartDate is absent, this node does not mint at all
#   (the subject template's placeholder fails) and buildingControlStartDate is
#   lost too — no PDTF v3 schema constraint ties the two together, so a
#   real-world instance could hit this; not exercised by testdata/01-04
#   (neither field occurs in any tracked fixture), proven via a standalone
#   scratch instance instead (same caveat as M18/constructionType above).
<#PlanningBuildingRegsRecord> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planningbuildingregs-{uprn}-{localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planningbuildingregs-{uprn}-{localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:planningStartDate ;
      rr:objectMap [ rml:reference "localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate" ; rr:datatype xsd:date ] ] ;  # <- propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate
  rr:predicateObjectMap [ rr:predicate opda:buildingControlStartDate ;
      rr:objectMap [ rml:reference "localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.buildingControlStartDate" ; rr:datatype xsd:date ] ] .  # <- propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.buildingControlStartDate

<#PlanningBuildingRegsRecordRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/planningbuildingregs-{uprn}-{localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M21 — Planning designation plan (localSearches[*].designationsAndProposals.plans[*])
#   (opda:Search)  statusDate on the plan itself.
# ---------------------------------------------------------------------------
<#PlanningDesignationPlan> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{name}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{name}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:statusDate ;
      rr:objectMap [ rml:reference "statusDate" ; rr:datatype xsd:date ] ] .  # <- ...designationsAndProposals.plans[].statusDate

<#PlanningDesignationPlanRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{name}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M22 — Planning designation entry (…plans[*].designations[*])  (opda:Search)
#   A distinct, independent Search-typed node from M21's plan-level node —
#   opda:Search is a general class with many valid instances (M5/M6/M9/M20
#   are all different Search records too); unlike M18's constructionType
#   (whose domain required THE SPECIFIC Property node), minting a separate
#   Search node here for the designation entry is semantically sound, not a
#   domain violation. Two-level array iterator (proven pattern; see M16).
# ---------------------------------------------------------------------------
<#PlanningDesignationEntry> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*].designations[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{designationType}" ;
                  rr:class opda:Search ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{designationType}/run" ] ] ;  # SHACL: class-promoted opda:Search requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:designationType ;
      rr:objectMap [ rml:reference "designationType" ; rr:datatype xsd:string ] ] .  # <- ...designationsAndProposals.plans[].designations[].designationType

<#PlanningDesignationEntryRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[*].designations[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/search/designation/{designationType}/run" ;
                  rr:class prov:Activity ] .

# ---------------------------------------------------------------------------
# M23 — valuationComparisonData (a top-level structure, PEER to propertyPack,
#   not nested under it). Two independent subtrees, each needing its own
#   TriplesMap iterator (morph-kgc: one iterator per TriplesMap), and — per
#   rdfs:domain, below — BOTH subtrees bear on opda:Valuation, not
#   opda:Comparable:
#
#     valuationComparisonData.propertyDetails[*]   — an array of comparable
#       properties, each with a real natural key (uprn). Instantiates
#       opda:Comparable (class-promoted; ODR-0008 Q4a) for the comparable
#       record itself, AND opda:soldPrice/opda:soldDate/opda:listPrice/
#       opda:listedDate — which the ontology's own rdfs:domain assigns to
#       opda:Valuation, not opda:Comparable ("Bearer opda:Valuation...flat
#       per §Q6a" — a deliberate ODR-0008 Q6a flattening decision, not
#       something this mapping invents). Comparable itself carries NO
#       rdfs:domain-bound datatype/object property in the current ontology
#       (verified: zero grep hits) — it is typed + given prov:wasGeneratedBy
#       only.
#
#     valuationComparisonData.propertyPricing      — a SINGLETON object (not
#       an array) with the subject property's own market-estimate figures
#       (estimatedPrice, rentalEstimate.estimatedAmount, yield,
#       priceEstimationDetails.*). Also opda:Valuation. Has no natural key of
#       its own; keyed on {estimatedPrice} itself (same optional-field-in-
#       template technique as M4b/M4d/M4e — this doubles as the "skip
#       together" guard AND the entity's own identity key, since no other
#       stable field exists here).
#
#   Because propertyDetails[*] and propertyPricing are different subtrees
#   with no shared key in the JSON, and rdfs:domain assigns fields from BOTH
#   onto opda:Valuation, this mapping mints TWO independent opda:Valuation-
#   typed nodes per transaction (valuation/estimate-{estimatedPrice} and
#   valuation/comparable-{uprn}) rather than fabricate a shared key that
#   doesn't exist in the data — each independently satisfies the
#   ValuationIdentityKeyShape (prov:wasGeneratedBy minCount 1).
# ---------------------------------------------------------------------------
<#Comparable> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/comparable/{uprn}" ;
                  rr:class opda:Comparable ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/comparable/{uprn}/run" ] ] .  # SHACL: class-promoted opda:Comparable requires prov:wasGeneratedBy

<#ComparableRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/comparable/{uprn}/run" ;
                  rr:class prov:Activity ] .

<#ValuationComparableListing> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}" ;
                  rr:class opda:Valuation ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/run" ] ] ;  # SHACL: class-promoted opda:Valuation requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:soldDate ;
      rr:objectMap [ rml:reference "propertyListingInfo.soldDate" ; rr:datatype xsd:date ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.soldDate (oneOf branch: Recently Sold; dateTime lexical truncated to xsd:date)
  rr:predicateObjectMap [ rr:predicate opda:listedDate ;
      rr:objectMap [ rml:reference "propertyListingInfo.listedDate" ; rr:datatype xsd:date ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.listedDate (oneOf branch: Currently On Sale; not instance-exercised, path verified)
  rr:predicateObjectMap [ rr:predicate opda:soldPrice ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/soldPrice-{propertyListingInfo.soldPrice}" ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.soldPrice (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:listPrice ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/listPrice-{propertyListingInfo.listPrice}" ] ] .  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.listPrice (MonetaryAmount join, see below; not instance-exercised)

<#ValuationComparableListingRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/run" ;
                  rr:class prov:Activity ] .

<#SoldPriceAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/soldPrice-{propertyListingInfo.soldPrice}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "propertyListingInfo.soldPrice" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.soldPrice
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#ListPriceAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyDetails[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/comparable-{uprn}/amount/listPrice-{propertyListingInfo.listPrice}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "propertyListingInfo.listPrice" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyDetails[].propertyListingInfo.listPrice
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#Valuation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}" ;
                  rr:class opda:Valuation ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/run" ] ] ;  # SHACL: class-promoted opda:Valuation requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:estimatedPrice ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/estimatedPrice-{estimatedPrice}" ] ] ;  # <- valuationComparisonData.propertyPricing.estimatedPrice (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:estimatedAmount ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/rentalEstimate-{rentalEstimate.estimatedAmount}" ] ] ;  # <- valuationComparisonData.propertyPricing.rentalEstimate.estimatedAmount (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:yield ;
      rr:objectMap [ rml:reference "yield" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyPricing.yield
  rr:predicateObjectMap [ rr:predicate opda:pricingMethodology ;
      rr:objectMap [ rml:reference "priceEstimationDetails.pricingMethodology" ; rr:datatype xsd:string ] ] ;  # <- valuationComparisonData.propertyPricing.priceEstimationDetails.pricingMethodology
  rr:predicateObjectMap [ rr:predicate opda:credibilitySources ;
      rr:objectMap [ rml:reference "priceEstimationDetails.credibilitySources[]" ; rr:datatype xsd:string ] ] .  # <- valuationComparisonData.propertyPricing.priceEstimationDetails.credibilitySources (array of strings)

<#ValuationRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/run" ;
                  rr:class prov:Activity ] .

<#EstimatedPriceAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/estimatedPrice-{estimatedPrice}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "estimatedPrice" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyPricing.estimatedPrice
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#RentalEstimateAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.valuationComparisonData.propertyPricing" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/valuation/estimate-{estimatedPrice}/amount/rentalEstimate-{rentalEstimate.estimatedAmount}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "rentalEstimate.estimatedAmount" ; rr:datatype xsd:decimal ] ] ;  # <- valuationComparisonData.propertyPricing.rentalEstimate.estimatedAmount
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

# ---------------------------------------------------------------------------
# M24 — RiskAssessment (environmental-peril riskSubcategories[])  (opda:RiskAssessment)
#   opda:subCategory (domain opda:RiskAssessment) cites TWO real occurrences —
#   flooding.floodRisk.riskSubcategories[] and climate.climateRisk
#   .riskSubcategories[] — both bound (ODR-0035: trace every real occurrence,
#   not just one dct:source citation). Each riskSubcategories[] item carries
#   its own genuine key (subCategory itself — a per-item distinguishing
#   name), unlike the parent floodRisk/climateRisk block (which has no key of
#   its own — closed below at M24a, once thought permanently blocked by the
#   since-fixed morph-kgc dropna bug; see M24a's own comment). Class-promoted (shares
#   RiskAssessment's identity shape with Comparable/Survey/Valuation, above)
#   so each sub-assessment node gets its own prov:wasGeneratedBy + RunActivity.
#   opda:actionAlertRating (plain xsd:integer) and opda:riskIndicator
#   (rdfs:range skos:Concept, opda:YesNoNotKnownScheme) are also real,
#   sibling fields on each riskSubcategories[] item (verified: real schema
#   enum here is Yes/No only, no "Not known" — the 3-value scheme is shared
#   more broadly). riskIndicator uses the per-value-filter pattern (M3c/
#   M14a/M14b), NOT the M30 FNML mechanism — riskSubcategories[] is a real
#   array, so the filter technique works, and ADR-0057 prefers it over FNML
#   when both are viable (single-file auditability; FNML is the escape
#   hatch for single-object contexts only, per M30's own comment).
# ---------------------------------------------------------------------------
<#FloodRiskSubcategory> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:subCategory ;
      rr:objectMap [ rml:reference "subCategory" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[].subCategory
  rr:predicateObjectMap [ rr:predicate opda:actionAlertRating ;
      rr:objectMap [ rml:reference "actionAlertRating" ; rr:datatype xsd:integer ] ] ;  # <- propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[].actionAlertRating
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Flooding> ] .  # constant: this TriplesMap only ever iterates the flooding container

<#FloodRiskSubcategoryRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ;
                  rr:class prov:Activity ] .

<#FloodRiskSubcategoryIndicatorYes> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[?(@.riskIndicator==\"Yes\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/Yes> ] ] .

<#FloodRiskSubcategoryIndicatorNo> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[?(@.riskIndicator==\"No\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/No> ] ] .

<#ClimateRiskSubcategory> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:subCategory ;
      rr:objectMap [ rml:reference "subCategory" ; rr:datatype xsd:string ] ] ;  # <- propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[].subCategory
  rr:predicateObjectMap [ rr:predicate opda:actionAlertRating ;
      rr:objectMap [ rml:reference "actionAlertRating" ; rr:datatype xsd:integer ] ] ;  # <- propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[].actionAlertRating
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Climate> ] .  # constant: this TriplesMap only ever iterates the climate container

<#ClimateRiskSubcategoryRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}/run" ;
                  rr:class prov:Activity ] .

<#ClimateRiskSubcategoryIndicatorYes> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[?(@.riskIndicator==\"Yes\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/Yes> ] ] .

<#ClimateRiskSubcategoryIndicatorNo> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ; rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[?(@.riskIndicator==\"No\")]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{subCategory}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:riskIndicator ;
      rr:objectMap [ rr:constant <https://opda.org.uk/pdtf/scheme/yesNoNotKnown/No> ] ] .

# M24a — RiskAssessment PARENT nodes (the floodRisk/climateRisk container
#   itself, one level up from M24's riskSubcategories[] children) — closes
#   opda:hasSubAssessment (ODR-0008d Rule 4's result-recursion axis: a parent
#   RiskAssessment -> each riskSubcategories[] child, itself a leaf
#   RiskAssessment per M24). Previously undiscussed as mappable at all: the
#   container has no own JSON key, but IS mintable on a stable ambient key
#   ({uprn}, already M4's Property identity key) plus a CONSTANT peril-name
#   segment (fixed per TriplesMap, not a JSON value) — same idiom as M7a/M23's
#   {titleNumber}-adjacent keying. Node existence is made conditional on the
#   container actually being present by embedding its own riskIndicator VALUE
#   in the subject template (the established skip-together technique, ADR-0057
#   Amendment 1): if floodRisk/climateRisk is entirely absent (e.g. testdata/02
#   minimal), the whole subject template placeholder fails to resolve and the
#   row is dropped — no spurious RiskAssessment minted for a peril that was
#   never assessed. hasSubAssessment then reaches the child's {subCategory} key
#   via the array-projected rr:template placeholder technique (proven for
#   opda:hasParticipant/opda:concerns) — cheap here because the iterator is
#   $.propertyPack (shared with M4/M7/etc), so the first path segment pulled is
#   "environmentalIssues", not the whole propertyPack subtree; when
#   riskSubcategories[] itself is absent (e.g. testdata/01, which has
#   floodRisk.riskIndicator but no riskSubcategories), only the
#   hasSubAssessment triple is dropped — the parent node itself still mints.
<#FloodRiskParent> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Flooding-{environmentalIssues.flooding.floodRisk.riskIndicator}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Flooding-{environmentalIssues.flooding.floodRisk.riskIndicator}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Flooding> ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasSubAssessment ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{environmentalIssues.flooding.floodRisk.riskSubcategories.subCategory}" ] ] .  # <- propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[] (result-recursion parent->child, ODR-0008d Rule 4)

<#FloodRiskParentRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Flooding-{environmentalIssues.flooding.floodRisk.riskIndicator}/run" ;
                  rr:class prov:Activity ] .

<#ClimateRiskParent> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Climate-{environmentalIssues.climate.climateRisk.riskIndicator}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Climate-{environmentalIssues.climate.climateRisk.riskIndicator}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:peril ;
      rr:object <https://opda.org.uk/pdtf/scheme/peril/Climate> ] ;
  rr:predicateObjectMap [ rr:predicate opda:hasSubAssessment ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/subcategory/{environmentalIssues.climate.climateRisk.riskSubcategories.subCategory}" ] ] .  # <- propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[] (result-recursion parent->child, ODR-0008d Rule 4)

<#ClimateRiskParentRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/property-{uprn}/peril/Climate-{environmentalIssues.climate.climateRisk.riskIndicator}/run" ;
                  rr:class prov:Activity ] .

# M25 — typeOfConstruction.buildingSafety.potentialCost: NOT mapped. rdfs:range
#   is opda:MonetaryAmount, but the real JSON field is free text (type:
#   string, "What will the potential cost be?" — no numeric constraint at
#   all). A ratified, pre-existing tension (council session-028 Q3; see the
#   term's own rdfs:comment), not something RML can bridge without
#   fabricating a numeric parse of free text. Left as a genuine, documented
#   gap — same shape as M14/M18/M20's gaps above.
#
# M26 — nearbyFacilities.schools[].schoolType, surveys[].misc.constructionType,
#   localSearches buildingControlStartDate/planningStartDate: already
#   documented as genuine gaps at M14, M18, M20 respectively (re-verified
#   this session — still true, no new technique found for any of them).

# ---------------------------------------------------------------------------
# M27 — propertyPack.ownership (leasehold branch): remaining LegalEstate-
#   domain leaves already added directly to M7's <#LegalEstate> TriplesMap,
#   above (same subject, same iterator — matching the M4/M7a established
#   style of one TriplesMap per node, many predicateObjectMaps). This block
#   covers the leaves whose rdfs:domain is NOT opda:LegalEstate:
#     - opda:certificateOfComplianceFee's MonetaryAmount value node (M27a)
#     - opda:dateRemedialActionRequired (domain opda:RiskAssessment) — a
#       SINGLETON risk-assessment block nested in managedAreasCoveredByPolicy
#       (not an array), keyed on the SAME titleNumber (M27b)
#     - opda:confirmation / opda:costsApplicableToTheDeed / opda:feeIncludingVAT
#       / opda:response (domain opda:Transaction) — properly typing these onto
#       the real opda:Transaction node would need the root iterator (for
#       transactionId) combined with this nested array's own leaves, the same
#       "cheap technique, expensive in practice" tradeoff documented at M1's
#       own comment (not a hard reachability wall — that framing was a
#       misdiagnosis of the since-fixed dropna bug). Not attempted here for
#       the same cost/benefit reason M1b/M12 stay untyped. Emitted instead on
#       an UNTYPED record keyed on titleNumber, exactly the M1b/M12 pattern
#       (untyped => no false Transaction identity asserted, no SHACL target,
#       but a closed-world domain violation under ODR-0029 R3 — named and
#       allowlisted in validate_shacl.sh, same as M1b/M12) (M27c)
#     - opda:accountName/accountNumber/sortCode/reference (domain
#       opda:Organisation) — the landlord contact IS a real Organisation,
#       keyed on its own genuine name (contact.nameOrOrganisation) (M27d)
#     - opda:numberOfSellers/numberOfNonUkResidentSellers (domain
#       opda:Proprietorship) — flat under propertyPack.ownership itself (a
#       singleton, like propertyPricing in M23), keyed on the subject
#       property's own uprn (reachable: same iterator as M4) (M27e)
#     - opda:hasFixedRentcharge/dealsWithDayToDayMaintenanceOfManagedArea/
#       fromTheOwners/forTheManagedAreas — the managedFreeholdOrCommonhold
#       oneOf branch's own exclusive leaves (domain opda:LegalEstate, plain
#       xsd:string/xsd:decimal, no Concept-range issue). The SAME M7
#       <#LegalEstate> TriplesMap (above) already picks these up (no separate
#       TriplesMap needed) — verified correct via a standalone scratch
#       instance (single-item ownershipsToBeTransferred[], managedFreehold
#       branch only), NOT added as a second item alongside the leasehold one
#       in testdata/03-multi-participant.json: a real morph-kgc engine
#       defect (see ADR-0057 Amendments, 2026-07-04 entry 2) makes a 2-item
#       ownershipsToBeTransferred[] array with heterogeneous top-level keys
#       across items silently break an UNRELATED sibling reference
#       (M4's "ownership.isFirstRegistration" etc.) — confirmed empirically,
#       traced to morph_kgc.utils.normalize_hierarchical_data's cartesian-
#       product flattening of nested arrays interacting badly with
#       heterogeneous item shapes. Leasehold remains the sole array item in
#       the tracked test fixture; this branch's correctness is proven, just
#       not exercised by the standard 01/02/03/04 regression suite.
#   NOT mapped in this batch: opda:numberOfSellers/numberOfNonUkResidentSellers
#   remain a genuine gap pending the Proprietor/Proprietorship Relator design
#   (see the removed M27f note in git history) — unrelated to this branch.
# ---------------------------------------------------------------------------
<#CertificateOfComplianceFeeAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/estate/{titleNumber}/amount/certificateOfComplianceFee-{leaseholdInformation.requiredDocuments.certificateOfComplianceFee}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.requiredDocuments.certificateOfComplianceFee" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.requiredDocuments.certificateOfComplianceFee
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#OwnershipRiskAssessment> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/estate-{titleNumber}" ;
                  rr:class opda:RiskAssessment ] ;
  rr:predicateObjectMap [ rr:predicate prov:wasGeneratedBy ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/estate-{titleNumber}/run" ] ] ;  # SHACL: class-promoted opda:RiskAssessment requires prov:wasGeneratedBy
  rr:predicateObjectMap [ rr:predicate opda:dateRemedialActionRequired ;
      rr:objectMap [ rml:reference "leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.dateRemedialActionRequired" ; rr:datatype xsd:date ] ] .  # <- …leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.dateRemedialActionRequired

<#OwnershipRiskAssessmentRunActivity> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/riskassessment/estate-{titleNumber}/run" ;
                  rr:class prov:Activity ] .

<#OwnershipTransactionRecord> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:confirmation ;
      rr:objectMap [ rml:reference "leaseholdInformation.confirmationOfAccuracy.confirmation" ; rr:datatype xsd:boolean ] ] ;  # <- …leaseholdInformation.confirmationOfAccuracy.confirmation
  rr:predicateObjectMap [ rr:predicate opda:costsApplicableToTheDeed ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}/amount/costsApplicableToTheDeed-{leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed}" ] ] ;  # <- …leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:feeIncludingVAT ;
      rr:objectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}/amount/feeIncludingVAT-{leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT}" ] ] ;  # <- …leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT (MonetaryAmount join, see below)
  rr:predicateObjectMap [ rr:predicate opda:response ;
      rr:objectMap [ rml:reference "managedFreeholdOrCommonholdInformation.confirmation.response" ; rr:datatype xsd:boolean ] ] .  # <- propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.confirmation.response

<#CostsApplicableToTheDeedAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}/amount/costsApplicableToTheDeed-{leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#FeeIncludingVATAmount> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/ownershiprecord/{titleNumber}/amount/feeIncludingVAT-{leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT}" ;
                  rr:class opda:MonetaryAmount ] ;
  rr:predicateObjectMap [ rr:predicate opda:amount ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT" ; rr:datatype xsd:decimal ] ] ;  # <- propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT
  rr:predicateObjectMap [ rr:predicate opda:currency ;
      rr:object <https://opda.org.uk/pdtf/scheme/currency/GBP> ] .

<#LandlordOrganisation> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack.ownership.ownershipsToBeTransferred[*]" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/org/{leaseholdInformation.contactDetails.contacts.landlord.contact.nameOrOrganisation}" ;
                  rr:class opda:Organisation ] ;
  rr:predicateObjectMap [ rr:predicate opda:accountName ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountName" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountName
  rr:predicateObjectMap [ rr:predicate opda:accountNumber ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountNumber" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.accountNumber
  rr:predicateObjectMap [ rr:predicate opda:sortCode ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.sortCode" ; rr:datatype xsd:string ] ] ;  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.sortCode
  rr:predicateObjectMap [ rr:predicate opda:reference ;
      rr:objectMap [ rml:reference "leaseholdInformation.contactDetails.contacts.landlord.bankDetails.reference" ; rr:datatype xsd:string ] ] .  # <- …leaseholdInformation.contactDetails.contacts.landlord.bankDetails.reference

# M27f — opda:numberOfSellers / opda:numberOfNonUkResidentSellers (domain
#   opda:Proprietorship): NOT mapped. Tried minting a Proprietorship node
#   keyed on uprn with just these two counts — caught by the (post-harness-
#   fix) SHACL run: ProprietorshipMediationShape requires ANY opda:Proprietorship
#   individual to carry opda:mediates -> >=2 opda:Proprietor individuals (a
#   UFO Relator, ODR-0006 §Q3 — "a relator that binds fewer than two bearers
#   is not a relator"). Properly satisfying this means identifying which
#   participants/legalOwners play the Proprietor role and linking them via
#   opda:mediates — a real Relator-modelling decision, not a mechanical
#   "add a predicateObjectMap" gap like the rest of this region. Left as a
#   genuine, documented gap pending that design (not attempted here to avoid
#   shipping a node that mechanically fails a hard SHACL constraint).

# M30 — the M28/M29 cluster, closed via RML-FNML (mapping/opda-udfs.py).
#   Every property below has rdfs:range skos:Concept but sits in a single,
#   always-present JSON object ($.propertyPack, or one leasehold
#   ownershipsToBeTransferred[] item), not a real array — the per-value-
#   filter technique that fixed M14's ofstedRating/transportType needs
#   `[?(...)]` JSONPath filter brackets, which only work on arrays.
#   Proven empirically this session: a single generic UDF
#   (opda:scheme_member_iri, value+scheme params) replicates opda_gen's own
#   `_slugify_for_uri` exactly (verified against real scheme members,
#   including the punctuation-stripping case "FTTC (Fibre to the Cabinet)"
#   -> ".../FTTC-Fibre-to-the-Cabinet") and constructs the correct
#   scheme-member IRI directly — output rr:termType rr:IRI (not the default
#   literal; morph-kgc's literal-output code path for rmlf:functionExecution
#   has an internal bug unconditionally touching a 'reference_results'
#   dataframe column that a bare function execution never populates).
#
#   opda:ownerType (domain opda:Proprietor) is NOT included here — Proprietor
#   is the same deferred Relator-modelling class flagged near M27 above (no
#   node minted yet; a real design decision, not an FNML gap).
#   opda:tenureKind (ODR-0008 §Q5a) has NO real JSON occurrence at all
#   (verified: zero matches anywhere in the v3 schema) — a genuinely
#   conceptual, ODR-only term, not a gap of this kind.
<#Property_FNMLEnums> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "INSTANCE.json" ;
                      rml:referenceFormulation ql:JSONPath ;
                      rml:iterator "$.propertyPack" ] ;
  rr:subjectMap [ rr:template "https://opda.org.uk/pdtf/harness/data/property/{uprn}" ] ;
  rr:predicateObjectMap [ rr:predicate opda:isInsured ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:value> ] ; rmlf:inputValueMap [ rml:reference "insurance.isInsured" ] ] ;
        rmlf:input [ rmlf:parameterMap [ rmlf:constant <urn:opda:param:scheme> ] ; rmlf:inputValueMap [ rmlf:constant "yesNo" ] ] ] ] ] ;  # <- propertyPack.insurance.isInsured
  rr:predicateObjectMap [ rr:predicate opda:hasBeenFlooded ;
      rr:objectMap [ rr:termType rr:IRI ; rmlf:functionExecution [
        rmlf:functionMap [ rmlf:constant <urn:opda:scheme_member_iri> ] ;
