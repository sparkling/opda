@prefix dct: <http://purl.org/dc/terms/> .
@prefix opda: <https://opda.org.uk/pdtf/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

opda:BoundedContextScheme
    rdf:type skos:ConceptScheme ;
    rdfs:label "PDTF Bounded Contexts"@en ;
    skos:definition "The six industry bounded contexts of the UK PDTF, each owning a SHACL overlay profile (ODR-0010). Domain-term membership in a context is a derived, on-demand query (opda:servesContext per ODR-0020), never hand-authored except per ODR-0019 Rule 8."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> .

opda:ConveyancingContext
    rdf:type skos:Concept ;
    skos:prefLabel "Conveyancing"@en ;
    skos:definition "Legal transfer of estate; overlays ta6/ta7/ta10/lpe1."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    skos:inScheme opda:BoundedContextScheme ;
    skos:topConceptOf opda:BoundedContextScheme ;
    opda:hasSteward "Law Society; SRA; CLC; Society of Licensed Conveyancers; CILEx; CILEx Regulation."@en .

opda:EstateAgencyContext
    rdf:type skos:Concept ;
    skos:prefLabel "Estate Agency"@en ;
    skos:definition "Marketing and sale of residential property; overlays baspi5/nts2."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    skos:inScheme opda:BoundedContextScheme ;
    skos:topConceptOf opda:BoundedContextScheme ;
    opda:hasSteward "Propertymark; property portals (Rightmove, Zoopla); regulated by NTSELAT (transitioning to MHCLG)."@en .

opda:MortgageLendingContext
    rdf:type skos:Concept ;
    skos:prefLabel "Mortgage Lending"@en ;
    skos:definition "Lending secured against property; overlays fme1."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    skos:inScheme opda:BoundedContextScheme ;
    skos:topConceptOf opda:BoundedContextScheme ;
    opda:hasSteward "UK Finance; BSA; regulated by the FCA."@en .

opda:PropertyDataServicesContext
    rdf:type skos:Concept ;
    skos:prefLabel "Property Data Services"@en ;
    skos:definition "Aggregation and supply of property data; overlays con29R/con29DW/llc1/oc1/rds/sr24."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    skos:inScheme opda:BoundedContextScheme ;
    skos:topConceptOf opda:BoundedContextScheme ;
    opda:hasSteward "COPSO."@en .

opda:PropertyTechnologyContext
    rdf:type skos:Concept ;
    skos:prefLabel "Property Technology"@en ;
    skos:definition "Orchestration and system-to-system messaging spanning the industry contexts."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    skos:inScheme opda:BoundedContextScheme ;
    skos:topConceptOf opda:BoundedContextScheme ;
    opda:hasSteward "No single regulator — orchestration layer across the industry contexts."@en .

opda:SurveyingContext
    rdf:type skos:Concept ;
    skos:prefLabel "Surveying"@en ;
    skos:definition "Physical inspection and valuation; overlays piq."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    skos:inScheme opda:BoundedContextScheme ;
    skos:topConceptOf opda:BoundedContextScheme ;
    opda:hasSteward "RICS."@en .

opda:consumesFrom
    rdf:type owl:AnnotationProperty ;
    rdfs:label "consumes from"@en ;
    rdfs:comment "Links a domain term (or its owning module) to an upstream conformist authority — an opda:Organisation / prov:Agent whose published model PDTF conforms to (HM Land Registry, Local Authority, MHCLG Material Information, DSIT/DIATF Identity, W3C Trust & VCs). The DDD Conformist relationship per ODR-0020: upstream authorities own no overlay, so they are NEVER opda:servesContext targets and are NOT members of opda:BoundedContextScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0019/section-rule-8> ;
    rdfs:isDefinedBy <https://opda.org.uk/pdtf/harness/odr/ODR-0020/section-decision> ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    skos:scopeNote "Annotation property (membership/provenance, not logical typing). rdfs:subPropertyOf prov:wasInfluencedBy so consumers can traverse it as PROV influence. ODR-0020 Rule on upstream authorities."@en .
