# opda-annotations.ttl — OPDA advisory annotations graph (foundation header)
# Generated by opda-gen 1.0.2 at 2026-05-30; DO NOT HAND-EDIT.
# Specification: https://opda.org.uk/pdtf/harness/adr/ADR-0007-ontology-generator-specification
# Implementation: https://opda.org.uk/pdtf/harness/adr/ADR-0008-generator-implementation-infrastructure
# This emission: https://opda.org.uk/pdtf/harness/adr/ADR-0026-bounded-context-scheme-emission
# Generator version: opda-gen-1.0.2
# Source commit: pinned-by-ADR-0026
# Carries the opda:ufoCategory facet (ADR-0045 / ODR-0031):
# the owl:AnnotationProperty declaration, one inert string tag
# per class (the 9-term UFO axis), and opda:UFOCategoryScheme
# (gUFO closeMatch + OntoClean signatures, referenced-not-
# imported, never reasoned). The six foundation classes carry no
# DPV co-annotation (not PII-bearing); per-module DPV annotations
# live in opda-<module>-annotations.ttl.
# MUST NOT contain sh:* or owl:Class triples
# (ODR-0004 §3a three-graph separation).

@prefix dct: <http://purl.org/dc/terms/> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix opda: <https://opda.org.uk/pdtf/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://opda.org.uk/pdtf/graph/annotations>
    rdf:type owl:Ontology ;
    dct:title "OPDA Advisory Annotations Graph"@en ;
    opda:targetsClassGraph <https://opda.org.uk/pdtf/> .

opda:UFOCategoryScheme
    rdf:type skos:ConceptScheme ;
    skos:prefLabel "UFO Category Scheme"@en ;
    skos:definition "The nine UFO foundational meta-categories OPDA classifies its classes under. Each concept carries its OntoClean signature and a skos:closeMatch to the corresponding gUFO type where one exists. Referenced-not-imported; never reasoned over (ODR-0031 R2)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    dct:title "UFO Category Scheme"@en .

opda:CollectiveCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Collective"@en ;
    skos:definition "An aggregate of endurants with uniform membership (cf. gufo:Collection)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:Collection ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Collective" .

opda:EventCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Event"@en ;
    skos:definition "A perdurant (occurrent): an entity that unfolds in time and has temporal parts."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:Event ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Event" .

opda:InformationObjectCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Information Object"@en ;
    skos:definition "An informational artefact / information content entity (documentary). An OPDA domain category rather than a core UFO endurant universal — cf. IAO information content entity (ODR-0030 Rule 4 crosswalk)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Information Object" .

opda:QualityCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Quality"@en ;
    skos:definition "An individualised quality inhering in an endurant. Descends from DOLCE's Quality (Masolo et al., WonderWeb D18, 2003)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:Quality ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Quality" .

opda:QualityValueCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Quality Value"@en ;
    skos:definition "The value of a quality — its position (Quale) in a quality region / space. Descends from DOLCE's Quale-in-Region (Masolo et al., WonderWeb D18, 2003)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Quality Value" .

opda:RelatorCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Relator"@en ;
    skos:definition "A relational endurant founded by an event, mediating two or more bearers (OntoClean +R, +I, +D). The relational-reification primitive (ODR-0030): it owns the relation's aggregation/modal attributes."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:Relator ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Relator" .

opda:RoleCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Role"@en ;
    skos:definition "An anti-rigid, externally-founded sortal role played by a single Kind (OntoClean −R, +D)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:Role ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Role" .

opda:RoleMixinCategory
    rdf:type skos:Concept ;
    skos:prefLabel "RoleMixin"@en ;
    skos:definition "An anti-rigid, externally-founded, dispersive (cross-sortal) role (OntoClean −R, +D) that spans more than one Kind."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:RoleMixin ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "RoleMixin" .

opda:SubstanceKindCategory
    rdf:type skos:Concept ;
    skos:prefLabel "Substance Kind"@en ;
    skos:definition "A rigid sortal (OntoClean +R, +O) that supplies its own principle of identity — instances are necessarily of this type, and it carries an identity criterion its instances inherit."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    skos:closeMatch gufo:Kind ;
    skos:inScheme opda:UFOCategoryScheme ;
    skos:notation "Substance Kind" .

opda:ontoCleanDependence
    rdf:type owl:AnnotationProperty ;
    rdfs:label "OntoClean dependence"@en ;
    rdfs:comment "OntoClean dependence meta-property (ADR-0046 / council session-042). owl:AnnotationProperty — annotation-graph-only, OWL 2 §10.1 inert. Value: 'dependent' (+D, externally founded). Emitted ONLY for the Relator family (Relator, Transaction, Proprietorship) where the Relator-founds-RoleMixin topology turned on dependence (session-042 ±D rule: ±D only where a Relator decision turned on it). NEVER opda:ontoCleanUnity."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/adr/ADR-0046>, <https://opda.org.uk/pdtf/harness/odr/ODR-0031> .

opda:ontoCleanIdentity
    rdf:type owl:AnnotationProperty ;
    rdfs:label "OntoClean identity"@en ;
    rdfs:comment "OntoClean identity meta-property (ADR-0046 / council session-042). owl:AnnotationProperty — annotation-graph-only, OWL 2 §10.1 inert. Values: 'supplies-IC' (+I, the type supplies an IC), 'carries-IC' (inherits IC from supertype/category), 'no-own-IC' (−I, borrows IC from bearer — Roles and RoleMixins). Derived from each type's opda:ufoCategory signature."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/adr/ADR-0046>, <https://opda.org.uk/pdtf/harness/odr/ODR-0031> .

opda:ontoCleanRigidity
    rdf:type owl:AnnotationProperty ;
    rdfs:label "OntoClean rigidity"@en ;
    rdfs:comment "OntoClean rigidity meta-property (ADR-0046 / council session-042). owl:AnnotationProperty — annotation-graph-only, OWL 2 §10.1 inert. Values: 'rigid' (+R), 'anti-rigid' (−R), 'semi-rigid', 'non-rigid'. Scope: the subsumption lattice the TBox OntoClean meta-shape ranges over (Relator, Transaction, Proprietorship, Role, Proprietor, RoleMixin, Buyer, Seller) + their contrast set. Derived from each type's opda:ufoCategory signature; NEVER opda:ontoCleanUnity. Consumed by the TBox OntoClean meta-shape CI gate (ADR-0046 §change 3+4)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/adr/ADR-0046>, <https://opda.org.uk/pdtf/harness/odr/ODR-0031> .

opda:ufoCategory
    rdf:type owl:AnnotationProperty ;
    rdfs:label "UFO category"@en ;
    rdfs:comment "The UFO foundational meta-category of an ontology class — one of Substance Kind / Information Object / Event / Relator / RoleMixin / Role / Quality / Quality Value / Collective. A documentary annotation (owl:AnnotationProperty — no logical axioms, OWL 2 §10.1): it records the design-time foundational commitment without entailing anything (the classification doctrine keeps kinds as facets, not subclass trees — ODR-0027). The category resource (opda:UFOCategoryScheme) carries the gUFO alignment and the OntoClean signature; this predicate carries the inert string tag, keyed to the concept's skos:notation (ODR-0031)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0011/section-8a>, <https://opda.org.uk/pdtf/harness/odr/ODR-0031> ;
    rdfs:range xsd:string ;
    skos:scopeNote "UFO-informed, not UFO-grounded — the wire format reasons with nothing UFO-shaped (ODR-0030 Rule 7). (i) The categories are UFO's (Guizzardi 2005). (ii) UFO's quality categories (Quality, Quality Value) descend from DOLCE's Quality / Quale / Region (Masolo et al., WonderWeb D18, 2003). (iii) The majority of OPDA's quality-tagged properties fall under that DOLCE-derived apparatus. Annotation-graph-only and referenced-not-imported to gUFO; never reasoned over (ODR-0031 R2; ODR-0030 Rule 1)."@en .

