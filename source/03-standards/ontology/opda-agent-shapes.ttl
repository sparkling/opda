<https://opda.org.uk/pdtf/shape/RelatorSpineSubjectShape>
    rdf:type sh:NodeShape ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0006/section-Q3> ;
    sh:class opda:Relator ;
    sh:message "opda:founds / opda:mediates are the Relator spine: every SUBJECT of either MUST be an opda:Relator (Council session-047 Q5 subject-guard — makes the relator entailment conservative-by-construction; ODR-0006 §Q3). Design-time + SHACL-validated, never reasoned."@en ;
    sh:severity sh:Violation ;
    sh:targetSubjectsOf opda:founds, opda:mediates .

