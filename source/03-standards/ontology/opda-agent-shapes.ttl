    sh:property _:b0fb940433a06 ;
    sh:targetClass opda:Organisation .

<https://opda.org.uk/pdtf/shape/OwnerTypeValueShape>
    rdf:type sh:NodeShape ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0024/section-Rules-R6> ;
    sh:property _:b52342e4c789f ;
    sh:targetSubjectsOf opda:ownerType .

<https://opda.org.uk/pdtf/shape/PersonIdentityKeyShape>
    rdf:type sh:NodeShape ;
