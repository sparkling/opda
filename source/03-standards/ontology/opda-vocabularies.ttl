opda:RoleScheme
    rdf:type skos:ConceptScheme ;
    skos:prefLabel "Participant Role"@en ;
    skos:definition "Role labels for the anti-rigid Roles a Person/Organisation plays as a Participant in a Transaction Relator."@en ;
