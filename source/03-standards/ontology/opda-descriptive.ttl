    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.isStudentAccommodation> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:landlordInsuresIfFlat
    rdf:type owl:DatatypeProperty ;
    rdfs:label "landlord insures if flat"@en ;
    rdfs:comment "Whether the landlord arranges buildings insurance (flat). Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.insurance.landlordInsuresIfFlat> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:landlordNotifiedOfSale
    rdf:type owl:DatatypeProperty ;
    rdfs:label "landlord notified of sale"@en ;
    rdfs:comment "Whether the landlord has been notified of the sale (Building Safety Act). Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingSafetyAct.landlordNotifiedOfSale> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:length
    rdf:type owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Length of a room in metres (xsd:decimal) — a Quale-in-Region field of the opda:RoomDimension value structure. Metres by convention (NO opda:UnitOfLengthScheme — session-030 / ODR-0024 R10, reusing the opda:area no-unit-scheme precedent). Flat per ODR-0008 §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.roomDimensions.rooms[].length> ;
    rdfs:domain opda:RoomDimension ;
    rdfs:range xsd:decimal .

opda:listedDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "listed date"@en ;
    rdfs:comment "Date a comparable property was listed for sale. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].propertyListingInfo.listedDate> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:date .

opda:localAuthorityName
    rdf:type owl:DatatypeProperty ;
    rdfs:label "local authority name"@en ;
    rdfs:comment "Name of the local authority that issued / governs a Search. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localAuthority.localAuthorityName> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:localAuthorityReference
    rdf:type owl:DatatypeProperty ;
    rdfs:label "local authority reference"@en ;
    rdfs:comment "Reference identifying a Search within the local authority's system. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localAuthority.localAuthorityReference> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:loftBoarded
    rdf:type owl:DatatypeProperty ;
    rdfs:label "loft boarded"@en ;
    rdfs:comment "Whether the Property's loft is boarded. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.typeOfConstruction.loft.loftBoarded> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:loftInsulated
    rdf:type owl:DatatypeProperty ;
    rdfs:label "loft insulated"@en ;
    rdfs:comment "Whether the Property's loft is insulated. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.typeOfConstruction.loft.loftInsulated> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:managementPlanInPlace
    rdf:type owl:DatatypeProperty ;
    rdfs:label "management plan in place"@en ;
    rdfs:comment "Whether a Japanese-knotweed management plan is in place. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.specialistIssues.japaneseKnotweed.managementPlanInPlace> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:mediaUrl
    rdf:type owl:DatatypeProperty ;
    rdfs:label "media URL"@en ;
    rdfs:comment "URL of a media item (property image / floorplan / etc.). xsd:anyURI. Domain-less artefact-reference attribute; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.media[].mediaUrl>, <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].media[].mediaUrl> ;
    rdfs:range xsd:anyURI .

opda:orderDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "order date"@en ;
    rdfs:comment "Date a Search was ordered. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].orderDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:organisesBuildingInsurance
    rdf:type owl:DatatypeProperty ;
    rdfs:label "organises building insurance"@en ;
    rdfs:comment "Whether the service contact organises buildings insurance. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.organisesBuildingInsurance> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:otherRating
    rdf:type owl:DatatypeProperty ;
    rdfs:label "other rating"@en ;
    rdfs:comment "Other (non-Ofsted) rating of a nearby school. Domain opda:NearbyFacility (the genus bearer; the school band is SHACL-scoped per ODR-0024 R4). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].otherRating> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range xsd:string .

opda:outstandingEnforcementAction
    rdf:type owl:DatatypeProperty ;
    rdfs:label "outstanding enforcement action"@en ;
    rdfs:comment "Whether there is outstanding enforcement action (managed-area risk assessment). Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.outstandingEnforcementAction> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:planningStartDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "planning start date"@en ;
    rdfs:comment "Start date of a planning matter in a local-authority Search result. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningStartDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:price
    rdf:type owl:DatatypeProperty ;
    rdfs:label "price"@en ;
    rdfs:comment "Monetary amount asked for a fixtures-and-fittings item included in a sale (a number in the data dictionary). A single shared fixtures monetary amount reused across all fixtures items — ODR-0022 §4 forbids minting one price property per item. Bound on the transaction-scoped fixtures-list node alongside opda:inclusionStatus. The Category-D fixtures amount ONLY — the Category-G headline / recurring / refundable monetary leaves (asking price, ground rent, deposit, service charge, fee …) do NOT reuse it (ODR-0022 §1 / G1). The value-structured opda:MonetaryAmount value type now EXISTS (the Category-G monetary walk, ODR-0024 R3); opda:price deliberately remains a single-currency interim decimal for the fixtures amount and is NOT migrated to it."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0022/section-Rules-4> ;
    rdfs:range xsd:decimal .

opda:pricingMethodology
    rdf:type owl:DatatypeProperty ;
    rdfs:label "pricing methodology"@en ;
    rdfs:comment "Methodology used to derive a Valuation's price estimate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyPricing.priceEstimationDetails.pricingMethodology> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:string .

opda:productCode
    rdf:type owl:DatatypeProperty ;
    rdfs:label "product code"@en ;
    rdfs:comment "Provider product code identifying a Search product. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].productCode> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:providerName
    rdf:type owl:DatatypeProperty ;
    rdfs:label "provider name"@en ;
    rdfs:comment "Name of the Search provider. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].providerName> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:providerReference
    rdf:type owl:DatatypeProperty ;
    rdfs:label "provider reference"@en ;
    rdfs:comment "Provider's reference for a Search. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].providerReference> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:pupils
    rdf:type owl:DatatypeProperty ;
    rdfs:label "pupils"@en ;
    rdfs:comment "Number of pupils at a nearby school. Domain opda:NearbyFacility (the genus bearer; the school band is SHACL-scoped per ODR-0024 R4). Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].pupils> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range xsd:integer .

opda:refNumber
    rdf:type owl:DatatypeProperty ;
    rdfs:label "reference number"@en ;
    rdfs:comment "Application/case reference number on a planning / building-control result. ONE shared property; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.buildingRegulationsApproval[].refNumber>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].refNumber> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:regulatedSearchTurnaroundTimeInWorkingDays
    rdf:type owl:DatatypeProperty ;
    rdfs:label "regulated search turnaround time in working days"@en ;
    rdfs:comment "Quoted turnaround time (working days) for a regulated search. Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localAuthority.regulatedSearchTurnaroundTimeInWorkingDays> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:integer .

opda:religiousCharacter
    rdf:type owl:DatatypeProperty ;
    rdfs:label "religious character"@en ;
    rdfs:comment "Religious character of a nearby school. Domain opda:NearbyFacility (the genus bearer; the school band is SHACL-scoped per ODR-0024 R4). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].religiousCharacter> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range xsd:string .

opda:reportDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "report date"@en ;
    rdfs:comment "Date a Search / survey report was produced. xsd:date. ONE shared property reused across search and survey reports; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].reportDate>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.surveys[].misc.reportDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:retrievedOn
    rdf:type owl:DatatypeProperty ;
    rdfs:label "retrieved on"@en ;
    rdfs:comment "Date a title / additional document was retrieved from the registry. xsd:date. Domain opda:AttachedDocument (the neutral document bearer; ODR-0024 R7); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].additionalDocuments[].retrievedOn> ;
    rdfs:domain opda:AttachedDocument ;
    rdfs:range xsd:date .

opda:roomName
    rdf:type owl:DatatypeProperty ;
    rdfs:label "room name"@en ;
    rdfs:comment "Name of a room (xsd:string) — a NON-RIGID label on the opda:RoomDimension value structure, NOT an identity principle and never a key (ODR-0024 R10 / session-030). Flat per ODR-0008 §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.roomDimensions.rooms[].roomName> ;
    rdfs:domain opda:RoomDimension ;
    rdfs:range xsd:string .

opda:saleAtUndervalue
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sale at undervalue"@en ;
    rdfs:comment "Whether the sale is at undervalue. Yes/No disclosure (price information); xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.priceInformation.saleAtUndervalue> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:schoolType
    rdf:type owl:DatatypeProperty ;
    rdfs:label "school type"@en ;
    rdfs:comment "Band of a nearby school per opda:SchoolTypeScheme (College / Nursery / Primary / Secondary / Private). Domain opda:NearbyFacility (the genus bearer; the school band is SHACL-scoped per ODR-0024 R4). ONE shared datatype property over the SchoolTypeScheme value-space — replaces the five range-less generic object properties (opda:college / nursery / primary / secondary / private) the council rejected as permanent-namespace landmines (session-028 Q1). Constrained by SHACL sh:in to the scheme members in the overlay profile. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].schoolType.college>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].schoolType.nursery>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].schoolType.primary>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].schoolType.private>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].schoolType.secondary> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range xsd:string .

opda:sellerCompletedDeedOfCertificate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "seller completed deed of certificate"@en ;
    rdfs:comment "Whether the seller completed a deed of certificate (Building Safety Act). Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingSafetyAct.deedOfCertificateServed.sellerCompletedDeedOfCertificate> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:sellerOwnedProperty
    rdf:type owl:DatatypeProperty ;
    rdfs:label "seller owned property"@en ;
    rdfs:comment "Whether the seller owned the property for enfranchisement qualification. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.enfranchisement.sellerOwnedProperty> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:soldDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sold date"@en ;
    rdfs:comment "Date a comparable property was sold (valuation comparable listing info). xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].propertyListingInfo.soldDate> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:date .

opda:specialties
    rdf:type owl:DatatypeProperty ;
    rdfs:label "specialties"@en ;
    rdfs:comment "Specialties of a nearby health-care facility (a multi-valued list — each value an xsd:string). Domain opda:NearbyFacility (the genus bearer; the health-care band is SHACL-scoped per ODR-0024 R4). Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.healthCare[].specialties> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range xsd:string .

opda:status
    rdf:type owl:DatatypeProperty ;
    rdfs:label "status"@en ;
    rdfs:comment "Status of a search-derived result item — planning permission, designation plan, road-adoption status, or search-order status. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a. (FLAG: polysemous across those contexts; placed on opda:Search; the data dictionary's three context-specific status enums are sh:in-restricted per-context in the overlay profile, not unified into one value-space.)"@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].status>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.roadsAndPublicRightsOfWay.roadsFootwaysAndFootpaths.subjectToAdoption[].status>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].status> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:statusDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "status date"@en ;
    rdfs:comment "Date a designation plan's status was set in a local-authority Search result. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[].statusDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:subCategory
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sub-category"@en ;
    rdfs:comment "Sub-category of an environmental-peril RiskAssessment (riskSubcategories[] across the climate / coal-mining / flooding / ground-stability / radon / etc. peril blocks). ONE shared property on opda:RiskAssessment. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[].subCategory>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[].subCategory> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range xsd:string .

opda:typeOfHealthCare
    rdf:type owl:DatatypeProperty ;
    rdfs:label "type of health care"@en ;
    rdfs:comment "Type of a nearby health-care facility. Domain opda:NearbyFacility (the genus bearer; the health-care band is SHACL-scoped per ODR-0024 R4). Plain string datatype per ODR-0008 §Q5a (no ontology-governed enum in the data dictionary); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.healthCare[].typeOfHealthCare> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range xsd:string .

opda:unitaryAuthority
    rdf:type owl:DatatypeProperty ;
    rdfs:label "unitary authority"@en ;
    rdfs:comment "Name of the unitary authority for the Property's locality. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localAuthority.unitaryAuthority> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:urgentWorksCarriedOut
    rdf:type owl:DatatypeProperty ;
    rdfs:label "urgent works carried out"@en ;
    rdfs:comment "Whether urgent works were carried out (managed-area risk assessment). Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.urgentWorksCarriedOut> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:urgentWorksRecommended
    rdf:type owl:DatatypeProperty ;
    rdfs:label "urgent works recommended"@en ;
    rdfs:comment "Whether urgent works were recommended (managed-area risk assessment). Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingsInsurance.managedAreasCoveredByPolicy.riskAssessments.urgentWorksRecommended> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:url
    rdf:type owl:DatatypeProperty ;
    rdfs:label "URL"@en ;
    rdfs:comment "URL of an external artefact (contract template, planning-permission page). xsd:anyURI. Domain-less artefact-reference attribute; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/contracts[].contract.template.url>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].url> ;
    rdfs:range xsd:anyURI .

opda:width
    rdf:type owl:DatatypeProperty ;
    rdfs:label "width"@en ;
    rdfs:comment "Width of a room in metres (xsd:decimal) — a Quale-in-Region field of the opda:RoomDimension value structure. Metres by convention (no opda:UnitOfLengthScheme). Flat per ODR-0008 §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.roomDimensions.rooms[].width> ;
    rdfs:domain opda:RoomDimension ;
    rdfs:range xsd:decimal .

opda:willingToInsure
    rdf:type owl:DatatypeProperty ;
    rdfs:label "willing to insure"@en ;
    rdfs:comment "Whether an insurer is willing to insure against an unresolved planning issue. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.alterationsAndChanges.unresolvedPlanningIssues.willingToInsure> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:yield
    rdf:type owl:DatatypeProperty ;
    rdfs:label "yield"@en ;
    rdfs:comment "Rental yield in a Valuation's pricing analysis. xsd:decimal. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyPricing.yield> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:decimal .

opda:annualCostOfPermit
    rdf:type owl:ObjectProperty ;
    rdfs:label "annual cost of permit"@en ;
    rdfs:comment "Annual cost of a controlled-parking permit for the Property. Bearer opda:Property. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.parking.controlledParking.annualCostOfPermit> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:MonetaryAmount .

opda:annualGroundRent
    rdf:type owl:ObjectProperty ;
    rdfs:label "annual ground rent"@en ;
    rdfs:comment "Annual ground rent payable under a leasehold estate. Bearer opda:LegalEstate (a tenure charge of the leasehold, not a Quality of the brick-and-mortar Property). → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.groundRent.annualGroundRent> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range opda:MonetaryAmount .

opda:annualServiceCharge
    rdf:type owl:ObjectProperty ;
    rdfs:label "annual service charge"@en ;
    rdfs:comment "Annual service charge payable under a leasehold or managed freehold/commonhold estate. Bearer opda:LegalEstate. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.annualServiceCharge>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.annualServiceCharge> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range opda:MonetaryAmount .

opda:certificateOfComplianceFee
    rdf:type owl:ObjectProperty ;
    rdfs:label "certificate of compliance fee"@en ;
    rdfs:comment "Fee for a certificate of compliance required on a leasehold transfer (required-documents block). Bearer opda:LegalEstate. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.requiredDocuments.certificateOfComplianceFee> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range opda:MonetaryAmount .

opda:constructionType
    rdf:type owl:ObjectProperty ;
    rdfs:label "construction type"@en ;
    rdfs:comment "Structural construction type of the Property (brick-and-block / timber frame / SIP / …) — value-space opda:ConstructionTypeScheme (ODR-0024 R6), sh:in-restricted via the descriptive enum shape. A Quale of opda:Property; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.surveys[].misc.constructionType> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:costsApplicableToTheDeed
    rdf:type owl:ObjectProperty ;
    rdfs:label "costs applicable to the deed"@en ;
    rdfs:comment "Costs applicable to a deed of covenant required on transfer. Bearer opda:Transaction (a completion/transfer cost, not a standing estate charge). → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.transferAndRegistration.deedOfCovenantRequired.costsApplicableToTheDeed> ;
    rdfs:domain opda:Transaction ;
    rdfs:range opda:MonetaryAmount .

opda:councilTaxAnnualCharge
    rdf:type owl:ObjectProperty ;
    rdfs:label "council tax annual charge"@en ;
    rdfs:comment "Annual council-tax charge for the Property. Bearer opda:Property (a recurring liability of the dwelling). → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.councilTax.councilTaxAnnualCharge> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:MonetaryAmount .

opda:currency
    rdf:type owl:ObjectProperty ;
    rdfs:label "currency"@en ;
    rdfs:comment "The currency of an opda:MonetaryAmount — a dereferenceable opda:CurrencyScheme concept (ISO-4217 alpha-3), NEVER an opaque string. The MonetaryAmount node shape makes it sh:minCount 1 (never absent on the value type) and sh:in-restricts it to the scheme; the overlay profile supplies GBP as the default (ODR-0024 R3)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0024/section-Rules-R3> ;
    rdfs:domain opda:MonetaryAmount ;
    rdfs:range skos:Concept .

opda:estimatedAmount
    rdf:type owl:ObjectProperty ;
    rdfs:label "estimated amount"@en ;
    rdfs:comment "Estimated rental amount in a Valuation's rental-estimate analysis. Bearer opda:Valuation. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyPricing.rentalEstimate.estimatedAmount> ;
    rdfs:domain opda:Valuation ;
    rdfs:range opda:MonetaryAmount .

opda:estimatedPrice
    rdf:type owl:ObjectProperty ;
    rdfs:label "estimated price"@en ;
    rdfs:comment "Estimated sale price in a Valuation's pricing analysis. Bearer opda:Valuation. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyPricing.estimatedPrice> ;
    rdfs:domain opda:Valuation ;
    rdfs:range opda:MonetaryAmount .

opda:feeIncludingVAT
    rdf:type owl:ObjectProperty ;
    rdfs:label "fee including VAT"@en ;
    rdfs:comment "Fee (including VAT) charged by a party for serving a notice of transfer / assignment / charge during conveyancing. Bearer opda:Transaction (a transfer-process fee). → opda:MonetaryAmount (ODR-0024 R3); ONE shared property across the notice-fee blocks; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.landlord.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.managementCompany.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.managingAgent.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfAssignmentAndCharge.other.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfTransferAndCharge.legalRepresentative.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfTransferAndCharge.managementCompany.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfTransferAndCharge.managingAgent.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfTransferAndCharge.other.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.contactDetails.serviceContactAssignments.noticeOfTransferAndCharge.rentchargeOwner.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.contactDetails.noticeOfTransferAndCharge.legalRepresentative.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.contactDetails.noticeOfTransferAndCharge.managementCompany.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.contactDetails.noticeOfTransferAndCharge.managingAgent.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.contactDetails.noticeOfTransferAndCharge.other.feeIncludingVAT>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.contactDetails.noticeOfTransferAndCharge.rentchargeOwner.feeIncludingVAT> ;
    rdfs:domain opda:Transaction ;
    rdfs:range opda:MonetaryAmount .

opda:hasRoomDimension
    rdf:type owl:ObjectProperty ;
    rdfs:label "has room dimension"@en ;
    rdfs:comment "Relates an opda:Property to a room-dimension value structure (one per room in roomDimensions.rooms[]). Characterisation of a value, NOT mereological parthood (no opda:Room individual is asserted) and NOT transitive (Council session-030 / ODR-0024 R10)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0024/section-Rules-R10> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:RoomDimension .

opda:hasSubAssessment
    rdf:type owl:ObjectProperty ;
    rdfs:label "has sub-assessment"@en ;
    rdfs:comment "Self-referential mereological part-of: a riskSubcategories[] entry is itself a leaf opda:RiskAssessment (ODR-0008d Rule 4). The node shape realises the recursion via sh:node opda:RiskAssessment. This is the RESULT-recursion axis; the peril → sub-peril TAXONOMY axis is skos:narrower within opda:PerilScheme — two distinct axes (Rule 4)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008d/section-Rule-4> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range opda:RiskAssessment .

opda:holdingDeposit
    rdf:type owl:ObjectProperty ;
    rdfs:label "holding deposit"@en ;
    rdfs:comment "Holding deposit in the Property's letting information (refundable — distinct value semantics from a sale price). Bearer opda:Property. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.lettingInformation.holdingDeposit> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:MonetaryAmount .

opda:inclusionStatus
    rdf:type owl:ObjectProperty ;
    rdfs:label "inclusion status"@en ;
    rdfs:comment "Whether a fixtures-and-fittings item is Included in, Excluded from, or absent (None) from a sale. A UFO Mode/Relator of the sale TRANSACTION (ODR-0007), confirmed by session-027 R4 — NOT a Quality of opda:Property (the same item is included in one sale and absent from the next, so inclusion has no rigid bearer in the brick-and-mortar). Bound on a transaction-scoped fixtures-list node (NEVER rdfs:domain opda:Property), ranging over the opda:InclusionStatusScheme value-space (Included / Excluded / None). The full sale-transaction Relator identity criterion is owned by ODR-0007."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0022/section-Rules-4> ;
    rdfs:range skos:Concept .

opda:listPrice
    rdf:type owl:ObjectProperty ;
    rdfs:label "list price"@en ;
    rdfs:comment "List price of a comparable property (valuation comparable listing info). Bearer opda:Valuation. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].propertyListingInfo.listPrice> ;
    rdfs:domain opda:Valuation ;
    rdfs:range opda:MonetaryAmount .

opda:marketingTenure
    rdf:type owl:ObjectProperty ;
    rdfs:label "marketing tenure"@en ;
    rdfs:comment "Marketed tenure of the Property (Freehold / Leasehold / Commonhold) — value-space the existing opda:TenureKindScheme (ODR-0024 R6: reuse-before-mint, NOT a third tenure scheme), sh:in-restricted via the descriptive enum shape. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.marketingTenure> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:ofstedRating
    rdf:type owl:ObjectProperty ;
    rdfs:label "Ofsted rating"@en ;
    rdfs:comment "Ofsted rating of a nearby school (Outstanding / Good / …) — value-space opda:OfstedRatingScheme (ODR-0024 R6), sh:in-restricted via the descriptive enum shape. Domain opda:NearbyFacility (the genus bearer). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.schools[].ofstedRating> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range skos:Concept .

opda:peril
    rdf:type owl:ObjectProperty ;
    rdfs:label "peril"@en ;
    rdfs:comment "The environmental / search peril a RiskAssessment reports on — a dereferenceable opda:PerilScheme concept (ODR-0008d Rule 1c / Rule 2), NEVER an opaque string. The node shape restricts the value to the PerilScheme concepts via sh:in."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008d/section-Rule-1> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range skos:Concept .

opda:potentialCost
    rdf:type owl:ObjectProperty ;
    rdfs:label "potential cost"@en ;
    rdfs:comment "Potential remediation cost in the Property's building-safety disclosure (council session-028 Q3 re-filed this monetary leaf from free-text to the monetary walk; the data-dictionary source is free text, so the magnitude is best-effort). Bearer opda:Property. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.typeOfConstruction.buildingSafety.potentialCost> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:MonetaryAmount .

opda:priceQualifier
    rdf:type owl:ObjectProperty ;
    rdfs:label "price qualifier"@en ;
    rdfs:comment "Qualifier on the marketed price (Guide price / Offers over / …) — value-space opda:PriceQualifierScheme (ODR-0024 R6), sh:in-restricted via the descriptive enum shape. Borne on opda:Property (the marketing price information); the Mode-vs-Quality nuance is held by session-029. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.priceInformation.priceQualifier> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:rent
    rdf:type owl:ObjectProperty ;
    rdfs:label "rent"@en ;
    rdfs:comment "Rent in the Property's letting information. Bearer opda:Property (letting terms of the dwelling; no Tenancy Kind is minted — promote on a named query). → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.lettingInformation.rent> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:MonetaryAmount .

opda:riskIndicator
    rdf:type owl:ObjectProperty ;
    rdfs:label "risk indicator"@en ;
    rdfs:comment "Whether action is recommended / the property is at risk for the RiskAssessment's peril (No / Not known / Yes). Value-space reuses opda:YesNoNotKnownScheme (a duplicate scheme would violate ODR-0022 Category C); the node shape sh:in-restricts it (ODR-0008d Rule 1c / Rule 4)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008d/section-Rule-4> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range skos:Concept .

opda:securityDeposit
    rdf:type owl:ObjectProperty ;
    rdfs:label "security deposit"@en ;
    rdfs:comment "Security/tenancy deposit in the Property's letting information (refundable). Bearer opda:Property. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.lettingInformation.securityDeposit> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:MonetaryAmount .

opda:sharedOwnershipRent
    rdf:type owl:ObjectProperty ;
    rdfs:label "shared ownership rent"@en ;
    rdfs:comment "Rent payable on the retained share under a shared-ownership lease. Bearer opda:LegalEstate. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.sharedOwnership.sharedOwnershipRent> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range opda:MonetaryAmount .

opda:soldPrice
    rdf:type owl:ObjectProperty ;
    rdfs:label "sold price"@en ;
    rdfs:comment "Sold price of a comparable property (valuation comparable listing info). Bearer opda:Valuation. → opda:MonetaryAmount (ODR-0024 R3); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].propertyListingInfo.soldPrice> ;
    rdfs:domain opda:Valuation ;
    rdfs:range opda:MonetaryAmount .

opda:transportType
    rdf:type owl:ObjectProperty ;
    rdfs:label "transport type"@en ;
    rdfs:comment "Type of a nearby transport facility (rail station / bus stop / …) — value-space opda:TransportTypeScheme (ODR-0024 R6), sh:in-restricted via the descriptive enum shape. Domain opda:NearbyFacility (the genus bearer, as opda:schoolType). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.nearbyFacilities.transport[].transportType> ;
    rdfs:domain opda:NearbyFacility ;
    rdfs:range skos:Concept .

opda:typeOfConnection
    rdf:type owl:ObjectProperty ;
    rdfs:label "type of connection"@en ;
    rdfs:comment "Broadband connection type of the Property (FTTP / FTTC / cable / …) — value-space opda:BroadbandConnectionTypeScheme (ODR-0024 R6), sh:in-restricted via the descriptive enum shape. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.connectivity.broadband.typeOfConnection> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .
