    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.isLimitedCompanySale> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:isManagingAgentEmployed
    rdf:type owl:DatatypeProperty ;
