    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.ownershipAndManagement.freeholdOwner> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:fromTheOwners
    rdf:type owl:DatatypeProperty ;
    rdfs:label "from the owners"@en ;
