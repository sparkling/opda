    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:hasFloorplan
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has floorplan"@en ;
    rdfs:comment "Whether a floorplan is available for the Property. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.roomDimensions.hasFloorplan> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:hasHelpToBuyEquityLoan
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has Help to Buy equity loan"@en ;
    rdfs:comment "Whether the Property has a Help to Buy equity loan. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.hasHelpToBuyEquityLoan> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:hasLift
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has lift"@en ;
    rdfs:comment "Whether the Property (building) has a lift. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.building.hasLift> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:hasTenantCompanyDissolved
    rdf:type owl:DatatypeProperty ;
    rdfs:label "has tenant company dissolved"@en ;
    rdfs:comment "Whether the tenant management company has been dissolved. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.ownershipAndManagement.hasTenantCompanyDissolved> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:headLeaseholderControlled
    rdf:type owl:DatatypeProperty ;
    rdfs:label "head leaseholder controlled"@en ;
    rdfs:comment "Whether the head lease is leaseholder-controlled. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.ownershipAndManagement.hasHeadlease.headLeaseholderControlled> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:isConnectedToNationalGrid
    rdf:type owl:DatatypeProperty ;
    rdfs:label "is connected to national grid"@en ;
    rdfs:comment "Whether the Property's solar panels are connected to the national grid. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.solarPanels.isConnectedToNationalGrid> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:isFirstRegistration
    rdf:type owl:DatatypeProperty ;
    rdfs:label "is first registration"@en ;
    rdfs:comment "Whether the sale is a first registration of the title. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.isFirstRegistration> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:isHMO
    rdf:type owl:DatatypeProperty ;
    rdfs:label "is HMO"@en ;
    rdfs:comment "Whether the Property is a House in Multiple Occupation. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.isHMO> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:isLeaseQualifying
    rdf:type owl:DatatypeProperty ;
    rdfs:label "is lease qualifying"@en ;
    rdfs:comment "Whether the lease is a qualifying lease under the Building Safety Act. Yes/No disclosure; xsd:string per §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingSafetyAct.isLeaseQualifying> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:isLimitedCompanySale
    rdf:type owl:DatatypeProperty ;
    rdfs:label "is limited company sale"@en ;
