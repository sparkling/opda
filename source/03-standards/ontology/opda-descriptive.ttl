opda:documentDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "document date"@en ;
    rdfs:comment "Date of a title / additional document. xsd:date. Domain opda:AttachedDocument (the neutral document bearer; ODR-0024 R7 — an attached doc is NOT evidence by mere attachment; a document plays the evidence role via opda:evidenceType, ODR-0027 §R6); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].additionalDocuments[].documentDate>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.documentDetails.document.documentDate> ;
    rdfs:domain opda:AttachedDocument ;
    rdfs:range xsd:date .

opda:documentTypeCode
    rdf:type owl:DatatypeProperty ;
    rdfs:label "document type code"@en ;
    rdfs:comment "Type code of a title / additional document. Domain opda:AttachedDocument (the neutral document bearer; ODR-0024 R7). Plain string datatype per ODR-0008 §Q5a (no in-data enum; session-028 Q-SKOS keeps it bare); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].additionalDocuments[].documentTypeCode> ;
    rdfs:domain opda:AttachedDocument ;
    rdfs:range xsd:string .

opda:expectedDeliveryDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "expected delivery date"@en ;
    rdfs:comment "Expected delivery date for an ordered Search. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.searches[].expectedDeliveryDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:filedUnder
    rdf:type owl:DatatypeProperty ;
    rdfs:label "filed under"@en ;
    rdfs:comment "Filing reference under which a title / additional document is held. Domain opda:AttachedDocument (the neutral document bearer; ODR-0024 R7); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].additionalDocuments[].filedUnder>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.documentDetails.document.filedUnder> ;
    rdfs:domain opda:AttachedDocument ;
    rdfs:range xsd:string .

