    rdfs:range xsd:string .

opda:inclusionStatus
    rdf:type owl:DatatypeProperty ;
    rdfs:label "inclusion status"@en ;
    rdfs:comment "Whether a fixtures-and-fittings item is Included in, Excluded from, or absent (None) from a sale. A UFO Mode/Relator of the sale TRANSACTION (ODR-0007), confirmed by session-027 R4 — NOT a Quality of opda:Property (the same item is included in one sale and absent from the next, so inclusion has no rigid bearer in the brick-and-mortar). Bound on a transaction-scoped fixtures-list node (NEVER rdfs:domain opda:Property), ranging over the opda:InclusionStatusScheme value-space (Included / Excluded / None). The full sale-transaction Relator identity criterion is owned by ODR-0007."@en ;
    dct:source <https://w3id.org/opda/odr/ODR-0022#section-Rules-4> ;
    rdfs:range xsd:string .

