opda:price
    rdf:type owl:DatatypeProperty ;
    rdfs:label "price"@en ;
    rdfs:comment "Monetary amount asked for a fixtures-and-fittings item included in a sale (a number in the data dictionary). ONE shared monetary-amount property reused across all fixtures items — ODR-0022 §4 mandates reusing a MonetaryAmount pattern, NEVER minting one price property per item. Bound on the transaction-scoped fixtures-list node alongside opda:inclusionStatus."@en ;
    dct:source <https://w3id.org/opda/odr/ODR-0022#section-Rules-4> ;
    rdfs:range xsd:decimal .

opda:pricingMethodology
    rdf:type owl:DatatypeProperty ;
    rdfs:label "pricing methodology"@en ;
    rdfs:comment "Methodology used to derive a Valuation's price estimate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#valuationComparisonData.propertyPricing.priceEstimationDetails.pricingMethodology> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:string .

opda:productCode
    rdf:type owl:DatatypeProperty ;
    rdfs:label "product code"@en ;
    rdfs:comment "Provider product code identifying a Search product. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.searches[].productCode> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:providerName
    rdf:type owl:DatatypeProperty ;
    rdfs:label "provider name"@en ;
    rdfs:comment "Name of the Search provider. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.searches[].providerName> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:providerReference
    rdf:type owl:DatatypeProperty ;
    rdfs:label "provider reference"@en ;
    rdfs:comment "Provider's reference for a Search. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.searches[].providerReference> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:pupils
    rdf:type owl:DatatypeProperty ;
    rdfs:label "pupils"@en ;
    rdfs:comment "Number of pupils at a nearby school. Domain opda:School. Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].pupils> ;
    rdfs:domain opda:School ;
    rdfs:range xsd:integer .

opda:refNumber
    rdf:type owl:DatatypeProperty ;
    rdfs:label "reference number"@en ;
    rdfs:comment "Application/case reference number on a planning / building-control result. ONE shared property; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.buildingRegulationsApproval[].refNumber>, <https://w3id.org/opda/data-dictionary#propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].refNumber> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:regulatedSearchTurnaroundTimeInWorkingDays
    rdf:type owl:DatatypeProperty ;
    rdfs:label "regulated search turnaround time in working days"@en ;
    rdfs:comment "Quoted turnaround time (working days) for a regulated search. Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.localAuthority.regulatedSearchTurnaroundTimeInWorkingDays> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:integer .

opda:religiousCharacter
    rdf:type owl:DatatypeProperty ;
    rdfs:label "religious character"@en ;
    rdfs:comment "Religious character of a nearby school. Domain opda:School. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].religiousCharacter> ;
    rdfs:domain opda:School ;
    rdfs:range xsd:string .

opda:reportDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "report date"@en ;
    rdfs:comment "Date a Search / survey report was produced. xsd:date. ONE shared property reused across search and survey reports; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.searches[].reportDate>, <https://w3id.org/opda/data-dictionary#propertyPack.surveys[].misc.reportDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:retrievedOn
    rdf:type owl:DatatypeProperty ;
    rdfs:label "retrieved on"@en ;
    rdfs:comment "Date a title / additional document was retrieved from the registry. xsd:date. Domain opda:Document (ODR-0009 document-evidence); flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.titlesToBeSold[].additionalDocuments[].retrievedOn> ;
    rdfs:domain opda:Document ;
    rdfs:range xsd:date .

opda:riskIndicator
    rdf:type owl:DatatypeProperty ;
    rdfs:label "risk indicator"@en ;
    rdfs:comment "Whether action is recommended / the property is at risk for the RiskAssessment's peril (No / Not known / Yes). Value-space reuses opda:YesNoNotKnownScheme (a duplicate scheme would violate ODR-0022 Category C); the node shape sh:in-restricts it (ODR-0008d Rule 1c / Rule 4)."@en ;
    dct:source <https://w3id.org/opda/odr/ODR-0008d#section-Rule-4> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range xsd:string .

opda:soldDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sold date"@en ;
    rdfs:comment "Date a comparable property was sold (valuation comparable listing info). xsd:date. Flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#valuationComparisonData.propertyDetails[].propertyListingInfo.soldDate> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:date .

opda:specialties
    rdf:type owl:DatatypeProperty ;
    rdfs:label "specialties"@en ;
    rdfs:comment "Specialties of a nearby health-care facility (a multi-valued list — each value an xsd:string). Domain opda:HealthCareFacility. Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.healthCare[].specialties> ;
    rdfs:domain opda:HealthCareFacility ;
    rdfs:range xsd:string .

opda:status
    rdf:type owl:DatatypeProperty ;
    rdfs:label "status"@en ;
    rdfs:comment "Status of a search-derived result item — planning permission, designation plan, road-adoption status, or search-order status. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a. (FLAG: polysemous across those contexts; placed on opda:Search; the data dictionary's three context-specific status enums are sh:in-restricted per-context in the overlay profile, not unified into one value-space.)"@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].status>, <https://w3id.org/opda/data-dictionary#propertyPack.localSearches.localAuthoritySearches.roadsAndPublicRightsOfWay.roadsFootwaysAndFootpaths.subjectToAdoption[].status>, <https://w3id.org/opda/data-dictionary#propertyPack.searches[].status> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:statusDate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "status date"@en ;
    rdfs:comment "Date a designation plan's status was set in a local-authority Search result. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.designationsAndProposals.plans[].statusDate> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:date .

opda:subCategory
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sub-category"@en ;
    rdfs:comment "Sub-category of an environmental-peril RiskAssessment (riskSubcategories[] across the climate / coal-mining / flooding / ground-stability / radon / etc. peril blocks). ONE shared property on opda:RiskAssessment. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.environmentalIssues.climate.climateRisk.riskSubcategories[].subCategory>, <https://w3id.org/opda/data-dictionary#propertyPack.environmentalIssues.flooding.floodRisk.riskSubcategories[].subCategory> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range xsd:string .

opda:typeOfHealthCare
    rdf:type owl:DatatypeProperty ;
    rdfs:label "type of health care"@en ;
    rdfs:comment "Type of a nearby health-care facility. Domain opda:HealthCareFacility. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.healthCare[].typeOfHealthCare> ;
    rdfs:domain opda:HealthCareFacility ;
    rdfs:range xsd:string .

opda:unitaryAuthority
    rdf:type owl:DatatypeProperty ;
    rdfs:label "unitary authority"@en ;
    rdfs:comment "Name of the unitary authority for the Property's locality. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.localAuthority.unitaryAuthority> ;
    rdfs:domain opda:Search ;
    rdfs:range xsd:string .

opda:url
    rdf:type owl:DatatypeProperty ;
    rdfs:label "URL"@en ;
    rdfs:comment "URL of an external artefact (contract template, planning-permission page). xsd:anyURI. Domain-less artefact-reference attribute; flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#contracts[].contract.template.url>, <https://w3id.org/opda/data-dictionary#propertyPack.localSearches.localAuthoritySearches.planningAndBuildingRegulations.decisionsAndPendingApplications.planningPermission[].url> ;
    rdfs:range xsd:anyURI .

opda:yield
    rdf:type owl:DatatypeProperty ;
    rdfs:label "yield"@en ;
    rdfs:comment "Rental yield in a Valuation's pricing analysis. xsd:decimal. Flat per §Q6a."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#valuationComparisonData.propertyPricing.yield> ;
    rdfs:domain opda:Valuation ;
    rdfs:range xsd:decimal .

opda:college
    rdf:type owl:ObjectProperty ;
    rdfs:label "college"@en ;
    rdfs:comment "Nearby college(s) — a band of the schoolType structure of opda:School (object-typed). Domain opda:School, range-less object property (the value is a structured school-band node)."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].schoolType.college> ;
    rdfs:domain opda:School .

opda:hasSubAssessment
    rdf:type owl:ObjectProperty ;
    rdfs:label "has sub-assessment"@en ;
    rdfs:comment "Self-referential mereological part-of: a riskSubcategories[] entry is itself a leaf opda:RiskAssessment (ODR-0008d Rule 4). The node shape realises the recursion via sh:node opda:RiskAssessment. This is the RESULT-recursion axis; the peril → sub-peril TAXONOMY axis is skos:narrower within opda:PerilScheme — two distinct axes (Rule 4)."@en ;
    dct:source <https://w3id.org/opda/odr/ODR-0008d#section-Rule-4> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range opda:RiskAssessment .

opda:nursery
    rdf:type owl:ObjectProperty ;
    rdfs:label "nursery"@en ;
    rdfs:comment "Nearby nursery(ies) — a band of the schoolType structure of opda:School. Domain opda:School, range-less object property."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].schoolType.nursery> ;
    rdfs:domain opda:School .

opda:peril
    rdf:type owl:ObjectProperty ;
    rdfs:label "peril"@en ;
    rdfs:comment "The environmental / search peril a RiskAssessment reports on — a dereferenceable opda:PerilScheme concept (ODR-0008d Rule 1c / Rule 2), NEVER an opaque string. The node shape restricts the value to the PerilScheme concepts via sh:in."@en ;
    dct:source <https://w3id.org/opda/odr/ODR-0008d#section-Rule-1> ;
    rdfs:domain opda:RiskAssessment ;
    rdfs:range skos:Concept .

opda:primary
    rdf:type owl:ObjectProperty ;
    rdfs:label "primary"@en ;
    rdfs:comment "Nearby primary school(s) — a band of the schoolType structure of opda:School. Domain opda:School, range-less object property."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].schoolType.primary> ;
    rdfs:domain opda:School .

opda:private
    rdf:type owl:ObjectProperty ;
    rdfs:label "private"@en ;
    rdfs:comment "Nearby private school(s) — a band of the schoolType structure of opda:School. Domain opda:School, range-less object property."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].schoolType.private> ;
    rdfs:domain opda:School .

opda:secondary
    rdf:type owl:ObjectProperty ;
    rdfs:label "secondary"@en ;
    rdfs:comment "Nearby secondary school(s) — a band of the schoolType structure of opda:School. Domain opda:School, range-less object property."@en ;
    dct:source <https://w3id.org/opda/data-dictionary#propertyPack.nearbyFacilities.schools[].schoolType.secondary> ;
    rdfs:domain opda:School .
