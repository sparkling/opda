    rdfs:label "last maintained"@en ;
    rdfs:comment "Date the Property's solar-panel system was last maintained. xsd:date. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.solarPanels.lastMaintained> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:date .

opda:lengthOfLeaseInYears
    rdf:type owl:DatatypeProperty ;
    rdfs:label "length of lease in years"@en ;
    rdfs:comment "Length of the leasehold term in years (the granted term). Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a. Complements opda:LeaseTerm (the OWL-Time interval) with the headline term-length figure."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.leaseTerm.lengthOfLeaseInYears> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:integer .

opda:location
    rdf:type owl:DatatypeProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "Physical-location description of a Property fixture or measurement point — electricity / gas / water meter, stopcock, or survey/charge locus (typed as a free-form string in the data dictionary). ONE shared location-description property reused across those points. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a. (FLAG: `propertyPack.location` is itself a structured geo block, not this leaf-level string; the structured locator is opda:Address territory — ODR-0015 — and is out of this leaf's scope.)"@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.mainsElectricity.electricityMeter.location>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.gasMeter.location>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.water.mainsWater.stopcock.location>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.water.mainsWater.waterMeter.location> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:logbookProvider
    rdf:type owl:DatatypeProperty ;
    rdfs:label "logbook provider"@en ;
    rdfs:comment "Name of the digital-property-logbook provider for the Property. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.completionAndMoving.digitalPropertyLogbook.logbookProvider> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:mpan
    rdf:type owl:DatatypeProperty ;
    rdfs:label "MPAN"@en ;
    rdfs:comment "Meter Point Administration Number — the electricity supply-point identifier for the Property. xsd:string (a fixed-width numeric identifier whose leading zeros are significant — the same convention opda:hasUPRN follows, NOT xsd:integer despite the data-dictionary typing). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.mainsElectricity.electricityMeter.mpan> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:mprn
    rdf:type owl:DatatypeProperty ;
    rdfs:label "MPRN"@en ;
    rdfs:comment "Meter Point Reference Number — the gas supply-point identifier for the Property. xsd:string (a fixed-width numeric identifier, per the opda:hasUPRN / opda:mpan convention, NOT xsd:integer). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.gasMeter.mprn> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:numberOfFloors
    rdf:type owl:DatatypeProperty ;
    rdfs:label "number of floors"@en ;
    rdfs:comment "Number of floors (storeys) the Property comprises. Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.building.numberOfFloors> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:integer .

opda:numberOfPropertiesSharing
    rdf:type owl:DatatypeProperty ;
    rdfs:label "number of properties sharing"@en ;
    rdfs:comment "Number of other properties sharing the Property's off-mains drainage system. Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.drainage.mainsFoulDrainage.offMainsDrainageSystem.otherConnectedProperties.numberOfPropertiesSharing> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:integer .

opda:otherCentralHeatingFuelType
    rdf:type owl:DatatypeProperty ;
    rdfs:label "other central heating fuel type"@en ;
    rdfs:comment "Free-text fuel classifier captured when the central-heating fuel is 'Other' (the open-ended companion to opda:centralHeatingFuelType). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.otherCentralHeatingFuelType> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:otherHeatingFeatures
    rdf:type owl:DatatypeProperty ;
    rdfs:label "other heating features"@en ;
    rdfs:comment "Additional heating features of the Property (a multi-valued list in the data dictionary — each value an xsd:string). UFO Quality of the physical Property. Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.otherHeatingFeatures> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:otherOwnershipDetails
    rdf:type owl:DatatypeProperty ;
    rdfs:label "other ownership details"@en ;
    rdfs:comment "Free-text ownership details captured when the ownership type is 'Other' for the LegalEstate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].otherOwnershipDetails> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:otherPropertiesInManagedArea
    rdf:type owl:DatatypeProperty ;
    rdfs:label "other properties in managed area"@en ;
    rdfs:comment "Count of other properties in the managed area sharing the leasehold LegalEstate's service arrangements. xsd:decimal (typed as a number in the data dictionary). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.general.otherPropertiesInManagedArea> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:decimal .

opda:otherType
    rdf:type owl:DatatypeProperty ;
    rdfs:label "other type"@en ;
    rdfs:comment "Free-text classifier captured when the Property's built-form / property-type is 'Other' (the open-ended companion to opda:propertyType). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.building.otherType> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:outsideAreas
    rdf:type owl:DatatypeProperty ;
    rdfs:label "outside areas"@en ;
    rdfs:comment "Outside areas of the Property — garden / yard / balcony / etc. (a multi-valued list — each value an xsd:string). UFO Quality of the physical Property. Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.residentialPropertyFeatures.outsideAreas> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:parkingArrangements
    rdf:type owl:DatatypeProperty ;
    rdfs:label "parking arrangements"@en ;
    rdfs:comment "Parking arrangements for the Property — allocated / on-street / garage / etc. (a multi-valued list — each value an xsd:string). UFO Quality of the physical Property. Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.parking.parkingArrangements> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:personWhoDealsWithTheDeedOfCovenant
    rdf:type owl:DatatypeProperty ;
    rdfs:label "person who deals with the deed of covenant"@en ;
    rdfs:comment "Name/role of the person who deals with the deed of covenant for the leasehold / managed-freehold LegalEstate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.transferAndRegistration.deedOfCovenantRequired.personWhoDealsWithTheDeedOfCovenant>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.transferAndRegistration.deedOfCovenantRequired.personWhoDealsWithTheDeedOfCovenant> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:pitch
    rdf:type owl:DatatypeProperty ;
    rdfs:label "pitch"@en ;
    rdfs:comment "Google Street View point-of-view pitch (degrees) for the Property's map locator. xsd:decimal numeric camera parameter. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.location.googleStreetViewPOV.pitch> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:decimal .

opda:procedureForObtainingCertificate
    rdf:type owl:DatatypeProperty ;
    rdfs:label "procedure for obtaining certificate"@en ;
    rdfs:comment "Procedure for obtaining a transfer/registration certificate on the leasehold / managed-freehold LegalEstate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.transferAndRegistration.procedureForObtainingCertificate>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.transferAndRegistration.procedureForObtainingCertificate> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:propertiesContributingToMaintenanceOfManagedArea
    rdf:type owl:DatatypeProperty ;
    rdfs:label "properties contributing to maintenance of managed area"@en ;
    rdfs:comment "Count of properties contributing to maintenance of the managed area for the leasehold LegalEstate. xsd:decimal (a number in the data dictionary). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.propertiesContributingToMaintenanceOfManagedArea> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:decimal .

opda:publicSewerMapAttached
    rdf:type owl:DatatypeProperty ;
    rdfs:label "public sewer map attached"@en ;
    rdfs:comment "Whether the public-sewer map is attached for the Property (a Yes/No-style string response in the data dictionary). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.maps.publicSewerMapAttached> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:receptions
    rdf:type owl:DatatypeProperty ;
    rdfs:label "receptions"@en ;
    rdfs:comment "Number of reception rooms in the Property. Plain integer datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.residentialPropertyFeatures.receptions> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:integer .

opda:rentIncreaseCalculated
    rdf:type owl:DatatypeProperty ;
    rdfs:label "rent increase calculated"@en ;
    rdfs:comment "How a ground-rent increase is calculated on the leasehold LegalEstate (e.g. RPI-linked, doubling). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.groundRent.rentSubjectToIncrease.rentIncreaseCalculated> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:rentReviewFrequency
    rdf:type owl:DatatypeProperty ;
    rdfs:label "rent review frequency"@en ;
    rdfs:comment "Frequency at which ground rent is reviewed on the leasehold LegalEstate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.groundRent.rentSubjectToIncrease.rentReviewFrequency> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:requirements
    rdf:type owl:DatatypeProperty ;
    rdfs:label "requirements"@en ;
    rdfs:comment "Requirements stated for a licence-to-assign on the leasehold LegalEstate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.transferAndRegistration.licenceToAssignRequired.requirements> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:sewerageBills
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sewerage bills"@en ;
    rdfs:comment "Free-text sewerage-billing description for the Property. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.charging.sewerageBills> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:sewerageProvider
    rdf:type owl:DatatypeProperty ;
    rdfs:label "sewerage provider"@en ;
    rdfs:comment "Name of the Property's sewerage provider. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.charging.sewerageProvider> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:sharedOwnershipPercentage
    rdf:type owl:DatatypeProperty ;
    rdfs:label "shared ownership percentage"@en ;
    rdfs:comment "Percentage of the Property owned under a shared-ownership leasehold LegalEstate. xsd:decimal (a number in the data dictionary). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.sharedOwnership.sharedOwnershipPercentage> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:decimal .

opda:startYearOfLease
    rdf:type owl:DatatypeProperty ;
    rdfs:label "start year of lease"@en ;
    rdfs:comment "Calendar year the leasehold term commenced. xsd:gYear (a year value in the data dictionary). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.leaseTerm.startYearOfLease> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:gYear .

opda:supplier
    rdf:type owl:DatatypeProperty ;
    rdfs:label "supplier"@en ;
    rdfs:comment "Name of the supplier for a Property utility / service (electricity, gas-fuel, heat-pump, solar, water, drainage, telephone, cable/satellite TV). ONE shared supplier-name property reused across the utility blocks (the data dictionary repeats the same `supplier` leaf under each). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.connectivity.cableSatelliteTV.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.connectivity.telephone.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.heatPump.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.mainsElectricity.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.otherSources.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.solarPanels.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.drainage.mainsFoulDrainage.supplier>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.water.mainsWater.supplier> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:supplyClassification
    rdf:type owl:DatatypeProperty ;
    rdfs:label "supply classification"@en ;
    rdfs:comment "Classification of the Property's water supply (e.g. metered / unmetered / rateable). A UFO Quale-in-Region of the physical Property. Plain string datatype per ODR-0008 §Q5a (no ontology-governed enum in the data dictionary); flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.water.supplyClassification> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:titleExtents
    rdf:type owl:DatatypeProperty ;
    rdfs:label "title extents"@en ;
    rdfs:comment "Statement of the extents covered by a title to be sold. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].titleExtents> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:titleNumber
    rdf:type owl:DatatypeProperty ;
    rdfs:label "title number"@en ;
    rdfs:comment "HMLR title number — identifies the registered-title RECORD (opda:RegisteredTitle), not the legal estate (ODR-0024 R8 / session-028 Q6). The estate has no title number; the record does — reach the estate via opda:recordsEstate. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].titleNumber>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].registerExtract.ocSummaryData.title.titleNumber>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.titlesToBeSold[].titleNumber> ;
    rdfs:domain opda:RegisteredTitle ;
    rdfs:range xsd:string .

opda:titlePropertyDescription
    rdf:type owl:DatatypeProperty ;
    rdfs:label "title property description"@en ;
    rdfs:comment "The property description as recorded on the title for the LegalEstate to be transferred. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].titlePropertyDescription> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:string .

opda:to
    rdf:type owl:DatatypeProperty ;
    rdfs:label "to"@en ;
    rdfs:comment "End date of a demand / decoration period on the leasehold / managed-freehold LegalEstate (mirror of opda:from). xsd:date. ONE shared period-end property reused across those periods; flat per §Q6a. (FLAG: `to` is a generic period-boundary name; reused across the estate's recurring date-range blocks.)"@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.buildingsInsurance.lastDemandPeriod.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.groundRent.lastDemandPeriod.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.lastDecoratedPeriod.externally.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.lastDecoratedPeriod.internally.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.lastDemandPeriod.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.insurance.managedAreaInsured.lastDemandPeriod.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.lastDecoratedPeriod.externally.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.lastDecoratedPeriod.internally.to>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].managedFreeholdOrCommonholdInformation.serviceCharge.lastDemandPeriod.to> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:date .

opda:typeOfFlooding
    rdf:type owl:DatatypeProperty ;
    rdfs:label "type of flooding"@en ;
    rdfs:comment "Type(s) of historical flooding the Property has experienced (a multi-valued list — each value an xsd:string). UFO Quality of the physical Property. Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a. (The per-peril flood RISK ASSESSMENT is opda:RiskAssessment territory; this is the factual historical-flooding-type attribute.)"@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.environmentalIssues.flooding.historicalFlooding.typeOfFlooding> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:waterBills
    rdf:type owl:DatatypeProperty ;
    rdfs:label "water bills"@en ;
    rdfs:comment "Free-text water-billing description for the Property. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.charging.waterBills> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:waterProvider
    rdf:type owl:DatatypeProperty ;
    rdfs:label "water provider"@en ;
    rdfs:comment "Name of the Property's water-supply provider. Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.charging.waterProvider> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:waterworksMapAttached
    rdf:type owl:DatatypeProperty ;
    rdfs:label "waterworks map attached"@en ;
    rdfs:comment "Whether the waterworks map is attached for the Property (a Yes/No-style string response). Plain string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.waterAndDrainage.maps.waterworksMapAttached> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

opda:willHandoverLogbook
    rdf:type owl:DatatypeProperty ;
    rdfs:label "will handover logbook"@en ;
    rdfs:comment "Whether the seller will hand over the digital property logbook on completion. xsd:boolean. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.completionAndMoving.digitalPropertyLogbook.willHandoverLogbook> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:boolean .

opda:year
    rdf:type owl:DatatypeProperty ;
    rdfs:label "year"@en ;
    rdfs:comment "Calendar year of a service-charge last-decorated period (externally / internally) on the leasehold LegalEstate. xsd:gYear. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.lastDecoratedPeriod.externally.year>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].leaseholdInformation.serviceCharge.lastDecoratedPeriod.internally.year> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range xsd:gYear .

opda:yearCompleted
    rdf:type owl:DatatypeProperty ;
    rdfs:label "year completed"@en ;
    rdfs:comment "Calendar year a Property alteration / change was completed (change of use, conservatory addition, window replacement since 2002). xsd:gYear. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.alterationsAndChanges.changeOfUse.yearCompleted>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.alterationsAndChanges.hasAddedConservatory.yearCompleted>, <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.alterationsAndChanges.windowReplacementsSince2002.yearCompleted> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:gYear .

opda:yearInstalled
    rdf:type owl:DatatypeProperty ;
    rdfs:label "year installed"@en ;
    rdfs:comment "Calendar year the Property's solar-panel system was installed. xsd:gYear (a year value in the data dictionary). Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricity.solarPanels.yearInstalled> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:gYear .

opda:yearOfBuild
    rdf:type owl:DatatypeProperty ;
    rdfs:label "year of build"@en ;
    rdfs:comment "Calendar year the Property was built. xsd:gYear — the data dictionary types it as a year value; plain datatype per ODR-0008 §Q5a, flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.yearOfBuild>, <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].basicDetails.buildInformation.yearOfBuild> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:gYear .

opda:yearTested
    rdf:type owl:DatatypeProperty ;
    rdfs:label "year tested"@en ;
    rdfs:comment "Calendar year the Property's electrical installation was last tested by a qualified electrician. xsd:gYear. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricalWorks.testedByQualifiedElectrician.yearTested> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:gYear .

opda:yearWorkCarriedOut
    rdf:type owl:DatatypeProperty ;
    rdfs:label "year work carried out"@en ;
    rdfs:comment "Calendar year electrical work was carried out on the Property (since 2005). xsd:gYear. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.electricalWorks.electricalWorkSince2005.yearWorkCarriedOut> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:gYear .

opda:zoom
    rdf:type owl:DatatypeProperty ;
    rdfs:label "zoom"@en ;
    rdfs:comment "Google Street View point-of-view zoom level for the Property's map locator. xsd:decimal numeric camera parameter. Flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.location.googleStreetViewPOV.zoom> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:decimal .

opda:areBoundariesUniform
    rdf:type owl:ObjectProperty ;
    rdfs:label "are boundaries uniform"@en ;
    rdfs:comment "Yes/No discriminator: are the Property's legal and physical boundaries uniform (i.e. do they match)? Bound to opda:YesNoScheme via SHACL sh:in in the BASPI5 profile."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:builtForm
    rdf:type owl:ObjectProperty ;
    rdfs:label "built form"@en ;
    rdfs:comment "Property built-form classification per opda:BuiltFormScheme (SKOS scheme in opda-vocabularies.ttl). UFO Quale-in-Region. Constrained by SHACL sh:in to the BuiltForm scheme members (ADR-0012 emits the constraint)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.building.builtForm> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:centralHeatingFuelType
    rdf:type owl:ObjectProperty ;
    rdfs:label "central heating fuel type"@en ;
    rdfs:comment "Fuel classification for a Property's central heating system per opda:CentralHeatingFuelTypeScheme (Mains gas / Electricity / Oil / LPG / Biomass / Other). UFO Quale-in-Region. Constrained by SHACL sh:in to the scheme members in the BASPI5 profile."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.heatingSystem.centralHeatingDetails.centralHeatingFuel.centralHeatingFuelType> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:currentEnergyRating
    rdf:type owl:ObjectProperty ;
    rdfs:label "current energy rating"@en ;
    rdfs:comment "EPC current energy rating band (A–G) per opda:CurrentEnergyRatingScheme. UFO Quale-in-Region. Regulator-sourced enum (DESNZ-governed). Constrained by SHACL sh:in to the scheme members (ADR-0012 emits the constraint)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.energyEfficiency.certificate.currentEnergyRating> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:hasAddress
    rdf:type owl:ObjectProperty ;
    rdfs:label "has address"@en ;
    rdfs:comment "Canonical bearer → Address join predicate. Per ODR-0005 §6b pre-commitment and ODR-0015 §3a, opda:hasAddress is uniform across variants — one bearer may hasAddress multiple Address instances differing on opda:addressVariant (title / marketing / inspire). Per Council session-047 Q6 the predicate is bearer-extended to Person/Organisation: no rdfs:domain (a single Property-only domain would entail every addressed Person is a Property — Hendler); bearer-typing (Property∪Person∪Organisation) lives in SHACL opda:HasAddressBearerShape. rdfs:range opda:Address kept; the Address class/IC stays ODR-0015-pending (Mode-vs-Resource open)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0015/section-3a> ;
    rdfs:range opda:Address .

opda:hasBeenFlooded
    rdf:type owl:ObjectProperty ;
    rdfs:label "has been flooded"@en ;
    rdfs:comment "Yes/No discriminator: has the Property been flooded? BASPI5 environmental-issue question. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:hasEPCCertificate
    rdf:type owl:ObjectProperty ;
    rdfs:label "has EPC certificate"@en ;
    rdfs:comment "Property → opda:EPCCertificate join predicate. The energy rating band stays on the Property as opda:currentEnergyRating (its rdfs:domain); this join reaches the certificate Entity as a distinct PROV-O artefact (10-year lifecycle, DESNZ register)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.energyEfficiency.certificate> ;
    rdfs:domain opda:Property ;
    rdfs:range opda:EPCCertificate .

opda:hasSmartHomeSystems
    rdf:type owl:ObjectProperty ;
    rdfs:label "has smart home systems"@en ;
    rdfs:comment "Yes/No discriminator: does the Property have smart-home systems installed? BASPI5 smart-home question. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:hasSprayFoamInstalled
    rdf:type owl:ObjectProperty ;
    rdfs:label "has spray foam installed"@en ;
    rdfs:comment "Yes/No discriminator: has spray-foam insulation been installed in the Property? Relevant for mortgage-eligibility per BASPI5. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:hasValidGuaranteesOrWarranties
    rdf:type owl:ObjectProperty ;
    rdfs:label "has valid guarantees or warranties"@en ;
    rdfs:comment "Yes/No discriminator: does the Property carry valid guarantees, warranties, or indemnity insurances? BASPI5 guarantees question. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:heatingType
    rdf:type owl:ObjectProperty ;
    rdfs:label "heating type"@en ;
    rdfs:comment "Property heating-system arrangement per opda:HeatingTypeScheme (Central heating / Communal heating system / Room heaters only / None). UFO Quale-in-Region. Constrained by SHACL sh:in to the scheme members in the BASPI5 profile."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.heating.heatingSystem.heatingType> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:identifiesSameProperty
    rdf:type owl:ObjectProperty ;
    rdfs:label "identifies same property"@en ;
    rdfs:comment "Co-reference predicate from any identity-bearing surface (RegisteredTitle, LegalEstate, Address) to the physical Property they identify. Per ODR-0005 Rule 5: NEVER use owl:sameAs (which would propagate every context's properties onto every other under inference). Domain intentionally unconstrained — any class with co-reference responsibility may emit this predicate."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0005/section-2a> ;
    rdfs:range opda:Property .

opda:isGroundRentPayable
    rdf:type owl:ObjectProperty ;
    rdfs:label "is ground rent payable"@en ;
    rdfs:comment "Yes/No discriminator: is ground rent payable on the Leasehold? BASPI5 ground-rent question. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range skos:Concept .

opda:isInsured
    rdf:type owl:ObjectProperty ;
    rdfs:label "is insured"@en ;
    rdfs:comment "Yes/No discriminator: is the Property currently insured? BASPI5 insurance question. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:isLocatedOverCommercialPremises
    rdf:type owl:ObjectProperty ;
    rdfs:label "is located over commercial premises"@en ;
    rdfs:comment "Yes/No discriminator: is the Property located over commercial premises? Applies to Flats and Maisonettes per BASPI5 question A1.8.6.1. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:isSharedOwnership
    rdf:type owl:ObjectProperty ;
    rdfs:label "is shared ownership"@en ;
    rdfs:comment "Yes/No discriminator: is the LegalEstate a shared-ownership lease? Applies to Leasehold ownership per BASPI5 question A1.3.1. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range skos:Concept .

opda:isSupplyMetered
    rdf:type owl:ObjectProperty ;
    rdfs:label "is supply metered"@en ;
    rdfs:comment "Yes/No discriminator: is the Property's utility supply (electricity / water / gas) metered? BASPI5 utility questions. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:offMainsDrainageSystemType
    rdf:type owl:ObjectProperty ;
    rdfs:label "off-mains drainage system type"@en ;
    rdfs:comment "Off-mains drainage classification per opda:OffMainsDrainageSystemTypeScheme (SuDS / Septic tank / Cesspit / Sewerage treatment plant / Other / Not known). Applies when not connected to mains sewerage."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:ownershipType
    rdf:type owl:ObjectProperty ;
    rdfs:label "ownership type"@en ;
    rdfs:comment "Ownership-type classification per opda:OwnershipTypeScheme (Freehold / Leasehold / Commonhold / Managed Freehold / Other). UFO Quale-in-Region of LegalEstate. Constrained by SHACL sh:in to the scheme members in the BASPI5 profile."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.ownership.ownershipsToBeTransferred[].ownershipType> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range skos:Concept .

opda:propertyType
    rdf:type owl:ObjectProperty ;
    rdfs:label "property type"@en ;
    rdfs:comment "Substance Kind label classifying the physical-form Kind of a Property per opda:PropertyTypeScheme (House / Bungalow / Park home / Flat / Maisonette / Other). Distinct from opda:builtForm (Quale-in-Region structural classification). Constrained by SHACL sh:in to the scheme members in the BASPI5 profile."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.buildInformation.building.propertyType>, <https://opda.org.uk/pdtf/harness/data-dictionary/valuationComparisonData.propertyDetails[].propertyType> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:recordsEstate
    rdf:type owl:ObjectProperty ;
    rdfs:label "records estate"@en ;
    rdfs:comment "Title-to-estate join: the RegisteredTitle's HMLR record names the LegalEstate it documents. Per ODR-0005 §3c, this is the three-way structural seam (RegisteredTitle recordsEstate LegalEstate; LegalEstate vests in Property; RegisteredTitle identifiesSameProperty Property)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0005/section-3c> ;
    rdfs:domain opda:RegisteredTitle ;
    rdfs:range opda:LegalEstate .

opda:sellerContributesToServiceCharge
    rdf:type owl:ObjectProperty ;
    rdfs:label "seller contributes to service charge"@en ;
    rdfs:comment "Yes/No discriminator: does the Seller contribute to a service charge for the Property? Applies to Leasehold / Managed Freehold / Commonhold per BASPI5. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range skos:Concept .

opda:soldWithVacantPossession
    rdf:type owl:ObjectProperty ;
    rdfs:label "sold with vacant possession"@en ;
    rdfs:comment "Yes/No discriminator: is the Property sold with vacant possession (vs sold subject to existing tenancies)? BASPI5 completion question. Bound to opda:YesNoScheme."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:Property ;
    rdfs:range skos:Concept .

opda:tenureKind
    rdf:type owl:ObjectProperty ;
    rdfs:label "tenure kind"@en ;
    rdfs:comment "Tenure classification per opda:TenureKindScheme — Substance Kind label (Freehold / Leasehold / Commonhold), a coded facet on opda:LegalEstate enforced by SHACL sh:in. Per the ODR-0011 §8a load-bearing cascade (Council session-036), tenure is +R but −I (no distinct identity criterion; tenure-change is a value change, not a re-typing) → classification, NOT a subclass: opda does NOT mint Freehold/Leasehold/Commonhold OWL sub-classes, and no skos:exactMatch-to-subclass is emitted (the §8a subclass binding applies only to load-bearing +I labels)."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/odr/ODR-0008/section-Q5a> ;
    rdfs:domain opda:LegalEstate ;
    rdfs:range skos:Concept .
