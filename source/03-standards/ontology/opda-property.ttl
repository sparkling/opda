    rdf:type owl:DatatypeProperty ;
    rdfs:label "accessibility and adaptations"@en ;
    rdfs:comment "Accessibility features and adaptations of the Property (a multi-valued list — each value an xsd:string). UFO Quality of the physical Property. Plain multi-valued string datatype per ODR-0008 §Q5a; flat per §Q6a."@en ;
    dct:source <https://opda.org.uk/pdtf/harness/data-dictionary/propertyPack.typeOfConstruction.accessibilityAndAdaptations> ;
    rdfs:domain opda:Property ;
    rdfs:range xsd:string .

